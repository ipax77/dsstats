+function closeModalByIdAndWait(id) {
+    const started = performance.now();
+    console.log("closing modal wait - " + Date.now());
+    const modalElement = document.getElementById(id);
+    if (!modalElement) {
+        console.log("closing modal wait missing - " + Date.now());
+        return Promise.resolve();
+    }
+
+    return new Promise(resolve => {
+        let resolved = false;
+        const timeoutId = setTimeout(() => finish("timeout"), 1500);
+
+        const finish = (reason) => {
+            if (resolved) return;
+
+            resolved = true;
+            clearTimeout(timeoutId);
+            modalElement.removeEventListener('hidden.bs.modal', onHidden);
+            requestAnimationFrame(() => {
+                console.log(`closing modal ${reason} raf elapsed=${(performance.now() - started).toFixed(1)}ms - ${Date.now()}`);
+                resolve();
+            });
+        };
+
+        const onHidden = () => {
+            console.log(`closing modal hidden elapsed=${(performance.now() - started).toFixed(1)}ms - ${Date.now()}`);
+            finish("hidden");
+        };
+
+        modalElement.addEventListener('hidden.bs.modal', onHidden, { once: true });
+
+        const modal = bootstrap.Modal.getInstance(modalElement);
+        if (modal && modalElement.classList.contains('show')) {
+            modal.hide();
+            console.log(`closing modal hide requested elapsed=${(performance.now() - started).toFixed(1)}ms - ${Date.now()}`);
+        } else {
+            console.log(`closing modal no instance elapsed=${(performance.now() - started).toFixed(1)}ms - ${Date.now()}`);
+            finish("no instance");
+        }
+    });
 }
 

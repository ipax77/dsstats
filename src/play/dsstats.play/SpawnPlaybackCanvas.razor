@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using dsstats.shared
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

@if (playback is not null)
{
    <div class="spawn-playback bgchart border border-dark rounded p-3 mb-4">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
            <div>
                <h5 class="mb-1 text-warning">Spawn Playback</h5>
                <div class="small text-light">@CurrentTimeLabel</div>
            </div>
            <div class="btn-group" role="group" aria-label="Spawn playback controls">
                <button type="button" class="btn btn-sm btn-outline-light" title="Back 5 seconds" @onclick="StepBackward">
                    <span class="bi bi-chevron-left"></span>
                </button>
                <button type="button" class="btn btn-sm btn-outline-light" title="Forward 5 seconds" @onclick="StepForward">
                    <span class="bi bi-chevron-right"></span>
                </button>
            </div>
        </div>
        <div class="spawn-playback-body">
            <div class="spawn-playback-canvas-wrap">
                <canvas @ref="canvasElement" class="spawn-playback-canvas"></canvas>
                <div class="spawn-playback-slider">
                    <input type="range"
                           class="form-range spawn-playback-range"
                           min="0"
                           max="@PlaybackStopMaxIndex"
                           step="1"
                           value="@currentPlaybackStopIndex"
                           disabled="@(playbackStops.Count <= 1)"
                           aria-label="Spawn playback position"
                           @oninput="SeekPlaybackStop" />
                    <div class="d-flex align-items-center justify-content-between gap-2 small text-muted">
                        <span>@FirstPlaybackStopLabel</span>
                        <span>@CurrentPlaybackStopLabel</span>
                        <span>@LastPlaybackStopLabel</span>
                    </div>
                </div>
            </div>
            <div class="spawn-playback-alive">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <div>
                        <h6 class="mb-0 text-warning">Alive Units</h6>
                        <div class="small text-muted">Current spawn @CurrentSpawnLabel</div>
                    </div>
                    <span class="badge text-bg-dark border border-secondary">@aliveUnitCount.ToString("N0") units</span>
                </div>
                <div class="spawn-playback-team-tables">
                    <section class="spawn-playback-team-table">
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                            <div class="small fw-semibold text-info">Team 1</div>
                            <div class="small text-muted">@team1AliveCount.ToString("N0") units</div>
                        </div>
                        <div class="table-responsive spawn-playback-alive-table">
                            <table class="table table-dark table-sm table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Unit</th>
                                        <th class="text-end">Alive</th>
                                        <th class="text-end">Kills</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (team1AliveUnitRows.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="3" class="text-muted text-center py-3">No estimated alive units</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var row in team1AliveUnitRows)
                                        {
                                            <tr>
                                                <td class="text-truncate" title="@row.UnitName">@row.UnitName</td>
                                                <td class="text-end">@row.AliveCount.ToString("N0")</td>
                                                <td class="text-end">@row.CurrentKills</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                    <section class="spawn-playback-team-table">
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                            <div class="small fw-semibold text-danger">Team 2</div>
                            <div class="small text-muted">@team2AliveCount.ToString("N0") units</div>
                        </div>
                        <div class="table-responsive spawn-playback-alive-table">
                            <table class="table table-dark table-sm table-striped align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Unit</th>
                                        <th class="text-end">Alive</th>
                                        <th class="text-end">Kills</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (team2AliveUnitRows.Count == 0)
                                    {
                                        <tr>
                                            <td colspan="3" class="text-muted text-center py-3">No estimated alive units</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var row in team2AliveUnitRows)
                                        {
                                            <tr>
                                                <td class="text-truncate" title="@row.UnitName">@row.UnitName</td>
                                                <td class="text-end">@row.AliveCount.ToString("N0")</td>
                                                <td class="text-end">@row.CurrentKills</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public ReplayDto? Replay { get; set; }

    [Parameter]
    public SpawnPlaybackSidecarDto? Sidecar { get; set; }

    private ElementReference canvasElement;
    private IJSObjectReference? module;
    private ReplayDto? currentReplay;
    private SpawnPlaybackSidecarDto? currentSidecar;
    private SpawnPlaybackReplay? playback;
    private SpawnPlaybackReplay? initializedReplay;
    private int currentGameloop;
    private int renderGameloop;
    private readonly List<int> playbackStops = [];
    private int currentPlaybackStopIndex;
    private bool canvasDrawPending;
    private readonly List<AliveUnitRow> team1AliveUnitRows = [];
    private readonly List<AliveUnitRow> team2AliveUnitRows = [];
    private int aliveUnitCount;
    private int team1AliveCount;
    private int team2AliveCount;
    private int currentSpawnNumber;

    private string CurrentTimeLabel =>
        playback is null
            ? string.Empty
            : $"{Math.Round(renderGameloop / SpawnPlaybackFactory.GameloopsPerSecond, 1):0.0}s / gameloop {renderGameloop:N0}";

    private string CurrentSpawnLabel => currentSpawnNumber > 0 ? currentSpawnNumber.ToString("N0") : "-";

    private int PlaybackStopMaxIndex => Math.Max(0, playbackStops.Count - 1);

    private string FirstPlaybackStopLabel => playbackStops.Count == 0 ? string.Empty : FormatGameloopSeconds(playbackStops[0]);

    private string CurrentPlaybackStopLabel => playbackStops.Count == 0
        ? string.Empty
        : $"{currentPlaybackStopIndex + 1:N0} / {playbackStops.Count:N0}";

    private string LastPlaybackStopLabel => playbackStops.Count == 0
        ? string.Empty
        : FormatGameloopSeconds(playbackStops[^1]);

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(currentReplay, Replay) || !ReferenceEquals(currentSidecar, Sidecar))
        {
            currentReplay = Replay;
            currentSidecar = Sidecar;
            playback = Replay is not null && Sidecar is not null
                ? SpawnPlaybackFactory.Create(Replay, Sidecar)
                : null;
            initializedReplay = null;
            BuildPlaybackStops(playback);
            currentGameloop = GetFirstPlaybackGameloop(playback);
            currentPlaybackStopIndex = FindPlaybackStopIndexAtOrBefore(currentGameloop);
            SetRenderGameloop(force: true);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (playback is null)
        {
            return;
        }

        module ??= await JSRuntime.InvokeAsync<IJSObjectReference>(
            "import",
            "./_content/dsstats.play/spawnPlayback.js");

        if (!ReferenceEquals(initializedReplay, playback))
        {
            initializedReplay = playback;
            await module.InvokeVoidAsync("initializeSpawnPlayback", canvasElement, playback);
            canvasDrawPending = true;
        }

        if (canvasDrawPending)
        {
            await module.InvokeVoidAsync("drawSpawnPlayback", canvasElement, renderGameloop);
            canvasDrawPending = false;
        }
    }

    private Task StepBackward()
    {
        if (playback is null)
        {
            return Task.CompletedTask;
        }

        currentGameloop = Math.Max(GetFirstPlaybackGameloop(playback), currentGameloop - playback.StepGameloops);
        SetRenderGameloop();
        currentPlaybackStopIndex = FindPlaybackStopIndexAtOrBefore(renderGameloop);
        return Task.CompletedTask;
    }

    private Task StepForward()
    {
        if (playback is null)
        {
            return Task.CompletedTask;
        }

        currentGameloop = Math.Min(playback.DurationGameloop, currentGameloop + playback.StepGameloops);
        SetRenderGameloop();
        currentPlaybackStopIndex = FindPlaybackStopIndexAtOrBefore(renderGameloop);
        return Task.CompletedTask;
    }

    private Task SeekPlaybackStop(ChangeEventArgs args)
    {
        if (playback is null || playbackStops.Count == 0)
        {
            return Task.CompletedTask;
        }

        int nextIndex = ParsePlaybackStopIndex(args.Value);
        if (nextIndex == currentPlaybackStopIndex && playbackStops[nextIndex] == currentGameloop)
        {
            return Task.CompletedTask;
        }

        currentPlaybackStopIndex = nextIndex;
        currentGameloop = playbackStops[nextIndex];
        SetRenderGameloop();
        return Task.CompletedTask;
    }

    private bool SetRenderGameloop(bool force = false)
    {
        int nextRenderGameloop = ResolveRenderGameloop(playback, currentGameloop);
        if (!force && nextRenderGameloop == renderGameloop)
        {
            return false;
        }

        renderGameloop = nextRenderGameloop;
        UpdateAliveUnitRows();
        canvasDrawPending = true;
        return true;
    }

    private void BuildPlaybackStops(SpawnPlaybackReplay? replay)
    {
        playbackStops.Clear();
        if (replay is null)
        {
            currentPlaybackStopIndex = 0;
            return;
        }

        int firstGameloop = GetFirstPlaybackGameloop(replay);
        if (replay.Snapshots.Count > 0)
        {
            AddPlaybackStop(firstGameloop);
            foreach (var snapshot in replay.Snapshots)
            {
                AddPlaybackStop(snapshot.EndGameloop);
            }

            AddPlaybackStop(replay.DurationGameloop);
            playbackStops.Sort();
            RemoveDuplicatePlaybackStops();
            return;
        }

        int stepGameloops = Math.Max(1, replay.StepGameloops);
        int fallbackGameloop = firstGameloop;
        while (fallbackGameloop < replay.DurationGameloop)
        {
            playbackStops.Add(fallbackGameloop);
            if (replay.DurationGameloop - fallbackGameloop <= stepGameloops)
            {
                break;
            }

            fallbackGameloop += stepGameloops;
        }

        AddPlaybackStop(firstGameloop);
        AddPlaybackStop(replay.DurationGameloop);
        playbackStops.Sort();
        RemoveDuplicatePlaybackStops();
    }

    private void AddPlaybackStop(int gameloop)
    {
        if (playbackStops.Count == 0 || playbackStops[^1] != gameloop)
        {
            playbackStops.Add(gameloop);
        }
    }

    private void RemoveDuplicatePlaybackStops()
    {
        if (playbackStops.Count < 2)
        {
            return;
        }

        int writeIndex = 1;
        int previous = playbackStops[0];
        for (int readIndex = 1; readIndex < playbackStops.Count; readIndex++)
        {
            int current = playbackStops[readIndex];
            if (current == previous)
            {
                continue;
            }

            playbackStops[writeIndex] = current;
            previous = current;
            writeIndex++;
        }

        if (writeIndex < playbackStops.Count)
        {
            playbackStops.RemoveRange(writeIndex, playbackStops.Count - writeIndex);
        }
    }

    private int ParsePlaybackStopIndex(object? value)
    {
        if (value is int index)
        {
            return ClampPlaybackStopIndex(index);
        }

        return value is string text && int.TryParse(text, out index)
            ? ClampPlaybackStopIndex(index)
            : currentPlaybackStopIndex;
    }

    private int ClampPlaybackStopIndex(int index)
    {
        if (index < 0)
        {
            return 0;
        }

        int maxIndex = playbackStops.Count - 1;
        return index > maxIndex ? maxIndex : index;
    }

    private int FindPlaybackStopIndexAtOrBefore(int gameloop)
    {
        int left = 0;
        int right = playbackStops.Count - 1;
        int index = 0;
        while (left <= right)
        {
            int middle = left + (right - left) / 2;
            if (playbackStops[middle] <= gameloop)
            {
                index = middle;
                left = middle + 1;
            }
            else
            {
                right = middle - 1;
            }
        }

        return index;
    }

    private static string FormatGameloopSeconds(int gameloop)
    {
        return $"{Math.Round(gameloop / SpawnPlaybackFactory.GameloopsPerSecond, 1):0.0}s";
    }

    private void UpdateAliveUnitRows()
    {
        team1AliveUnitRows.Clear();
        team2AliveUnitRows.Clear();
        aliveUnitCount = 0;
        team1AliveCount = 0;
        team2AliveCount = 0;
        currentSpawnNumber = 0;
        if (playback is null)
        {
            return;
        }

        Dictionary<AliveUnitKey, AliveUnitAccumulator> rows = [];
        foreach (var player in playback.Players)
        {
            foreach (var unit in player.Units)
            {
                if (unit.SpawnGameloop > renderGameloop)
                {
                    continue;
                }

                currentSpawnNumber = Math.Max(currentSpawnNumber, unit.SpawnNumber);
                if (unit.ExpiresGameloop <= renderGameloop)
                {
                    continue;
                }

                aliveUnitCount++;
                if (player.TeamId == 1)
                {
                    team1AliveCount++;
                }
                else if (player.TeamId == 2)
                {
                    team2AliveCount++;
                }

                var key = new AliveUnitKey(player.TeamId, unit.Name);
                rows.TryGetValue(key, out var row);
                rows[key] = row.Add(GetCurrentKills(unit.KillGameloops, renderGameloop));
            }
        }

        foreach (var pair in rows)
        {
            var row = new AliveUnitRow(
                pair.Key.TeamId,
                pair.Key.UnitName,
                pair.Value.AliveCount,
                pair.Value.CurrentKills);
            if (pair.Key.TeamId == 1)
            {
                team1AliveUnitRows.Add(row);
            }
            else if (pair.Key.TeamId == 2)
            {
                team2AliveUnitRows.Add(row);
            }
        }

        team1AliveUnitRows.Sort(CompareAliveUnitRows);
        team2AliveUnitRows.Sort(CompareAliveUnitRows);
    }

    private static int CompareAliveUnitRows(AliveUnitRow left, AliveUnitRow right)
    {
        return string.Compare(left.UnitName, right.UnitName, StringComparison.Ordinal);
    }

    private readonly record struct AliveUnitKey(int TeamId, string UnitName);

    private readonly record struct AliveUnitAccumulator(int AliveCount, int CurrentKills)
    {
        public AliveUnitAccumulator Add(int kills)
        {
            return new(AliveCount + 1, CurrentKills + kills);
        }
    }

    private static int GetCurrentKills(IReadOnlyList<int> killGameloops, int currentGameloop)
    {
        int kills = 0;
        while (kills < killGameloops.Count && killGameloops[kills] <= currentGameloop)
        {
            kills++;
        }

        return kills;
    }

    private static int GetFirstPlaybackGameloop(SpawnPlaybackReplay? replay)
    {
        if (replay is null)
        {
            return 0;
        }

        return replay.Snapshots.Count > 0
            ? replay.Snapshots[0].EndGameloop
            : GetFirstUnitSpawnGameloop(replay);
    }

    private static int GetFirstUnitSpawnGameloop(SpawnPlaybackReplay? replay)
    {
        return replay?.Players
            .SelectMany(player => player.Units)
            .Select(unit => unit.SpawnGameloop)
            .DefaultIfEmpty(0)
            .Min() ?? 0;
    }

    private static int ResolveRenderGameloop(SpawnPlaybackReplay? replay, int gameloop)
    {
        if (replay is null || replay.Snapshots.Count == 0)
        {
            return gameloop;
        }

        int left = 0;
        int right = replay.Snapshots.Count - 1;
        int candidateIndex = -1;
        while (left <= right)
        {
            int middle = left + (right - left) / 2;
            if (replay.Snapshots[middle].StartGameloop <= gameloop)
            {
                candidateIndex = middle;
                left = middle + 1;
            }
            else
            {
                right = middle - 1;
            }
        }

        if (candidateIndex < 0)
        {
            return gameloop;
        }

        int renderGameloop = gameloop;
        for (int i = candidateIndex; i >= 0; i--)
        {
            var snapshot = replay.Snapshots[i];
            if (snapshot.EndGameloop < gameloop)
            {
                break;
            }

            renderGameloop = Math.Max(renderGameloop, snapshot.EndGameloop);
        }

        return renderGameloop;
    }

    public async ValueTask DisposeAsync()
    {
        if (module is not null)
        {
            try
            {
                await module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }

    private sealed record AliveUnitRow(
        int TeamId,
        string UnitName,
        int AliveCount,
        int CurrentKills);
}

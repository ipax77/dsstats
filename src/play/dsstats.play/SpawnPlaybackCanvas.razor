@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using System.Buffers.Binary
@using dsstats.shared
@using dsstats.shared.Interfaces
@using dsstats.shared.Units
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject IUnitLifeCostService UnitLifeCostService

@if (playback is not null)
{
    <div @ref="playbackElement" class="spawn-playback bgchart border border-dark rounded p-3 mb-4 @(showAliveUnits ? null : "spawn-playback-alive-collapsed")">
        <div class="spawn-playback-toolbar d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
            <div>
                <h5 class="mb-1 text-warning">Spawn Playback</h5>
                <div class="small text-light">@CurrentTimeLabel</div>
                <div class="small text-muted">@PlaybackStatusLabel</div>
            </div>
            <div class="spawn-playback-toolbar-actions d-flex flex-wrap align-items-center gap-2">
                <div class="btn-group" role="group" aria-label="Spawn playback controls">
                    <button type="button" class="btn btn-sm btn-outline-light" title="Back 5 seconds" @onclick="StepBackward">
                        <span class="bi bi-chevron-left"></span>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-light" title="@PlayPauseTitle" @onclick="TogglePlayback">
                        <span class="bi @PlayPauseIcon"></span>
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-outline-light"
                            title="Stop"
                            disabled="@(animationState == SpawnPlaybackAnimationState.Stopped)"
                            @onclick="StopAnimation">
                        <span class="bi bi-stop-fill"></span>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-light" title="Forward 5 seconds" @onclick="StepForward">
                        <span class="bi bi-chevron-right"></span>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-light" title="@FullscreenTitle" @onclick="ToggleFullscreen">
                        <span class="bi @FullscreenIcon"></span>
                    </button>
                    <button type="button"
                            class="btn btn-sm @SpawnWaveOverlayButtonClass"
                            title="@SpawnWaveOverlayTitle"
                            aria-pressed="@showSpawnWaveOverlay"
                            disabled="@(!HasSpawnWaveOverlayData)"
                            @onclick="ToggleSpawnWaveOverlay">
                        <span class="bi bi-table"></span>
                    </button>
                </div>
                <select class="form-select form-select-sm spawn-playback-speed"
                        aria-label="Spawn playback speed"
                        value="@selectedPlaybackSpeed"
                        @onchange="SetPlaybackSpeed">
                    <option value="slow">Slow</option>
                    <option value="normal">Normal</option>
                    <option value="fast">Fast</option>
                </select>
                <div class="spawn-playback-alive-controls d-flex align-items-center gap-2">
                    <button type="button"
                            class="btn btn-sm btn-outline-light spawn-playback-clear-highlight"
                            title="Clear unit highlight"
                            aria-label="Clear unit highlight"
                            data-spawn-playback-clear-highlight>
                        <span class="bi bi-x-lg"></span>
                    </button>
                    <button type="button"
                            class="btn btn-sm btn-outline-light"
                            title="@AliveUnitsToggleTitle"
                            aria-expanded="@showAliveUnits"
                            @onclick="ToggleAliveUnits">
                        <span class="bi @AliveUnitsToggleIcon"></span>
                    </button>
                    <span class="badge text-bg-dark border border-secondary">@aliveUnitCount.ToString("N0") units</span>
                </div>
            </div>
        </div>
        <div class="spawn-playback-body">
            <div class="spawn-playback-canvas-wrap">
                <canvas @ref="canvasElement" class="spawn-playback-canvas"></canvas>
                <div class="spawn-playback-slider">
                    <input type="range"
                           class="form-range spawn-playback-range"
                           min="0"
                           max="@PlaybackStopMaxIndex"
                           step="1"
                           value="@currentPlaybackStopIndex"
                           disabled="@(playbackStops.Count <= 1)"
                           aria-label="Spawn playback position"
                           @oninput="SeekPlaybackStop" />
                    <div class="d-flex align-items-center justify-content-between gap-2 small text-muted">
                        <span>@FirstPlaybackStopLabel</span>
                        <span>@CurrentPlaybackStopLabel</span>
                        <span>@LastPlaybackStopLabel</span>
                    </div>
                </div>
            </div>
            <div class="spawn-playback-alive">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                    <div>
                        <h6 class="mb-0 text-warning">Alive Units</h6>
                        <div class="small text-muted">Current spawn @CurrentSpawnLabel</div>
                    </div>
                </div>
                @if (showAliveUnits)
                {
                    <div class="spawn-playback-team-tables">
                        <section class="spawn-playback-team-table">
                            <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                                <div class="small fw-semibold text-info">Team 1</div>
                                <div class="small text-muted">@team1AliveCount.ToString("N0") units</div>
                            </div>
                            <div class="table-responsive spawn-playback-alive-table">
                                <table class="table table-dark table-sm table-striped align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Unit</th>
                                            <th class="text-end">Alive</th>
                                            <th class="text-end">Kills</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (team1AliveUnitRows.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="3" class="text-muted text-center py-3">No estimated alive units</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var row in team1AliveUnitRows)
                                            {
                                                <tr class="spawn-playback-alive-row"
                                                    @key="row.HighlightKey"
                                                    role="button"
                                                    tabindex="0"
                                                    aria-pressed="false"
                                                    title="Highlight @row.UnitName on the canvas"
                                                    data-spawn-playback-alive-unit-row
                                                    data-spawn-playback-highlight-key="@row.HighlightKey">
                                                    <td title="@row.UnitName">
                                                        <span class="spawn-playback-unit-cell">
                                                            <UnitIcon Class="spawn-playback-unit-icon"
                                                                      Commander="@row.Commander"
                                                                      UnitName="@row.UnitName"
                                                                      Size="20"
                                                                      TeamId="@row.TeamId"
                                                                      TeamColor="@row.TeamColor"
                                                                      UnitColor="@row.UnitColor" />
                                                            <span class="text-truncate">@row.UnitName</span>
                                                        </span>
                                                    </td>
                                                    <td class="text-end">@row.AliveCount.ToString("N0")</td>
                                                    <td class="text-end">@row.CurrentKills</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </section>
                        <section class="spawn-playback-team-table">
                            <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                                <div class="small fw-semibold text-danger">Team 2</div>
                                <div class="small text-muted">@team2AliveCount.ToString("N0") units</div>
                            </div>
                            <div class="table-responsive spawn-playback-alive-table">
                                <table class="table table-dark table-sm table-striped align-middle mb-0">
                                    <thead>
                                        <tr>
                                            <th>Unit</th>
                                            <th class="text-end">Alive</th>
                                            <th class="text-end">Kills</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (team2AliveUnitRows.Count == 0)
                                        {
                                            <tr>
                                                <td colspan="3" class="text-muted text-center py-3">No estimated alive units</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var row in team2AliveUnitRows)
                                            {
                                                <tr class="spawn-playback-alive-row"
                                                    @key="row.HighlightKey"
                                                    role="button"
                                                    tabindex="0"
                                                    aria-pressed="false"
                                                    title="Highlight @row.UnitName on the canvas"
                                                    data-spawn-playback-alive-unit-row
                                                    data-spawn-playback-highlight-key="@row.HighlightKey">
                                                    <td title="@row.UnitName">
                                                        <span class="spawn-playback-unit-cell">
                                                            <UnitIcon Class="spawn-playback-unit-icon"
                                                                      Commander="@row.Commander"
                                                                      UnitName="@row.UnitName"
                                                                      Size="20"
                                                                      TeamId="@row.TeamId"
                                                                      TeamColor="@row.TeamColor"
                                                                      UnitColor="@row.UnitColor" />
                                                            <span class="text-truncate">@row.UnitName</span>
                                                        </span>
                                                    </td>
                                                    <td class="text-end">@row.AliveCount.ToString("N0")</td>
                                                    <td class="text-end">@row.CurrentKills</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    </div>
                }
            </div>
        </div>
    </div>
}

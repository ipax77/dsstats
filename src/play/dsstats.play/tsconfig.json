{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2022",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "removeComments": true,
    "preserveConstEnums": true,
    "rootDir": "./TypeScript",
    "sourceMap": false,
    "noEmit": true,
    "strict": true,
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./TypeScript/**/*.ts"
  ]
}

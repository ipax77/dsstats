<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <SpawnPlaybackSources Include="TypeScript/**/*.ts" />
  </ItemGroup>

  <PropertyGroup>
    <SpawnPlaybackOutput>wwwroot/spawnPlayback.js</SpawnPlaybackOutput>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="10.0.*" />
    <PackageReference Include="Microsoft.TypeScript.MSBuild" Version="6.0.3">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\common\dsstats.parser\dsstats.parser.csproj" />
    <ProjectReference Include="..\..\common\dsstats.shared\dsstats.shared.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="package.json;package-lock.json;tsconfig.json">
      <Pack>False</Pack>
    </None>
    <Content Update="package.json;package-lock.json;tsconfig.json">
      <Pack>False</Pack>
    </Content>
  </ItemGroup>

  <Target Name="RestoreSpawnPlaybackNodePackages"
          BeforeTargets="BuildSpawnPlayback"
          Inputs="package.json;package-lock.json"
          Outputs="node_modules/.package-lock.json">
    <Exec Command="npm ci" Condition="Exists('package-lock.json')" />
    <Exec Command="npm install" Condition="!Exists('package-lock.json')" />
  </Target>

  <Target Name="BuildSpawnPlayback"
          BeforeTargets="ResolveStaticWebAssetsInputs"
          DependsOnTargets="RestoreSpawnPlaybackNodePackages"
          Inputs="@(SpawnPlaybackSources);package.json;package-lock.json"
          Outputs="$(SpawnPlaybackOutput)">
    <Exec Command="npm run build" />
  </Target>

</Project>

@page "/"
@using Microsoft.Extensions.Localization
@using dsstats.db
@using dsstats.localization
@using dsstats.maui.Services
@using dsstats.shared
@using dsstats.shared.Interfaces
@using dsstats.shared.Maui
@using dsstats.weblib.Players
@using dsstats.weblib.Replays
@inherits CultureBaseComponent
@inject IReplayRepository ReplayRepository
@inject ImportState ImportState
@inject SessionProgress SessionProgress
@inject IPlayerService PlayerService
@implements IDisposable

<div class="container-fluid">

	<div class="bgchart border rounded p-3 mb-3">

		<div class="mb-2 text-muted">
			@Loc["Decode game replays into match statistics and ratings"]
		</div>

		<div class="d-flex align-items-start gap-3">

			<div>
				@if (ImportState.IsRunning)
				{
					<button type="button"
							class="btn btn-danger"
							@onclick="CancelImport">
						@Loc["Decoding in Progress... (Stop)"]
					</button>
				}
				else
				{
					<button type="button"
							class="btn btn-danger"
							@onclick="StartImportAsync">
						@Loc["Decode Replays"]
					</button>

					<div class="small text-muted mt-1">
						@Loc["Scans your replay folder and decodes all new games"]
					</div>
				}
			</div>

			<button type="button"
					class="btn btn-outline-light align-self-start"
					@onclick="UploadReplays">
				@Loc["Upload Replays"]
			</button>

		</div>
	</div>

	@if (replayDetails == null)
	{
		<div class="bgchart rounded p-3 mb-3">
			<h4 class="text-warning mb-1">
				@Loc["No replays decoded yet"]
			</h4>
			<div class="text-muted">
				@Loc["Click 'Decode Replays' above to scan your replay folder and generate statistics."]
			</div>
		</div>
	}

	<div class="row mt-3 g-4 align-items-start">
		<div class="col-auto">
			@if (replayDetails != null)
			{
				<div class="bgchart rounded p-2 d-inline-block">
					<div class="d-flex align-items-center gap-2">

						<div class="icon-slot">
							<div class="spinner-border spinner-border-sm @(loadingRatings ? "" : "d-none")"
								 role="status">
								<span class="visually-hidden">Loading...</span>
							</div>

							<i class="bi bi-camera-reels @(loadingRatings ? "d-none" : "")"></i>
						</div>

						<h4 class="text-warning mb-0">
							@(replayDetails.ReplayHash == latestReplayHash ? Loc["Latest Replay"] : Loc["Recent Replay"])
						</h4>

					</div>
				</div>
				<div>
					<ReplayComponent @ref="replayComponent" ReplayDetails="replayDetails"
									 IsScrollable="true"
									 IsCloseable="false"
									 OnPlayerRequest="e => playerModal?.Show(e)"
									 OnScrollRequest="e => ScrollReplay(e)"
									 OnRatingUpdateRequest="UpdateRatings" />
				</div>
			}
		</div>

		<div class="col-auto">
			<div class="card border-light" style="max-width: 390px;">
				<div class="card-header bgchart2">
					<div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
						<h4 class="text-warning mb-0">@Loc["Session Progress"]</h4>
						<a href="config" class="btn btn-sm btn-outline-light">
							<i class="bi bi-person-badge me-1"></i>@Loc["Settings"]
						</a>
					</div>
				</div>
				<div class="card-body bgchart">
					@if (!uploadEnabled)
					{
						<div class="alert alert-secondary mb-0">
							<div class="fw-semibold mb-2">@Loc["Upload Replays to {0}", "dsstats.pax77.org"]</div>
							<p class="small mb-3">
								Session progress uses replay ratings from the server. Enable uploads first, then recent replays can show rating gain and winrate.
							</p>
							<button class="btn btn-primary" @onclick="EnableUploadAndRefresh">
								<i class="bi bi-cloud-upload me-2"></i>@Loc["Upload Replays"]
							</button>
						</div>
					}
					else
					{
						<div class="row align-items-center gap-2 mb-3">
							<div role="group" aria-label="Session window mode">
								<button type="button"
										class="btn btn-sm @(sessionConfig?.SessionWindowMode == MauiSessionWindowMode.Time ? "btn-primary" : "btn-outline-light")"
										@onclick="() => SetWindowMode(MauiSessionWindowMode.Time)">
									Time
								</button>
								<button type="button"
										class="btn btn-sm @(sessionConfig?.SessionWindowMode == MauiSessionWindowMode.Count ? "btn-primary" : "btn-outline-light")"
										@onclick="() => SetWindowMode(MauiSessionWindowMode.Count)">
									Count
								</button>
							</div>

							@if (sessionConfig?.SessionWindowMode == MauiSessionWindowMode.Time)
							{
								<select class="form-select form-select-sm w-auto" value="@sessionConfig.SessionWindowHours" @onchange="SetTimeWindow">
									@foreach (var hours in timeWindows)
									{
										<option value="@hours">@hours h</option>
									}
								</select>
							}
							else
							{
								<select class="form-select form-select-sm w-auto" value="@(sessionConfig?.SessionWindowReplayCount ?? 10)" @onchange="SetReplayWindow">
									@foreach (var replayCount in replayWindows)
									{
										<option value="@replayCount">Last @replayCount</option>
									}
								</select>
							}

							<select class="form-select form-select-sm w-auto" @bind="selectedSessionGameMode" @bind:after="SetGameMode">
								<option value="@((int)GameMode.None)">All GameModes</option>
								@foreach (var gameMode in sessionGameModes)
								{
									<option value="@((int)gameMode)">@gameMode</option>
								}
							</select>
						</div>

						@if (profiles.Count == 0)
						{
							<div class="alert alert-secondary mb-0">
								@Loc["No SC2 profiles configured. Please add a profile in the settings to decode and upload replays."]
								<a href="config">@Loc["Settings"]</a>
							</div>
						}
						else
						{
							@if (sessionLoading)
							{
								<div class="d-flex align-items-center gap-2 mb-3">
									<div class="spinner-border spinner-border-sm text-warning" role="status"></div>
									<span class="small text-muted">Refreshing session window and rating data...</span>
								</div>
							}

							@if (sessionReplayResult.Replays.Count == 0)
							{
								<div class="alert alert-secondary mb-0">
									No replays in the selected window match your active profiles yet.
								</div>
							}
							else
							{
								<div class="row row-cols-2 g-2 small mb-3">
									<div class="col-auto">
										<div class="border rounded p-2">
											<div class="text-muted">Games</div>
											<div class="fw-semibold">@sessionReplayResult.Replays.Count.ToString("N0")</div>
										</div>
									</div>
									<div class="col-auto">
										<div class="border rounded p-2">
											<div class="text-muted">Time</div>
											<div class="fw-semibold">@TimeSpan.FromSeconds(sessionReplayResult.TotalDuration).ToString(@"hh\:mm\:ss")</div>
										</div>
									</div>
									<div class="col-auto">
										<div class="border rounded p-2">
											<div class="text-muted">Winrate</div>
											<div class="fw-semibold">@sessionReplayResult.Winrate.ToString("P1")</div>
										</div>
									</div>
									<div class="col-auto">
										<div class="border rounded p-2">
											<div class="text-muted">Rating</div>
											<div class="fw-semibold @(sessionReplayResult.TotalGain < 0 ? "text-danger" : "text-success")">
												@sessionReplayResult.TotalGain.ToString("N2")
											</div>
										</div>
									</div>
								</div>

								@if (sessionReplayResult.ProfileRatings.Count > 0)
								{
									<div class="mb-3">
										<div class="small text-muted mb-2">Latest Active Profile Ratings</div>
										<div class="d-flex flex-wrap gap-2">
											@foreach (var profileRating in sessionReplayResult.ProfileRatings)
											{
												<div class="border rounded p-2 small pointer"
													 @onclick="() => LoadReplay(profileRating.ReplayHash)">
													<div class="fw-semibold">@profileRating.ProfileName</div>
													<div class="text-warning">@profileRating.Rating.ToString("N0")</div>
													<div class="text-muted">
														@profileRating.GameMode |
														@profileRating.Gametime.ToString("yy-MM-dd")
													</div>
													<div class="@(profileRating.RatingDelta < 0 ? "text-danger" : "text-success")">
														@profileRating.RatingDelta.ToString("+#0.##;-#0.##;0")
													</div>
												</div>
											}
										</div>
									</div>
								}

								<div class="table-responsive" style="max-height: 520px;">
									<table class="tptable">
										<thead>
											<tr>
												<th>Date</th>
												<th>GameMode</th>
												<th>Duration</th>
												<th>Rating</th>
											</tr>
										</thead>
										<tbody>
											@foreach (var replay in sessionReplayResult.Replays)
											{
												<tr class="pointer" @onclick="() => LoadReplay(replay.ReplayHash)">
													<td>@replay.Gametime.ToString("yy-MM-dd")</td>
													<td><span class="d-inline-block text-truncate" style="max-width: 80px;">@replay.GameMode</span></td>
													<td>@TimeSpan.FromSeconds(replay.Duration).ToString(@"hh\:mm\:ss")</td>
													<td class="@(replay.RatingGain < 0 ? "text-danger" : "text-success")">
														@replay.RatingGain.ToString("N2")
													</td>
												</tr>
											}
										</tbody>
									</table>
								</div>
							}
						}
					}
				</div>
			</div>
		</div>
	</div>

	<div>
		@if (profiles.Count == 0)
		{
			<p class="bgchart p-3">
				@Loc["No SC2 profiles configured. Please add a profile in the settings to decode and upload replays."]
				<a href="config">@Loc["Settings"]</a>
			</p>
		}
		else
		{
			<h3>@Loc["Players"]</h3>
			<div class="row mt-3">
				@foreach (var profile in profiles)
				{
					<div class="col-auto mb-3">
						<ProfileCard Profile="profile" OnStatsRequest="e => ShowStats(e)" />
					</div>
				}
			</div>
		}
	</div>
</div>
<PlayerModal @ref="playerModal" />

@code {
	private static readonly int[] timeWindows = [3, 6, 12, 24];
	private static readonly int[] replayWindows = [10, 20, 30, 50];
	private static readonly GameMode[] sessionGameModes = Enum.GetValues<GameMode>()
		.Where(mode => mode != GameMode.None)
		.ToArray();

	ReplayDetails? replayDetails;
	ReplayComponent? replayComponent;
	PlayerModal? playerModal;
	SemaphoreSlim loadSs = new(1, 1);
	string latestReplayHash = string.Empty;
	bool loadingRatings;
	bool sessionLoading;
	bool uploadEnabled;
	string? StatusMessage;
	List<Sc2Profile> profiles = [];
	CancellationTokenSource cts = new();
	CancellationTokenSource? sessionLoadCts;
	MauiConfigDto? sessionConfig;
	int selectedSessionGameMode;

	SessionReplayResult sessionReplayResult = SessionReplayResult.Empty;

	protected override void OnInitialized()
	{
		ImportState.OnFinished += OnImportStateFinished;
		base.OnInitialized();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await LoadConfigStateAsync();
			await LoadLatestReplay();
			await RefreshSessionProgressAsync();
		}
	}

	private void OnImportStateFinished()
	{
		_ = InvokeAsync(RefreshAfterImportAsync);
	}

	private async Task RefreshAfterImportAsync()
	{
		await LoadConfigStateAsync();
		await LoadLatestReplay();
		await RefreshSessionProgressAsync();
	}

	private async Task LoadConfigStateAsync()
	{
		sessionConfig = SessionProgress.NormalizeSettings(await DsstatsService.GetConfigDto());
		if (!sessionConfig.SessionWindowInitialized)
		{
			sessionConfig.SessionWindowGameMode = GameMode.None;
			sessionConfig.SessionWindowInitialized = true;
			await DsstatsService.SaveConfig(sessionConfig);
			sessionConfig = SessionProgress.NormalizeSettings(await DsstatsService.GetConfigDto());
		}
		selectedSessionGameMode = (int)sessionConfig.SessionWindowGameMode;
		uploadEnabled = sessionConfig.UploadCredential;

		var config = await DsstatsService.GetConfig();
		profiles = config.Sc2Profiles
			.Where(x => x.Active && x.ToonId.Id > 0)
			.OrderBy(o => o.Name)
				.ThenBy(t => t.ToonId.Region)
			.ToList();
	}

	private async Task LoadLatestReplay()
	{
		await loadSs.WaitAsync();
		try
		{
			replayDetails = await ReplayRepository.GetLatestReplay();
			if (replayDetails is null)
			{
				return;
			}
			latestReplayHash = replayDetails.ReplayHash;
			replayComponent?.Update(replayDetails);
		}
		finally
		{
			loadSs.Release();
		}
		await InvokeAsync(StateHasChanged);
	}

	private async Task LoadReplay(string replayHash)
	{
		await loadSs.WaitAsync();
		try
		{
			var newDetails = await ReplayRepository.GetReplayDetails(replayHash);
			if (newDetails is null)
			{
				return;
			}
			replayDetails = newDetails;
			replayComponent?.Update(replayDetails);
			await InvokeAsync(StateHasChanged);
		}
		finally
		{
			loadSs.Release();
		}
	}

	private async Task ScrollReplay(bool left)
	{
		if (replayDetails is null)
		{
			return;
		}
		await loadSs.WaitAsync();
		try
		{
			var nextDetails = await ReplayRepository.GetNextReplay(!left, replayDetails.ReplayHash);
			if (nextDetails is null)
			{
				return;
			}
			replayDetails = nextDetails;
			replayComponent?.Update(replayDetails);
			await InvokeAsync(StateHasChanged);
		}
		finally
		{
			loadSs.Release();
		}
	}

	private async Task UpdateRatings()
	{
		await loadSs.WaitAsync();
		try
		{
			if (replayDetails == null)
			{
				return;
			}

			loadingRatings = true;
			await InvokeAsync(StateHasChanged);

			var rating = await SessionProgress.UpdateRating(replayDetails.ReplayHash, forceRefresh: true, cts.Token);
			if (rating is null)
			{
				return;
			}
			replayDetails.ReplayRatings = [rating];
			replayComponent?.Update(replayDetails);
			await RefreshSessionProgressAsync();
		}
		finally
		{
			loadingRatings = false;
			loadSs.Release();
		}
		await InvokeAsync(StateHasChanged);
	}

	private async Task RefreshSessionProgressAsync()
	{
		sessionLoadCts?.Cancel();
		sessionLoadCts?.Dispose();
		sessionLoadCts = CancellationTokenSource.CreateLinkedTokenSource(cts.Token);
		var token = sessionLoadCts.Token;

		sessionLoading = uploadEnabled;
		sessionReplayResult = SessionReplayResult.Empty;
		await InvokeAsync(StateHasChanged);

		if (!uploadEnabled)
		{
			sessionLoading = false;
			await InvokeAsync(StateHasChanged);
			return;
		}

		try
		{
			sessionReplayResult = await SessionProgress.GetSessionReplaysAsync(async result =>
			{
				sessionReplayResult = result;
				await SyncCurrentReplayRatingAsync();
				await InvokeAsync(StateHasChanged);
			}, token);

			await SyncCurrentReplayRatingAsync();
		}
		catch (OperationCanceledException)
		{
		}
		finally
		{
			sessionLoading = false;
		}

		await InvokeAsync(StateHasChanged);
	}

	private async Task SyncCurrentReplayRatingAsync()
	{
		if (replayDetails is null)
		{
			return;
		}

		var rating = await ReplayRepository.GetReplayRating(replayDetails.ReplayHash);
		if (rating is null)
		{
			return;
		}

		var existing = replayDetails.ReplayRatings.FirstOrDefault(r => r.RatingType == RatingType.All);
		if (ReferenceEquals(existing, rating))
		{
			return;
		}

		replayDetails.ReplayRatings = [rating];
		replayComponent?.Update(replayDetails);
	}

	private async Task SetWindowMode(MauiSessionWindowMode mode)
	{
		if (sessionConfig is null || sessionConfig.SessionWindowMode == mode)
		{
			return;
		}

		sessionConfig.SessionWindowMode = mode;
		await SaveSessionSettingsAsync();
	}

	private async Task SetTimeWindow(ChangeEventArgs args)
	{
		if (sessionConfig is null || !int.TryParse(args.Value?.ToString(), out var hours))
		{
			return;
		}

		sessionConfig.SessionWindowHours = hours;
		await SaveSessionSettingsAsync();
	}

	private async Task SetReplayWindow(ChangeEventArgs args)
	{
		if (sessionConfig is null || !int.TryParse(args.Value?.ToString(), out var replayCount))
		{
			return;
		}

		sessionConfig.SessionWindowReplayCount = replayCount;
		await SaveSessionSettingsAsync();
	}

	private async Task SetGameMode()
	{
		if (sessionConfig is null)
		{
			return;
		}

		sessionConfig.SessionWindowGameMode = Enum.IsDefined(typeof(GameMode), selectedSessionGameMode)
			? (GameMode)selectedSessionGameMode
			: GameMode.None;

		await SaveSessionSettingsAsync();
	}

	private async Task SaveSessionSettingsAsync()
	{
		if (sessionConfig is null)
		{
			return;
		}

		sessionConfig = SessionProgress.NormalizeSettings(sessionConfig);
		await DsstatsService.SaveConfig(sessionConfig);
		await LoadConfigStateAsync();
		await RefreshSessionProgressAsync();
	}

	private async Task EnableUploadAndRefresh()
	{
		if (sessionConfig is null)
		{
			sessionConfig = await DsstatsService.GetConfigDto();
		}

		sessionConfig.UploadCredential = true;
		await DsstatsService.SaveConfig(sessionConfig);
		await LoadConfigStateAsync();
		await UploadReplays();
	}

	private async Task UploadReplays()
	{
		var result = await DsstatsService.Upload(ImportState, true);
		StatusMessage = result.Success ? "Upload successful" : result.Error;
		await RefreshSessionProgressAsync();
	}

	private async Task StartImportAsync()
	{
		if (ImportState.IsRunning)
			return;

		StatusMessage = null;

		try
		{
			await DsstatsService.StartImportAsync(ImportState);
			StatusMessage = "Import completed.";
		}
		catch (OperationCanceledException)
		{
			StatusMessage = "Import cancelled.";
		}
		catch (Exception ex)
		{
			StatusMessage = $"Import failed: {ex.Message}";
		}
	}

	private void CancelImport()
	{
		ImportState.Cancel();
	}

	private async Task ShowStats(ToonIdDto toonId)
	{
		PlayerStatsRequest request = new()
		{
			ToonId = toonId,
			Player = new(),
			RatingType = RatingType.All,
		};
		var stats = await PlayerService.GetPlayerStats(request);
		playerModal?.Show(stats);
	}

	protected override void Dispose(bool disposing)
	{
		if (disposing)
		{
			ImportState.OnFinished -= OnImportStateFinished;
			cts.Cancel();
			sessionLoadCts?.Cancel();
			sessionLoadCts?.Dispose();
			loadSs.Dispose();
			cts.Dispose();
		}

		base.Dispose(disposing);
	}
}

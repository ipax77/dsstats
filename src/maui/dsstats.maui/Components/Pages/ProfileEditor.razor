@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Name</label>
                <div class="form-control bg-dark text-light">@Profile.Name</div>
            </div>
            <div class="col-md-5">
                <label class="form-label">Folder</label>
                <div class="form-control bg-dark text-light text-truncate" title="@Profile.Folder">@Profile.Folder</div>
            </div>
            <div class="col-md-2">
                <div class="form-check mt-4">
                    <InputCheckbox class="form-check-input" @bind-Value="Profile.Active" />
                    <label class="form-check-label">Active</label>
                </div>
            </div>
            <div class="col-md-1">
                <div class="small text-muted">@($"{Profile.ToonId.Region}-S2-{Profile.ToonId.Realm}-{Profile.ToonId.Id}")</div>
            </div>
        </div>
    </div>
</div>

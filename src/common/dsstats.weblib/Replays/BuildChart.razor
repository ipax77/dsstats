@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop
@using System.Text.Json
@using dsstats.shared
@using System.Globalization
@using dsstats.shared.Units
@using pax.BlazorChartJs
@inject ILogger<BuildChart> Logger

<ChartComponent @ref="chartComponent" ChartJsConfig="chartConfig" OnEventTriggered="ChartEventTriggered" />

@code {
    [Parameter]
    [EditorRequired]
    public SpawnDto? Spawn { get; set; }

    [Parameter]
    [EditorRequired]
    public int Team { get; set; }

    [Parameter]
    [EditorRequired]
    public Commander Cmdr { get; set; }

    [Parameter, EditorRequired]
    public Lazy<Task<IJSObjectReference>> moduleTask { get; set; } = default!;

    [Parameter]
    public Dictionary<string, (double Radius, string Color)>? UnitDisplayInfo { get; set; }

    private CustomChartJsConfig chartConfig = null!;
    private ChartComponent? chartComponent;

    private bool chartIsReady;
    private bool annotationsRegistered;

    protected override void OnInitialized()
    {
        chartConfig = GetBubbleChartConfig();
        base.OnInitialized();
    }

    private List<ChartJsDataset> BuildBubbleChartDatasets(SpawnDto spawn, int team)
    {
        Dictionary<string, UnitDatasetBuilder> builders = new(StringComparer.Ordinal);

        foreach (var unit in spawn.Units)
        {
            if (unit.Positions is { Count: > 0 } positions)
            {
                var builder = GetOrAddDatasetBuilder(builders, unit.Name, positions.Count / 2);
                builder.EnsureAdditionalCapacity(positions.Count / 2);

                for (int i = 0; i + 1 < positions.Count; i += 2)
                {
                    Point point = new(positions[i], positions[i + 1]);
                    (var x, var y) = GetRotatedPoint(point, team);
                    builder.AddPoint(x, y);
                }
            }
        }

        List<ChartJsDataset> datasets = new(builders.Count);
        foreach (var builder in builders.Values.OrderByDescending(o => o.Data.Count))
        {
            datasets.Add(builder.ToDataset());
        }

        return datasets;
    }

    private UnitDatasetBuilder GetOrAddDatasetBuilder(
        Dictionary<string, UnitDatasetBuilder> builders,
        string dbName,
        int initialCapacity)
    {
        if (builders.TryGetValue(dbName, out var builder))
        {
            return builder;
        }

        var unitInfo = UnitMap.GetUnitInfo(dbName, Cmdr);
        (var radius, var color) = UnitDisplayInfo is not null && UnitDisplayInfo.TryGetValue(dbName, out var di)
            ? di
            : UnitMapNg.GetColorAndRadius(dbName, Cmdr);

        builder = new(dbName, unitInfo.Name, radius, color, initialCapacity);
        builders.Add(dbName, builder);
        return builder;
    }

    private (double x, double y) GetRotatedPoint(Point point, int team)
    {
        (var x, var y) = RotatePoint(point);
        x = team == 2 ? (x - 62.23907) / 2.0 : (x - 176.79037) / 2.0;
        y = y - 107.97919;
        return new(Math.Round((-x + 8 - 0.1), 2), Math.Round(y + 0.5, 2));
    }

    public static (double, double) RotatePoint(Point pointToRotate)
    {
        double centerX = 128.0;
        double centerY = 120.0;
        double angleInRadians = -45 * (Math.PI / 180);
        double cosTheta = Math.Cos(angleInRadians);
        double sinTheta = Math.Sin(angleInRadians);
        var x = (cosTheta * (pointToRotate.X - centerX) - sinTheta * (pointToRotate.Y - centerY) + centerX);
        var y = (sinTheta * (pointToRotate.X - centerX) + cosTheta * (pointToRotate.Y - centerY) + centerY);
        return (x, y);
    }

    public async Task Update(SpawnDto? spawn, Commander cmdr, int team, Dictionary<string, (double Radius, string Color)>? unitDisplayInfo = null)
    {
        await UpdateCore(spawn, cmdr, team, unitDisplayInfo, smooth: false);
    }

    public async Task UpdateSmooth(SpawnDto? spawn, Commander cmdr, int team, Dictionary<string, (double Radius, string Color)>? unitDisplayInfo = null)
    {
        await UpdateCore(spawn, cmdr, team, unitDisplayInfo, smooth: true);
    }

    private async Task UpdateCore(
        SpawnDto? spawn,
        Commander cmdr,
        int team,
        Dictionary<string, (double Radius, string Color)>? unitDisplayInfo,
        bool smooth)
    {
        Team = team;
        Spawn = spawn;
        Cmdr = cmdr;
        if (unitDisplayInfo is not null)
        {
            UnitDisplayInfo = unitDisplayInfo;
        }

        if (!chartIsReady)
        {
            return;
        }

        List<ChartJsDataset> datasets = spawn is null
            ? []
            : BuildBubbleChartDatasets(spawn, team);

        try
        {
            if (smooth)
            {
                chartConfig.SetDatasetsSmooth(datasets, [], updateOptions: false);
            }
            else
            {
                if (chartConfig.Data.Datasets.Any())
                {
                    chartConfig.RemoveDatasets(chartConfig.Data.Datasets);
                }

                if (datasets.Count > 0)
                {
                    chartConfig.AddDatasets(datasets);
                }
            }

            var module = await moduleTask.Value;
            await module.InvokeVoidAsync("drawChartBorder", chartConfig.ChartJsConfigGuid);
        }
        catch (TaskCanceledException) { }
        catch (JSDisconnectedException) { }
    }

    public async Task HighlightUnits(string unitName)
    {
        var dataset = chartConfig.Data.Datasets
            .Cast<BubbleDataset>()
            .FirstOrDefault(f => f.Label == unitName);

        if (dataset is null)
        {
            return;
        }

        var index = chartConfig.Data.Datasets.IndexOf(dataset);

        if (index < 0)
        {
            return;
        }

        try
        {
            var module = await moduleTask.Value.ConfigureAwait(false);
            await module.InvokeVoidAsync("setDatasetPointsActive", chartConfig.ChartJsConfigGuid, index);
        }
        catch (TaskCanceledException) { }
        catch (JSDisconnectedException) { }
    }

    private async void ChartEventTriggered(ChartJsEvent e)
    {
        if (e is ChartJsInitEvent initEvent)
        {
            var success = await RegisterPlugin();
            chartIsReady = !success;
            await Update(Spawn, Cmdr, Team);
        }
        else if (e is ChartJsLegendHoverEvent hoverEvent)
        {
            if (!string.IsNullOrEmpty(hoverEvent.Label))
            {
                await HighlightUnits(hoverEvent.Label);
            }
        }
    }

    public CustomChartJsConfig GetBubbleChartConfig()
    {
        return new()
        {
            Type = ChartType.bubble,
            Data = new ChartJsData()
            {
                Datasets = new List<ChartJsDataset>()
            },
            Options = new CustomChartJsOptions()
            {
                // Responsive = true,
                MaintainAspectRatio = false,
                // OnHoverEvent = true,
                Plugins = new()
                {
                    Title = new()
                    {
                        Display = false,
                    },
                    Legend = new Legend()
                    {
                        Display = true,
                        Position = Team == 1 ? "left" : "right",
                        MaxWidth = 100,
                        Labels = new Labels()
                        {
                            BoxWidth = 20,
                        },
                        OnHoverEvent = true
                    },
                    Tooltip = new Tooltip()
                    {
                        Callbacks = new TooltipCallbacks()
                        {
                            Label = ChartJsFunction.FromName("buildUnitTooltipLabel")
                        }
                    }
                },
                Scales = new ChartJsOptionsScales()
                {
                    X = new LinearAxis()
                    {
                        Type = "linear",
                        Position = "bottom",
                        Title = new()
                        {
                            Display = false,
                        },
                        Ticks = new LinearAxisTick()
                        {
                            Display = false,
                        },
                        Grid = new ChartJsGrid()
                        {
                            Display = false,
                        },
                        Border = new ChartJsAxisBorder()
                        {
                            Display = false,
                        },
                        SuggestedMin = 0,
                        SuggestedMax = 8
                    },
                    Y = new LinearAxis()
                    {
                        Title = new()
                        {
                            Display = false,
                        },
                        Ticks = new LinearAxisTick()
                        {
                            Display = false,
                        },
                        Grid = new ChartJsGrid()
                        {
                            Display = false,
                        },
                        Border = new ChartJsAxisBorder()
                        {
                            Display = false,
                        },
                        SuggestedMin = 0,
                        SuggestedMax = 25
                    }
                }
            }
        };
    }

    private async Task<bool> RegisterPlugin()
    {
        if (!annotationsRegistered)
        {
            try
            {
                var module = await moduleTask.Value.ConfigureAwait(false);
                await module.InvokeVoidAsync("registerPlugin")
                    .ConfigureAwait(false);
            }
            catch (TaskCanceledException) { return false; }
            catch (JSDisconnectedException) { return false; }

            annotationsRegistered = true;

            if (chartConfig.Options?.Plugins is null)
            {
                return true;
            }
            ;
            chartConfig.Options.Plugins.Annotation = new()
            {
                Annotations = new()
                    {
                        { "arrow1", new LabelAnnotation()
                        {
                            XValue = Team == 1 ? 7.5 : 0.2,
                            YValue = 1.3,
                            XAdjust = 0,
                            YAdjust = 0,
                            Position = "start",
                            Color = "#080808E6",
                            BackgroundColor = "#dee2e6",
                            BorderRadius = 10,
                            Content = Team == 2 ? "<" : ">",
                            Font = new Font()
                            {
                                Size = 14,
                            }
                        } },
                        { "arrow2", new LabelAnnotation()
                        {
                            XValue = Team == 1 ? 7.5 : 0.2,
                            YValue = 25,
                            XAdjust = 0,
                            YAdjust = 0,
                            Position = "start",
                            Color = "#080808E6",
                            BackgroundColor = "#dee2e6",
                            BorderRadius = 10,
                            Content = Team == 2 ? "<" : ">",
                            Font = new Font()
                            {
                                Size = 14,
                            }
                        } }
                    }
            };
            chartConfig.ReinitializeChart();
            return true;
        }
        return false;
    }

    public record CmdrBubbleDataPoint : BubbleDataPoint
    {
        public string Label { get; set; } = string.Empty;
    }

    private static string GetDatasetId(string dbName)
    {
        return $"build-{dbName}";
    }

    private sealed class UnitDatasetBuilder
    {
        public UnitDatasetBuilder(string dbName, string label, double radius, string color, int initialCapacity)
        {
            DbName = dbName;
            Label = label;
            Radius = radius;
            Color = color;
            Data = new(Math.Max(0, initialCapacity));
        }

        public string DbName { get; }
        public string Label { get; }
        public double Radius { get; }
        public string Color { get; }
        public List<CmdrBubbleDataPoint> Data { get; }

        public void EnsureAdditionalCapacity(int additionalCapacity)
        {
            var neededCapacity = Data.Count + additionalCapacity;
            if (Data.Capacity < neededCapacity)
            {
                Data.Capacity = neededCapacity;
            }
        }

        public void AddPoint(double x, double y)
        {
            Data.Add(new CmdrBubbleDataPoint()
            {
                X = x,
                Y = y,
                R = Radius,
                Label = Label
            });
        }

        public ChartJsDataset ToDataset()
        {
            Data.Sort(ComparePoints);
            List<object> data = new(Data.Count);
            foreach (var point in Data)
            {
                data.Add(point);
            }

            return new BubbleDataset()
            {
                Id = GetDatasetId(DbName),
                Label = Label,
                Data = data,
                BorderWidth = 2,
                BorderColor = $"{Color}CC",
                BackgroundColor = $"{Color}80",
                HoverBorderColor = $"{Color}FF",
                HoverBorderWidth = 4,
            };
        }

        private static int ComparePoints(CmdrBubbleDataPoint left, CmdrBubbleDataPoint right)
        {
            var result = left.Y.CompareTo(right.Y);
            if (result != 0)
            {
                return result;
            }

            result = left.X.CompareTo(right.X);
            if (result != 0)
            {
                return result;
            }

            result = left.R.CompareTo(right.R);
            if (result != 0)
            {
                return result;
            }

            return string.CompareOrdinal(left.Label, right.Label);
        }
    }

    public record Point(int X, int Y)
    {
        public static readonly Point Zero = new(0, 0);
    };
}

@using Microsoft.JSInterop
@using dsstats.shared
@using dsstats.shared.Interfaces
@using dsstats.shared.Units
@implements IDisposable
@inject IReplayRepository ReplayRepository
@inject SpawnPositionHydrationService SpawnPositionHydration

<div class="card bgchart w-auto">
    <div class="card-header bgchart2 rounded">
        <div class="d-flex align-items-center justify-content-between mb-2">
            <div class="preload-@(Player.Race.ToString().ToLower())" alt="@Player.Race" style="width: 25px; height: 25px;"></div>
            <span class="badge @badgeClass" style="font-size: 1.1rem;">
                #@Player.GamePos @Player.Name
            </span>
            <div>
                <button class="btn btn-sm btn-outline-light bgchart" type="button" data-bs-toggle="collapse"
                        data-bs-target="@($"#Player{Player.GamePos}Map")" aria-expanded="false"
                        aria-controls="@($"Player{Player.GamePos}Map")" @onclick="ToggleMap">
                    <span class="oi @(showMap ? "bi-chevron-down" : "bi-chevron-up")"></span>
                    Map
                </button>
            </div>
        </div>
        <div class="d-flex align-items-center justify-content-between">
            <div class="ms-1 me-1">
                <button class="btn btn-sm btn-outline-warning bgchart" type="button" data-bs-toggle="collapse"
                        data-bs-target="@($"#Player{Player.GamePos}Gas")" aria-expanded="false"
                        aria-controls="@($"Player{Player.GamePos}Gas")" @onclick="e => showGas = !showGas">
                    <span class="bi @(showGas ? "bi-chevron-down" : "bi-chevron-up")"></span>
                    Gas @BreakpointSpawn?.GasCount
                </button>
            </div>
            <div class="">
                <button class="btn btn-sm btn-outline-light bgchart" type="button" data-bs-toggle="collapse"
                        data-bs-target="@($"#Player{Player.GamePos}Upgrades")" aria-expanded="false"
                        aria-controls="@($"Player{Player.GamePos}Upgrades")" @onclick="e => showUpgrades = !showUpgrades">
                    <span class="bi @(showUpgrades ? "bi-chevron-down" : "bi-chevron-up")"></span>
                    Upgrades @ReplayHelper.GetNumberString(BreakpointSpawn?.UpgradeSpent)
                </button>
            </div>
        </div>
    </div>
    <div class="card-body bgchart">
        <div class="collapse" id="@($"Player{Player.GamePos}Map")">
            @if (showMap)
            {
                @if (HasSpawnPlayback)
                {
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-2" style="width: 500px; max-width: 100%;">
                        <div class="btn-group btn-group-sm" role="group" aria-label="Build chart mode">
                            <button type="button"
                                    class="btn @(chartMode == BuildChartMode.Breakpoint ? "btn-info" : "btn-outline-info")"
                                    @onclick="() => SetChartMode(BuildChartMode.Breakpoint)">
                                Breakpoint
                            </button>
                            <button type="button"
                                    class="btn @(chartMode == BuildChartMode.Spawn ? "btn-info" : "btn-outline-info")"
                                    @onclick="() => SetChartMode(BuildChartMode.Spawn)">
                                Spawn
                            </button>
                        </div>
                        @if (chartMode == BuildChartMode.Spawn)
                        {
                            <div class="btn-group btn-group-sm" role="group" aria-label="Spawn wave controls">
                                <button type="button"
                                        class="btn btn-outline-light"
                                        title="Previous spawn"
                                        disabled="@(loadingSpawnWaves || selectedSpawnWaveIndex <= 0)"
                                        @onclick="PreviousSpawnWave">
                                    <span class="bi bi-chevron-left"></span>
                                </button>
                                <button type="button"
                                        class="btn btn-outline-light"
                                        title="Next spawn"
                                        disabled="@(loadingSpawnWaves || selectedSpawnWaveIndex >= spawnWaves.Count - 1)"
                                        @onclick="NextSpawnWave">
                                    <span class="bi bi-chevron-right"></span>
                                </button>
                            </div>
                            <select class="form-select form-select-sm text-light bgchart"
                                    style="width: 12rem;"
                                    aria-label="Spawn wave"
                                    disabled="@(loadingSpawnWaves || spawnWaves.Count == 0)"
                                    value="@selectedSpawnWaveIndex"
                                    @onchange="SelectSpawnWave">
                                @for (var i = 0; i < spawnWaves.Count; i++)
                                {
                                    <option value="@i">@GetSpawnWaveLabel(spawnWaves[i])</option>
                                }
                            </select>
                        }
                    </div>
                }
                <div class="bgchart" style="height: 600px; width: 500px;">
                    @if (chartMode == BuildChartMode.Spawn)
                    {
                        @if (loadingSpawnWaves)
                        {
                            <div class="h-100 d-flex align-items-center justify-content-center text-light p-3">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                                    <span>Loading spawns...</span>
                                </div>
                            </div>
                        }
                        else if (SelectedSpawnWave is not null)
                        {
                            <HydratedBuildChart @ref="buildChart"
                                                @key="MapChartKey"
                                                ReplayDetails="ReplayHelper.ReplayDetails"
                                                GamePos="Player.GamePos"
                                                Breakpoint="ReplayHelper.Breakpoint"
                                                Team="Player.TeamId"
                                                Cmdr="Player.Race"
                                                moduleTask="moduleTask"
                                                UnitDisplayInfo="_unitDisplayInfo"
                                                PositionedSpawn="SelectedSpawnWave.Spawn"
                                                ChartKeySuffix="MapChartKey"
                                                EmptyText="No spawn chart data is available." />
                        }
                        else
                        {
                            <div class="h-100 d-flex align-items-center justify-content-center text-warning p-3 text-center">
                                @(spawnWaveLoadFailed ? "Spawn data could not be loaded." : "No spawn waves are available.")
                            </div>
                        }
                    }
                    else
                    {
                    <HydratedBuildChart @ref="buildChart"
                                        @key="MapChartKey"
                                        ReplayDetails="ReplayHelper.ReplayDetails"
                                        GamePos="Player.GamePos"
                                        Breakpoint="ReplayHelper.Breakpoint"
                                        Team="Player.TeamId"
                                        Cmdr="Player.Race"
                                        moduleTask="moduleTask"
                                        UnitDisplayInfo="_unitDisplayInfo"
                                        ChartKeySuffix="MapChartKey" />
                    }
                </div>
            }
        </div>
        <div class="collapse" id="@($"Player{Player.GamePos}Gas")">
            <RefineryInfoComponent Player="Player" />
        </div>
        <div class="collapse" id="@($"Player{Player.GamePos}Upgrades")">
            <UpgradesComponent Player="Player" />
        </div>
        <div class="d-flex justify-content-center">
            <table class="tptable border rounded p-2 w-auto">
                <thead>
                    <tr>
                        <td></td>
                        <td>Unit</td>
                        <td>Count</td>
                    </tr>
                </thead>
                <tbody>
                    @if (DisplayedSpawn != null)
                    {
                    @foreach (var unit in DisplayedSpawn.Units.OrderByDescending(o => o.Count))
                        {
                            var unitInfo = UnitMap.GetUnitInfo(unit.Name, Player.Race);
                            var unitColor = _unitDisplayInfo.TryGetValue(unit.Name, out var di) ? di.Color : "#CCCCCC";
                            <tr @onmouseover="e => HighlightUnits(unitInfo.Name)">
                                <td>
                                    <span class="unit-color-indicator" style="background-color: @($"{unitColor}CC")"></span>
                                </td>
                                <td>@unitInfo.Name</td>
                                <td class="text-start">@unit.Count</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ReplayPlayerDto Player { get; set; } = default!;

    [Parameter, EditorRequired]
    public ReplayHelper ReplayHelper { get; set; } = default!;

    [Parameter, EditorRequired]
    public Lazy<Task<IJSObjectReference>> moduleTask { get; set; } = default!;

    HydratedBuildChart? buildChart;
    private bool showMap = false;
    private bool showGas = false;
    private bool showUpgrades = false;
    private IReadOnlyList<SpawnPlaybackWaveInfo> spawnWaves = [];
    private CancellationTokenSource? spawnWaveLoadCts;
    private BuildChartMode chartMode = BuildChartMode.Breakpoint;
    private int selectedSpawnWaveIndex;
    private int spawnWaveLoadVersion;
    private int currentGamePos;
    private string? currentReplayHash;
    private bool loadingSpawnWaves;
    private bool spawnWaveLoadFailed;

    private SpawnDto? BreakpointSpawn => ReplayHelper.GetSpawn(Player);
    private SpawnPlaybackWaveInfo? SelectedSpawnWave =>
        (uint)selectedSpawnWaveIndex < (uint)spawnWaves.Count
            ? spawnWaves[selectedSpawnWaveIndex]
            : null;
    private SpawnDto? DisplayedSpawn => chartMode == BuildChartMode.Spawn && SelectedSpawnWave is not null
        ? SelectedSpawnWave.Spawn
        : BreakpointSpawn;
    private string badgeClass => ReplayHelper.IsWinner(Player) ? "text-bg-success" : "text-bg-danger";
    private bool HasSpawnPlayback => ReplayHelper.ReplayDetails.Replay.SpawnPlayback?.Available == true;
    private string MapChartKey
    {
        get
        {
            if (chartMode == BuildChartMode.Spawn && SelectedSpawnWave is { } wave)
            {
                return BuildChartTarget.GetVisibleWaveKey(
                    showMap,
                    ReplayHelper.ReplayDetails.ReplayHash,
                    Player.GamePos,
                    wave.SpawnNumber,
                    wave.StartGameloop) ?? string.Empty;
            }

            return BuildChartTarget.GetVisibleKey(
                showMap,
                ReplayHelper.ReplayDetails.ReplayHash,
                Player.GamePos,
                ReplayHelper.Breakpoint) ?? string.Empty;
        }
    }

    private Dictionary<string, (double Radius, string Color)> _unitDisplayInfo = [];

    protected override void OnParametersSet()
    {
        if (currentGamePos != Player.GamePos || currentReplayHash != ReplayHelper.ReplayDetails.ReplayHash)
        {
            currentGamePos = Player.GamePos;
            currentReplayHash = ReplayHelper.ReplayDetails.ReplayHash;
            ResetSpawnWaveState();
        }

        ComputeDisplayInfo();
    }

    private void ComputeDisplayInfo()
    {
        _unitDisplayInfo = DisplayedSpawn?.Units
            .DistinctBy(u => u.Name)
            .ToDictionary(u => u.Name, u => UnitMapNg.GetColorAndRadius(u.Name, Player.Race))
            ?? [];
    }

    private async Task HighlightUnits(string name)
    {
        if (!showMap || buildChart is null)
        {
            return;
        }
        await buildChart.HighlightUnits(name);
    }

    private async Task ToggleMap()
    {
        showMap = !showMap;
        if (showMap && chartMode == BuildChartMode.Spawn)
        {
            await EnsureSpawnWavesLoaded();
        }

        ComputeDisplayInfo();
        await InvokeAsync(StateHasChanged);
    }

    public void Update()
    {
        ComputeDisplayInfo();
        InvokeAsync(StateHasChanged);
    }

    private async Task SetChartMode(BuildChartMode mode)
    {
        if (chartMode == mode)
        {
            return;
        }

        chartMode = mode;
        if (chartMode == BuildChartMode.Spawn)
        {
            await EnsureSpawnWavesLoaded();
        }

        ComputeDisplayInfo();
        await InvokeAsync(StateHasChanged);
    }

    private async Task EnsureSpawnWavesLoaded()
    {
        if (!HasSpawnPlayback || loadingSpawnWaves || spawnWaves.Count > 0)
        {
            return;
        }

        spawnWaveLoadCts?.Cancel();
        spawnWaveLoadCts?.Dispose();
        spawnWaveLoadCts = new();
        var loadCts = spawnWaveLoadCts;
        var version = ++spawnWaveLoadVersion;
        loadingSpawnWaves = true;
        spawnWaveLoadFailed = false;
        await InvokeAsync(StateHasChanged);

        try
        {
            var waves = await SpawnPositionHydration.GetSpawnWavesAsync(
                ReplayHelper.ReplayDetails,
                Player.GamePos,
                ReplayRepository,
                loadCts.Token);

            if (version != spawnWaveLoadVersion || loadCts.IsCancellationRequested)
            {
                return;
            }

            spawnWaves = waves;
            selectedSpawnWaveIndex = Math.Clamp(selectedSpawnWaveIndex, 0, Math.Max(0, spawnWaves.Count - 1));
        }
        catch (OperationCanceledException)
        {
        }
        catch
        {
            if (version == spawnWaveLoadVersion)
            {
                spawnWaves = [];
                selectedSpawnWaveIndex = 0;
                spawnWaveLoadFailed = true;
            }
        }
        finally
        {
            if (version == spawnWaveLoadVersion)
            {
                loadingSpawnWaves = false;
                ComputeDisplayInfo();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private Task SelectSpawnWave(ChangeEventArgs args)
    {
        if (args.Value is string value && int.TryParse(value, out var index))
        {
            selectedSpawnWaveIndex = Math.Clamp(index, 0, Math.Max(0, spawnWaves.Count - 1));
            ComputeDisplayInfo();
        }

        return InvokeAsync(StateHasChanged);
    }

    private Task PreviousSpawnWave()
    {
        selectedSpawnWaveIndex = Math.Max(0, selectedSpawnWaveIndex - 1);
        ComputeDisplayInfo();
        return InvokeAsync(StateHasChanged);
    }

    private Task NextSpawnWave()
    {
        selectedSpawnWaveIndex = Math.Min(Math.Max(0, spawnWaves.Count - 1), selectedSpawnWaveIndex + 1);
        ComputeDisplayInfo();
        return InvokeAsync(StateHasChanged);
    }

    private static string GetSpawnWaveLabel(SpawnPlaybackWaveInfo wave)
    {
        return $"Spawn {wave.SpawnNumber} - {FormatGameloop(wave.StartGameloop)}";
    }

    private static string FormatGameloop(int gameloop)
    {
        var time = TimeSpan.FromSeconds(Math.Round(gameloop / 22.4));
        return time.Hours > 0
            ? time.ToString(@"hh\:mm\:ss")
            : time.ToString(@"mm\:ss");
    }

    private void ResetSpawnWaveState()
    {
        spawnWaveLoadCts?.Cancel();
        spawnWaveLoadCts?.Dispose();
        spawnWaveLoadCts = null;
        spawnWaves = [];
        selectedSpawnWaveIndex = 0;
        loadingSpawnWaves = false;
        spawnWaveLoadFailed = false;
        chartMode = BuildChartMode.Breakpoint;
        spawnWaveLoadVersion++;
    }

    public void Dispose()
    {
        spawnWaveLoadCts?.Cancel();
        spawnWaveLoadCts?.Dispose();
    }

    private enum BuildChartMode
    {
        Breakpoint,
        Spawn
    }
}

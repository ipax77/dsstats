@using dsstats.shared
@using pax.BlazorChartJs

<ChartComponent @ref="chartComponent" ChartJsConfig="chartJsConfig" OnEventTriggered="EventTriggered" />

@code {
    [Parameter, EditorRequired]
    public SynergyResponse Response { get; set; } = default!;

    [Parameter, EditorRequired]
    public StatsRequest Request { get; set; } = default!;

    [Parameter]
    public List<Commander> Commanders { get; set; } = [];

    ChartJsConfig chartJsConfig = null!;
    ChartComponent? chartComponent;
    bool chartReady;
    IReadOnlyCollection<Commander> selectedCommanders = [];

    protected override void OnInitialized()
    {
        chartJsConfig = GetChartConfig();
        selectedCommanders = [.. Commanders];
        base.OnInitialized();
    }

    private void EventTriggered(ChartJsEvent chartJsEvent)
    {
        if (chartJsEvent is ChartJsInitEvent)
        {
            chartReady = true;
            PrepareData(Response, Request, selectedCommanders);
        }
    }

    public void PrepareData(SynergyResponse response, StatsRequest request, IReadOnlyCollection<Commander> selected)
    {
        Response = response;
        Request = request;
        selectedCommanders = [.. selected];

        if (!chartReady)
        {
            return;
        }

        var entsByPair = new Dictionary<(Commander, Commander), SynergyEnt>(response.SynergyEnts.Count);
        var commandersWithData = new HashSet<Commander>();
        var teammateSet = new HashSet<Commander>();

        foreach (var ent in response.SynergyEnts)
        {
            entsByPair.Add(GetPairKey(ent.Commander, ent.Teammate), ent);
            commandersWithData.Add(ent.Commander);
            teammateSet.Add(ent.Commander);
            teammateSet.Add(ent.Teammate);
        }

        var teammateLabels = teammateSet
            .OrderBy(c => c)
            .ToList();

        if (chartJsConfig.Options?.Plugins?.Title != null)
        {
            chartJsConfig.Options.Plugins.Title.Text = new IndexableOption<string>(
                $"Synergy AvgGain (normalized 0-1) - {GetTimeInfo(request)}");
        }

        var desiredCommanders = selectedCommanders
            .Where(commandersWithData.Contains)
            .Distinct()
            .OrderBy(c => c)
            .ToList();

        var labels = teammateLabels.Select(t => t.ToString()).ToList();

        if (response.SynergyEnts.Count == 0 || desiredCommanders.Count == 0 || teammateLabels.Count == 0)
        {
            chartJsConfig.SetDatasetsSmooth([], labels, updateOptions: true);
            return;
        }

        var minAvgGain = response.SynergyEnts.Min(e => e.AvgGain);
        var maxAvgGain = response.SynergyEnts.Max(e => e.AvgGain);

        List<ChartJsDataset> datasets = new(desiredCommanders.Count);

        foreach (var commander in desiredCommanders)
        {
            datasets.Add(CreateDataset(commander, teammateLabels, entsByPair, minAvgGain, maxAvgGain));
        }

        chartJsConfig.SetDatasetsSmooth(datasets, labels, updateOptions: true);
    }

    private SynergyTooltipDataset CreateDataset(
        Commander commander,
        IReadOnlyList<Commander> teammateLabels,
        Dictionary<(Commander, Commander), SynergyEnt> entsByPair,
        double minAvgGain,
        double maxAvgGain)
    {
        List<object> normalizedValues = new(teammateLabels.Count);
        List<SynergyTooltipPoint> commanderTooltip = new(teammateLabels.Count);

        var commanderName = commander.ToString();

        foreach (var teammate in teammateLabels)
        {
            var ent = GetEnt(commander, teammate, entsByPair);
            var normalized = ent == null ? 0d : Normalize(ent.AvgGain, minAvgGain, maxAvgGain);

            normalizedValues.Add(normalized);
            commanderTooltip.Add(new()
            {
                Commander = commanderName,
                Teammate = teammate.ToString(),
                Normalized = normalized,
                AvgGain = ent?.AvgGain ?? 0,
                Winrate = ent?.Winrate ?? 0,
                Games = ent?.Games ?? 0
            });
        }

        return new SynergyTooltipDataset()
        {
            Id = GetDatasetId(commander),
            Label = commander == Commander.None ? "Player" : commanderName,
            Data = normalizedValues,
            TooltipPoints = commanderTooltip,
            BorderColor = Data.CmdrColor[commander],
            BackgroundColor = $"{Data.CmdrColor[commander]}33",
            BorderWidth = 2,
            PointRadius = 3,
            Fill = true,
            Tension = 0.1
        };
    }

    SynergyEnt? GetEnt(Commander a, Commander b, Dictionary<(Commander, Commander), SynergyEnt> entsByPair)
    {
        return entsByPair.TryGetValue(GetPairKey(a, b), out var ent) ? ent : null;
    }

    private static string GetDatasetId(Commander commander)
    {
        return $"synergy-{commander}";
    }

    private static (Commander, Commander) GetPairKey(Commander a, Commander b)
    {
        return a < b ? (a, b) : (b, a);
    }

    private static double Normalize(double value, double min, double max)
    {
        if (max <= min)
        {
            return 1;
        }

        var normalized = (value - min) / (max - min);
        return Math.Clamp(normalized, 0, 1);
    }

    private string GetTimeInfo(StatsRequest request)
    {
        if (request.Filter != null)
        {
            return $"{request.Filter.DateRange.From:yyyy-MM-dd} - {request.Filter.DateRange.To:yyyy-MM-dd}";
        }

        var timeInfo = Data.GetTimePeriodInfo(request.TimePeriod);
        return $"{timeInfo.Start:yyyy-MM-dd} - {timeInfo.End:yyyy-MM-dd}";
    }

    private static ChartJsConfig GetChartConfig()
    {
        return new ChartJsConfig()
        {
            Type = ChartType.radar,
            Options = new ChartJsOptions()
            {
                Responsive = true,
                MaintainAspectRatio = true,
                Plugins = new Plugins()
                {
                    Title = new Title()
                    {
                        Display = true,
                        Text = new IndexableOption<string>("Synergy AvgGain"),
                        Color = "white",
                        Font = new Font()
                        {
                            Size = 16
                        }
                    },
                    Legend = new Legend()
                    {
                        Display = true,
                        Position = "right",
                        Labels = new Labels()
                        {
                            Color = "#f2f2f2",
                        }
                    },
                    Tooltip = new Tooltip()
                    {
                        Callbacks = new TooltipCallbacks()
                        {
                            Label = ChartJsFunction.FromName("synergyTooltipLabel")
                        }
                    }
                },
                Scales = new ChartJsOptionsScales()
                {
                    R = new LinearRadialAxis()
                    {
                        AngleLines = new AngleLines()
                        {
                            Display = true,
                            Color = "#f2f2f233",
                            BorderDash = [ 2, 5 ],
                            BorderDashOffset = 0
                        },
                        Grid = new ChartJsGrid()
                        {
                            Display = true,
                            Color = "#f2f2f233",
                        },
                        Border = new()
                        {
                            Display = true,
                            Color = "#f2f2f233",
                            Dash = [15, 2],
                            DashOffset = 0
                        },
                        PointLabels = new PointLabels()
                        {
                            Display = true,
                            Font = new Font()
                            {
                                Size = 12
                            },
                            Color = "#f2f2f2"
                        },
                        Ticks = new()
                        {
                            Display = true,
                            Color = "#666",
                            BackdropColor = "transparent",
                            Font = new Font()
                            {
                                Size = 10
                            },
                        },
                        BeginAtZero = true,
                        SuggestedMax = 1.0
                    }
                }
            }
        };
    }

    private sealed record SynergyTooltipDataset : LineDataset
    {
        public List<SynergyTooltipPoint> TooltipPoints { get; set; } = [];
    }

    private sealed class SynergyTooltipPoint
    {
        public string Commander { get; set; } = string.Empty;
        public string Teammate { get; set; } = string.Empty;
        public double Normalized { get; set; }
        public double AvgGain { get; set; }
        public double Winrate { get; set; }
        public int Games { get; set; }
    }
}

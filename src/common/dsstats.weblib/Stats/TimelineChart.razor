@using dsstats.shared
@using pax.BlazorChartJs

<ChartComponent @ref="chartComponent" ChartJsConfig="chartJsConfig" OnEventTriggered="EventTriggered" />

@code {
    [Parameter, EditorRequired]
    public TimelineResponse Response { get; set; } = default!;

    [Parameter, EditorRequired]
    public StatsRequest Request { get; set; } = default!;

    [Parameter]
    public List<Commander> Commanders { get; set; } = [];

    ChartJsConfig chartJsConfig = null!;
    ChartComponent? chartComponent;
    bool chartReady;
    IReadOnlyCollection<Commander> selectedCommanders = [];

    protected override void OnInitialized()
    {
        chartJsConfig = GetChartConfig();
        selectedCommanders = [.. Commanders];
        base.OnInitialized();
    }

    private void EventTriggered(ChartJsEvent chartJsEvent)
    {
        if (chartJsEvent is ChartJsInitEvent)
        {
            chartReady = true;
            PrepareData(Response, Request, selectedCommanders);
        }
    }

    public void PrepareData(TimelineResponse response, StatsRequest request, IEnumerable<Commander> selected)
    {
        Response = response;
        Request = request;
        selectedCommanders = [.. selected];

        if (!chartReady)
        {
            return;
        }

        if (chartJsConfig.Options?.Plugins?.Title != null)
        {
            chartJsConfig.Options.Plugins.Title.Text = new IndexableOption<string>(
                $"Timeline AvgGain - {GetTimeInfo(request)}");
        }

        Dictionary<Commander, TimelineEnt> timelineEntsByCommander = new(response.TimelineEnts.Count);
        foreach (var timelineEnt in response.TimelineEnts)
        {
            timelineEntsByCommander.TryAdd(timelineEnt.Commander, timelineEnt);
        }

        List<ChartJsDataset> datasets = new(timelineEntsByCommander.Count);

        foreach (var commander in selectedCommanders.Distinct().OrderBy(c => c))
        {
            if (timelineEntsByCommander.TryGetValue(commander, out var timelineEnt))
            {
                datasets.Add(GetDataset(commander, timelineEnt));
            }
        }

        chartJsConfig.SetDatasetsSmooth(datasets, TimelineLabels, updateOptions: true);
    }

    private ChartJsDataset GetDataset(Commander commander, TimelineEnt timelineEnt)
    {
        List<object> data = new(11);
        List<TimelineTooltipPoint> tooltipPoints = new(11);

        for (int i = 0; i < 11; i++)
        {
            var bucketStart = i < 10 ? i * 3 + 5 : 35;
            var step = timelineEnt.Steps.FirstOrDefault(s => s.BucketStart == bucketStart);

            data.Add(step?.AvgGain ?? 0);

            tooltipPoints.Add(new()
            {
                AvgGain = step?.AvgGain ?? 0,
                Winrate = step == null || step.Count == 0 ? 0 : (step.Wins / (double)step.Count),
                Games = step?.Count ?? 0,
            });
        }

        var dataset = new TimelineTooltipDataset()
        {
            Id = GetDatasetId(commander),
            Label = commander == Commander.None ? "Player" : commander.ToString(),
            Data = data,
            TooltipPoints = tooltipPoints,
            BorderColor = Data.CmdrColor[commander],
            BackgroundColor = $"{Data.CmdrColor[commander]}1A",
            BorderWidth = 2,
            PointRadius = 3,
            Fill = true,
            Tension = 0.1
        };

        return dataset;
    }

    private static readonly string[] TimelineLabels = ["5-8 min", "8-11 min", "11-14 min", "14-17 min", "17-20 min", "20-23 min", "23-26 min", "26-29 min", "29-32 min", "32-35 min", "35+"];

    private static string GetDatasetId(Commander commander)
    {
        return $"timeline-{commander}";
    }

    private string GetTimeInfo(StatsRequest request)
    {
        if (request.Filter != null)
        {
            return $"{request.Filter.DateRange.From:yyyy-MM-dd} - {request.Filter.DateRange.To:yyyy-MM-dd}";
        }

        var timeInfo = Data.GetTimePeriodInfo(request.TimePeriod);
        return $"{timeInfo.Start:yyyy-MM-dd} - {timeInfo.End:yyyy-MM-dd}";
    }

    private static ChartJsConfig GetChartConfig()
    {
        return new ChartJsConfig()
        {
            Type = ChartType.line,
            Options = new ChartJsOptions()
            {
                Responsive = true,
                MaintainAspectRatio = true,
                Plugins = new Plugins()
                {
                    Title = new Title()
                    {
                        Display = true,
                        Text = new IndexableOption<string>("Timeline AvgGain"),
                        Color = "white",
                        Font = new Font()
                        {
                            Size = 16
                        }
                    },
                    Legend = new Legend()
                    {
                        Display = true,
                        Position = "right",
                        Labels = new Labels()
                        {
                            Color = "#f2f2f2",
                        }
                    },
                    Tooltip = new Tooltip()
                    {
                        Callbacks = new TooltipCallbacks()
                        {
                            Label = ChartJsFunction.FromName("timelineTooltipLabel")
                        }
                    }
                },
                Scales = new()
                {
                    X = new()
                    {
                        Title = new()
                        {
                            Display = true,
                            Text = "Game Duration",
                            Color = "white",
                            Font = new Font()
                            {
                                Size = 14
                            }
                        },
                        Grid = new()
                        {
                            Color = "#444",
                        },
                        Border = new()
                        {
                            Display = true,
                            Color = "#444",
                            Dash = [2, 5],
                            DashOffset = 0
                        },
                        Ticks = new()
                        {
                            Color = "#f2f2f2"
                        }
                    },
                    Y = new()
                    {
                        Title = new()
                        {
                            Display = true,
                            Text = "Average Gain",
                            Color = "white",
                            Font = new Font()
                            {
                                Size = 14
                            }
                        },
                        Grid = new()
                        {
                            Color = "#444"
                        },
                        Border = new()
                        {
                            Display = true,
                            Color = "#444",
                            Dash = [2, 5],
                            DashOffset = 0
                        },
                        Ticks = new()
                        {
                            Color = "#f2f2f2"
                        }
                    }
                }
            }
        };
    }

    private sealed record TimelineTooltipDataset : LineDataset
    {
        public List<TimelineTooltipPoint> TooltipPoints { get; set; } = [];
    }

    private sealed class TimelineTooltipPoint
    {
        public double AvgGain { get; set; }
        public double Winrate { get; set; }
        public int Games { get; set; }
    }
}

@page "/te/play"
@using dsstats.parser
@using dsstats.play
@using dsstats.shared
@using dsstats.shared.Interfaces
@rendermode InteractiveServer
@inject ILogger<PlayPage> Logger
@inject IReplayImportService ReplayImportService

<PageTitle>dsstats - play</PageTitle>

<div class="container-fluid">
    <h3 class="mt-2 fw-bold text-warning d-inline-block p-2 bgchart border border-dark rounded">Play</h3>

    <div class="card shadow-sm border-0 bgchart mb-4" style="max-width: 720px;">
        <div class="card-body">
            <h5 class="card-title mb-3">Replay Spawn Playback</h5>
            <div class="mb-3">
                <label for="playReplayFile" class="form-label">Select Replay File</label>
                <InputFile class="form-control form-control-lg" id="playReplayFile" OnChange="LoadReplay" />
            </div>
            <div class="alert alert-info mb-0" role="alert">
                <small>
                    This page decodes the replay locally, stores the replay playback sidecar, and renders the DTO-backed canvas.
                </small>
            </div>
        </div>
    </div>

    <UnitIconHydrator Class="unit-icon-preview bgchart border border-dark rounded p-3 mb-4">
        <div class="d-flex flex-wrap align-items-end justify-content-between gap-2 mb-3">
            <div>
                <h5 class="text-warning mb-1">Unit Icon Preview</h5>
                <div class="small text-muted">All standard units rendered at 3x playback table size.</div>
            </div>
            <span class="badge text-bg-dark border border-secondary">@IconPreviewCount icons</span>
        </div>
        @foreach (var group in IconPreviewGroups)
        {
            <section class="unit-icon-preview-group" style="--unit-preview-accent: @group.AccentColor;">
                <div class="unit-icon-preview-heading">
                    <span class="unit-icon-preview-dot"></span>
                    <span>@group.Name</span>
                </div>
                <div class="unit-icon-preview-grid">
                    @foreach (var unit in group.Units)
                    {
                        <div class="unit-icon-preview-item" title="@unit.Name">
                            <UnitIcon Class="unit-icon-preview-glyph"
                                      Commander="@group.Commander"
                                      UnitName="@unit.Name"
                                      Size="@IconPreviewSize"
                                      TeamColor="@unit.TeamColor"
                                      Title="@unit.Name" />
                            <span class="unit-icon-preview-label">@unit.Name</span>
                        </div>
                    }
                </div>
            </section>
        }
    </UnitIconHydrator>

    @if (isLoading)
    {
        <div class="mb-4">
            <div class="spinner-border text-warning" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-warning mb-4" style="max-width: 720px;">
            @error
        </div>
    }

    @if (spawnPlayback is not null)
    {
        @if (!string.IsNullOrEmpty(importStatus))
        {
            <div class="alert alert-success mb-4" style="max-width: 720px;">
                @importStatus
            </div>
        }

        <div class="mb-4" style="max-width: 980px;">
            <h5 class="text-warning mb-3">Debug Stats</h5>
            <div class="row g-3">
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Players</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.PlayerCount</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Spawns</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.SpawnCount</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Max Active Spawns</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.MaxSimultaneousActiveSpawns</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Units</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.UnitCount.ToString("N0")</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Died Events</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.UnitsWithDiedEvent.ToString("N0")</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Died Positions</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.UnitsWithDiedPosition.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <SpawnPlaybackCanvas Replay="replayDto" Sidecar="spawnPlaybackSidecar" Playback="spawnPlayback" />
    }
</div>

@code {
    private const long MaxFileSize = 3 * 1024 * 1024;
    private bool isLoading;
    private string error = string.Empty;
    private string importStatus = string.Empty;
    private dsstats.shared.ReplayDto? replayDto;
    private SpawnPlaybackSidecarDto? spawnPlaybackSidecar;
    private SpawnPlaybackReplayNg? spawnPlayback;
    private const int IconPreviewSize = 60;
    private static readonly IconPreviewGroup[] IconPreviewGroups =
    [
        new("Objectives", "Objective", "#F8D34A",
        [
            new("Nexus", "#5DADEC"),
            new("Planetary", "#F87171"),
            new("Cannon", "#F8D34A"),
            new("Bunker", "#F59E0B"),
        ]),
        new("Protoss", "Protoss", "#F4D372",
        [
            new("Zealot"),
            new("Sentry"),
            new("Stalker"),
            new("Adept"),
            new("High Templar"),
            new("Dark Templar"),
            new("Archon"),
            new("Immortal"),
            new("Colossus"),
            new("Disruptor"),
            new("Observer"),
            new("Oracle"),
            new("Phoenix"),
            new("Void Ray"),
            new("Carrier"),
            new("Tempest"),
            new("Mothership"),
        ]),
        new("Terran", "Terran", "#8FB6D6",
        [
            new("Marine"),
            new("Marauder"),
            new("Reaper"),
            new("Ghost"),
            new("Hellbat"),
            new("Hellion"),
            new("Medivac"),
            new("Banshee"),
            new("Viking"),
            new("Raven"),
            new("Siege Tank"),
            new("Cyclone"),
            new("Widow Mine"),
            new("Liberator"),
            new("Thor"),
            new("Battlecruiser"),
        ]),
        new("Zerg", "Zerg", "#B487C8",
        [
            new("Zergling"),
            new("Hydralisk"),
            new("Infestor"),
            new("Overseer"),
            new("Corruptor"),
            new("Lurker"),
            new("Roach"),
            new("Queen"),
            new("Mutalisk"),
            new("Swarm Host"),
            new("Ultralisk"),
            new("Ravager"),
            new("Baneling"),
            new("Viper"),
            new("Brood Lord"),
            new("Locust"),
        ]),
    ];

    private static readonly int IconPreviewCount = IconPreviewGroups.Sum(static group => group.Units.Length);

    private async Task LoadReplay(InputFileChangeEventArgs e)
    {
        isLoading = true;
        error = string.Empty;
        importStatus = string.Empty;
        replayDto = null;
        spawnPlaybackSidecar = null;
        spawnPlayback = null;
        await InvokeAsync(StateHasChanged);

        var file = e.GetMultipleFiles(1).FirstOrDefault();
        if (file is null)
        {
            isLoading = false;
            return;
        }

        try
        {
            using var replayBuffer = new MemoryStream((int)Math.Min(file.Size, MaxFileSize));
            await file.OpenReadStream(MaxFileSize).CopyToAsync(replayBuffer);
            replayBuffer.Position = 0;

            var sc2Replay = await DsstatsParser.GetSc2Replay(replayBuffer);
            if (sc2Replay is null)
            {
                error = "Failed decoding replay.";
                return;
            }

            var directStrikeReplay = DsstatsParser.ParseDirectStrikeReplay(sc2Replay);
            replayDto = DsstatsParser.ParseReplay(sc2Replay);
            if (replayDto is null)
            {
                error = "Failed parsing replay.";
                return;
            }

            spawnPlaybackSidecar = SpawnPlaybackSidecarFactory.Create(sc2Replay, directStrikeReplay);
            if (spawnPlaybackSidecar is null)
            {
                error = "Replay parsed, but it is not eligible for spawn playback.";
                return;
            }

            var encodedSidecar = SpawnPlaybackSidecarCodec.EncodeWithMetadata(spawnPlaybackSidecar);
            replayDto.SpawnPlayback = new()
            {
                Available = true,
                FormatVersion = encodedSidecar.FormatVersion,
                CompressedLength = encodedSidecar.CompressedLength,
                UncompressedLength = encodedSidecar.UncompressedLength,
                UnitCount = encodedSidecar.UnitCount
            };

            var importResult = await ReplayImportService.ImportReplayWithSpawnPlayback(replayDto, encodedSidecar);
            if (importResult?.Success == true)
            {
                importStatus = $"Stored replay playback sidecar for {importResult.ReplayHash}.";
            }
            else
            {
                error = $"Replay parsed, but storing playback failed: {importResult?.Error ?? "unknown error"}";
            }

            spawnPlayback = SpawnPlaybackFactoryNg.Create(replayDto, spawnPlaybackSidecar);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "File: {Filename} play replay decode failed", file.Name);
            error = $"Replay playback unavailable: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private sealed record IconPreviewGroup(string Name, string Commander, string AccentColor, IconPreviewUnit[] Units);

    private sealed record IconPreviewUnit(string Name, string? TeamColor = null);
}

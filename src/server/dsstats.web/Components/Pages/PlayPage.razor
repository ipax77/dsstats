@page "/te/play"
@using dsstats.parser
@using dsstats.play
@using dsstats.shared
@using dsstats.shared.Interfaces
@using dsstats.shared.Units
@using Sc2DirectStrike.Parser
@using s2protocol.NET
@rendermode InteractiveServer
@inject ILogger<PlayPage> Logger
@inject IReplayImportService ReplayImportService

<PageTitle>dsstats - play</PageTitle>

<div class="container-fluid">
    <h3 class="mt-2 fw-bold text-warning d-inline-block p-2 bgchart border border-dark rounded">Play</h3>

    <div class="card shadow-sm border-0 bgchart mb-4" style="max-width: 720px;">
        <div class="card-body">
            <h5 class="card-title mb-3">Replay Spawn Playback</h5>
            <div class="mb-3">
                <label for="playReplayFile" class="form-label">Select Replay File</label>
                <InputFile class="form-control form-control-lg" id="playReplayFile" OnChange="LoadReplay" />
            </div>
            <div class="alert alert-info mb-0" role="alert">
                <small>
                    This page decodes the replay locally, stores the replay playback sidecar, and renders the DTO-backed canvas.
                </small>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="mb-4">
            <div class="spinner-border text-warning" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(error))
    {
        <div class="alert alert-warning mb-4" style="max-width: 720px;">
            @error
        </div>
    }

    @if (spawnPlayback is not null)
    {
        @if (!string.IsNullOrEmpty(importStatus))
        {
            <div class="alert alert-success mb-4" style="max-width: 720px;">
                @importStatus
            </div>
        }

        <div class="mb-4" style="max-width: 980px;">
            <h5 class="text-warning mb-3">Debug Stats</h5>
            <div class="row g-3">
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Players</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.PlayerCount</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Spawns</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.SpawnCount</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Max Active Spawns</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.MaxSimultaneousActiveSpawns</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Units</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.UnitCount.ToString("N0")</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Died Events</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.UnitsWithDiedEvent.ToString("N0")</div>
                        </div>
                    </div>
                </div>
                <div class="col-6 col-md-4 col-xl-2">
                    <div class="card bgchart border-secondary h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small">Died Positions</div>
                            <div class="fs-4 fw-bold">@spawnPlayback.Stats.UnitsWithDiedPosition.ToString("N0")</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <SpawnPlaybackCanvas Replay="replayDto" Sidecar="spawnPlaybackSidecar" />
    }
</div>

@code {
    private const long MaxFileSize = 3 * 1024 * 1024;
    private bool isLoading;
    private string error = string.Empty;
    private string importStatus = string.Empty;
    private dsstats.shared.ReplayDto? replayDto;
    private SpawnPlaybackSidecarDto? spawnPlaybackSidecar;
    private SpawnPlaybackReplay? spawnPlayback;

    private async Task LoadReplay(InputFileChangeEventArgs e)
    {
        isLoading = true;
        error = string.Empty;
        importStatus = string.Empty;
        replayDto = null;
        spawnPlaybackSidecar = null;
        spawnPlayback = null;
        await InvokeAsync(StateHasChanged);

        var file = e.GetMultipleFiles(1).FirstOrDefault();
        if (file is null)
        {
            isLoading = false;
            return;
        }

        try
        {
            using var replayBuffer = new MemoryStream((int)Math.Min(file.Size, MaxFileSize));
            await file.OpenReadStream(MaxFileSize).CopyToAsync(replayBuffer);
            replayBuffer.Position = 0;

            var sc2Replay = await DsstatsParser.GetSc2Replay(replayBuffer);
            if (sc2Replay is null)
            {
                error = "Failed decoding replay.";
                return;
            }

            var directStrikeReplay = DsstatsParser.ParseDirectStrikeReplay(sc2Replay);
            replayDto = DsstatsParser.ParseReplay(sc2Replay);
            if (replayDto is null)
            {
                error = "Failed parsing replay.";
                return;
            }

            spawnPlaybackSidecar = SpawnPlaybackSidecarFactory.Create(sc2Replay, directStrikeReplay);
            var encodedSidecar = SpawnPlaybackSidecarCodec.EncodeWithMetadata(spawnPlaybackSidecar);
            replayDto.SpawnPlayback = new()
            {
                Available = true,
                FormatVersion = encodedSidecar.FormatVersion,
                CompressedLength = encodedSidecar.CompressedLength,
                UncompressedLength = encodedSidecar.UncompressedLength,
                UnitCount = encodedSidecar.UnitCount
            };

            var importResult = await ReplayImportService.ImportReplayWithSpawnPlayback(replayDto, encodedSidecar);
            if (importResult?.Success == true)
            {
                importStatus = $"Stored replay playback sidecar for {importResult.ReplayHash}.";
            }
            else
            {
                error = $"Replay parsed, but storing playback failed: {importResult?.Error ?? "unknown error"}";
            }

            spawnPlayback = SpawnPlaybackFactory.Create(replayDto, spawnPlaybackSidecar);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "File: {Filename} play replay decode failed", file.Name);
            error = $"Replay playback unavailable: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static PlaybackMetadata GetPlaybackMetadata(Sc2Replay replay, DirectStrikeReplay directStrikeReplay)
    {
        var bornEvents = replay.TrackerEvents?.SUnitBornEvents;
        if (bornEvents is null || bornEvents.Count == 0)
        {
            return new([], new Dictionary<SpawnPlaybackUnitKey, IReadOnlyList<int>>());
        }

        var killGameloopsByTag = GetKillGameloopsByKillerTag(replay);
        var unitKillGameloops = GetUnitKillGameloops(bornEvents, killGameloopsByTag);
        var killCountsByTag = GetKillCountsByTag(killGameloopsByTag);
        var landmarks = GetObjectiveLandmarks(bornEvents, killCountsByTag);

        return new(landmarks, unitKillGameloops);
    }

    private static IReadOnlyList<SpawnPlaybackLandmark> GetObjectiveLandmarks(
        ICollection<s2protocol.NET.Models.SUnitBornEvent> bornEvents,
        IReadOnlyDictionary<UnitTag, int> killCountsByTag)
    {
        List<SpawnPlaybackLandmark> landmarks = new(4);
        HashSet<string> seen = new(StringComparer.Ordinal);

        foreach (var bornEvent in bornEvents)
        {
            var landmark = bornEvent.UnitTypeName switch
            {
                "ObjectiveNexus" => CreateLandmark("Nexus", "Base", bornEvent.X, bornEvent.Y, 14, "#5DADEC", bornEvent, killCountsByTag),
                "ObjectivePlanetaryFortress" => CreateLandmark("Planetary", "Base", bornEvent.X, bornEvent.Y, 14, "#F87171", bornEvent, killCountsByTag),
                "ObjectivePhotonCannon" => CreateLandmark("Cannon", "Defense", bornEvent.X, bornEvent.Y, 9, "#F8D34A", bornEvent, killCountsByTag),
                "ObjectiveBunker" => CreateLandmark("Bunker", "Defense", bornEvent.X, bornEvent.Y, 9, "#F59E0B", bornEvent, killCountsByTag),
                _ => null
            };

            if (landmark is null || !seen.Add(landmark.Name))
            {
                continue;
            }

            landmarks.Add(landmark);
            if (landmarks.Count == 4)
            {
                break;
            }
        }

        return landmarks;
    }

    private static Dictionary<UnitTag, List<int>> GetKillGameloopsByKillerTag(Sc2Replay replay)
    {
        Dictionary<UnitTag, List<int>> killGameloops = [];

        var diedEvents = replay.TrackerEvents?.SUnitDiedEvents;
        if (diedEvents is null || diedEvents.Count == 0)
        {
            return killGameloops;
        }

        foreach (var diedEvent in diedEvents)
        {
            if (diedEvent.KillerUnitTagIndex is int killerUnitTagIndex
                && diedEvent.KillerUnitTagRecycle is int killerUnitTagRecycle)
            {
                var tag = new UnitTag(killerUnitTagIndex, killerUnitTagRecycle);
                if (!killGameloops.TryGetValue(tag, out var gameloops))
                {
                    gameloops = [];
                    killGameloops[tag] = gameloops;
                }

                gameloops.Add(diedEvent.Gameloop);
            }
        }

        foreach (var gameloops in killGameloops.Values)
        {
            gameloops.Sort();
        }

        return killGameloops;
    }

    private static Dictionary<UnitTag, int> GetKillCountsByTag(
        IReadOnlyDictionary<UnitTag, List<int>> killGameloopsByTag)
    {
        Dictionary<UnitTag, int> killCounts = new(killGameloopsByTag.Count);
        foreach (var pair in killGameloopsByTag)
        {
            killCounts[pair.Key] = pair.Value.Count;
        }

        return killCounts;
    }

    private static Dictionary<SpawnPlaybackUnitKey, IReadOnlyList<int>> GetUnitKillGameloops(
        ICollection<s2protocol.NET.Models.SUnitBornEvent> bornEvents,
        IReadOnlyDictionary<UnitTag, List<int>> killGameloopsByTag)
    {
        Dictionary<SpawnPlaybackUnitKey, IReadOnlyList<int>> unitKillGameloops = new(bornEvents.Count);
        foreach (var bornEvent in bornEvents)
        {
            var tag = new UnitTag(bornEvent.UnitTagIndex, bornEvent.UnitTagRecycle);
            if (!killGameloopsByTag.TryGetValue(tag, out var killGameloops))
            {
                continue;
            }

            var key = SpawnPlaybackFactory.GetUnitKey(
                bornEvent.UnitIndex,
                bornEvent.Gameloop,
                bornEvent.X,
                bornEvent.Y,
                bornEvent.UnitTypeName);
            unitKillGameloops[key] = killGameloops;
        }

        return unitKillGameloops;
    }

    private static SpawnPlaybackLandmark CreateLandmark(
        string name,
        string kind,
        int x,
        int y,
        double radius,
        string color,
        s2protocol.NET.Models.SUnitBornEvent bornEvent,
        IReadOnlyDictionary<UnitTag, int> killCountsByTag)
    {
        int teamId = y >= SpawnPlaybackFactory.MapHeight / 2 ? 1 : 2;
        int kills = killCountsByTag.GetValueOrDefault(new(bornEvent.UnitTagIndex, bornEvent.UnitTagRecycle));
        return new(name, kind, teamId, x, y, radius, color, kills, bornEvent.SUnitDiedEvent?.Gameloop);
    }

    private static IReadOnlyList<SpawnPlaybackBuildUnit> GetBuildUnitSummaries(
        Sc2Replay replay,
        DirectStrikeReplay directStrikeReplay,
        IReadOnlyDictionary<SpawnPlaybackUnitKey, int> unitKills)
    {
        var bornEvents = replay.TrackerEvents?.SUnitBornEvents;
        if (bornEvents is null || bornEvents.Count == 0)
        {
            return [];
        }

        Dictionary<int, int> playerIndexesByControlPlayerId = GetPlayerIndexesByControlPlayerId(replay, directStrikeReplay);
        if (playerIndexesByControlPlayerId.Count == 0)
        {
            return [];
        }

        PlayerLayout[] playerLayouts = GetPlayerLayouts(bornEvents, directStrikeReplay.Players.Count, playerIndexesByControlPlayerId);
        List<BuildUnitTracker> buildUnits = GetBuildUnits(
            replay,
            directStrikeReplay,
            playerIndexesByControlPlayerId,
            playerLayouts);
        if (buildUnits.Count == 0)
        {
            return [];
        }

        AssignSpawnKillsToBuildUnits(directStrikeReplay, buildUnits, unitKills);

        List<SpawnPlaybackBuildUnit> summaries = new(buildUnits.Count);
        foreach (var buildUnit in buildUnits)
        {
            if (buildUnit.SpawnedUnitCount == 0 && buildUnit.Kills == 0)
            {
                continue;
            }

            var player = directStrikeReplay.Players[buildUnit.PlayerIndex];
            var displayInfo = UnitMapNg.GetColorAndRadius(
                buildUnit.Name,
                (dsstats.shared.Commander)(int)player.Commander);
            summaries.Add(new(
                player.Name,
                player.TeamId,
                player.GamePos,
                UnitMap.GetUnitInfo(buildUnit.Name, (dsstats.shared.Commander)(int)player.Commander).Name,
                buildUnit.BuiltGameloop,
                buildUnit.X,
                buildUnit.Y,
                buildUnit.SpawnedUnitCount,
                buildUnit.Kills,
                displayInfo.radius,
                displayInfo.color));
        }

        summaries.Sort(static (left, right) =>
        {
            int killsComparison = right.Kills.CompareTo(left.Kills);
            if (killsComparison != 0)
            {
                return killsComparison;
            }

            int spawnComparison = right.SpawnedUnitCount.CompareTo(left.SpawnedUnitCount);
            return spawnComparison != 0
                ? spawnComparison
                : left.BuiltGameloop.CompareTo(right.BuiltGameloop);
        });
        return summaries;
    }

    private static Dictionary<int, int> GetPlayerIndexesByControlPlayerId(
        Sc2Replay replay,
        DirectStrikeReplay directStrikeReplay)
    {
        Dictionary<int, int> playerIndexesByControlPlayerId = [];
        Dictionary<int, int> playerIndexesBySlotId = [];
        for (int i = 0; i < directStrikeReplay.Players.Count; i++)
        {
            playerIndexesBySlotId.TryAdd(directStrikeReplay.Players[i].SlotId, i);
        }

        foreach (var setupEvent in replay.TrackerEvents?.SPlayerSetupEvents ?? [])
        {
            int playerIndex;
            if (playerIndexesBySlotId.TryGetValue(setupEvent.SlotId, out int slotPlayerIndex))
            {
                playerIndex = slotPlayerIndex;
            }
            else if (setupEvent.PlayerId > 0 && setupEvent.PlayerId <= directStrikeReplay.Players.Count)
            {
                playerIndex = setupEvent.PlayerId - 1;
            }
            else if (setupEvent.SlotId >= 0 && setupEvent.SlotId < directStrikeReplay.Players.Count)
            {
                playerIndex = setupEvent.SlotId;
            }
            else
            {
                continue;
            }

            playerIndexesByControlPlayerId.TryAdd(setupEvent.PlayerId, playerIndex);
        }

        return playerIndexesByControlPlayerId;
    }

    private static PlayerLayout[] GetPlayerLayouts(
        ICollection<s2protocol.NET.Models.SUnitBornEvent> bornEvents,
        int playerCount,
        IReadOnlyDictionary<int, int> playerIndexesByControlPlayerId)
    {
        PlayerLayout[] playerLayouts = new PlayerLayout[playerCount];
        for (int i = 0; i < playerLayouts.Length; i++)
        {
            playerLayouts[i] = new();
        }

        foreach (var bornEvent in bornEvents)
        {
            if (bornEvent.Gameloop != 0
                || !playerIndexesByControlPlayerId.TryGetValue(bornEvent.ControlPlayerId, out int playerIndex)
                || (uint)playerIndex >= (uint)playerLayouts.Length)
            {
                continue;
            }

            var point = new PlaybackPoint(bornEvent.X, bornEvent.Y);
            switch (bornEvent.UnitTypeName)
            {
                case "StagingAreaFootprintSouth":
                case "AreaMarkerSouth":
                    playerLayouts[playerIndex].South = point;
                    break;
                case "StagingAreaFootprintWest":
                case "AreaMarkerWest":
                    playerLayouts[playerIndex].West = point;
                    break;
                case "StagingAreaFootprintNorth":
                case "AreaMarkerNorth":
                    playerLayouts[playerIndex].North = point;
                    break;
                case "StagingAreaFootprintEast":
                case "AreaMarkerEast":
                    playerLayouts[playerIndex].East = point;
                    break;
            }
        }

        return playerLayouts;
    }

    private static List<BuildUnitTracker> GetBuildUnits(
        Sc2Replay replay,
        DirectStrikeReplay directStrikeReplay,
        IReadOnlyDictionary<int, int> playerIndexesByControlPlayerId,
        PlayerLayout[] playerLayouts)
    {
        List<BuildUnitTracker> buildUnits = [];
        Dictionary<UnitTag, BuildUnitTracker> buildUnitsByTag = [];
        foreach (var bornEvent in replay.TrackerEvents?.SUnitBornEvents ?? [])
        {
            if (bornEvent.Gameloop == 0
                || IsIgnoredBuildUnitName(bornEvent.UnitTypeName)
                || !playerIndexesByControlPlayerId.TryGetValue(bornEvent.ControlPlayerId, out int playerIndex)
                || (uint)playerIndex >= (uint)playerLayouts.Length
                || (uint)playerIndex >= (uint)directStrikeReplay.Players.Count
                || !playerLayouts[playerIndex].Contains(bornEvent.X, bornEvent.Y))
            {
                continue;
            }

            var buildUnit = new BuildUnitTracker(
                playerIndex,
                new(bornEvent.UnitTagIndex, bornEvent.UnitTagRecycle),
                bornEvent.UnitIndex,
                bornEvent.UnitTypeName,
                bornEvent.Gameloop,
                bornEvent.X,
                bornEvent.Y);
            buildUnits.Add(buildUnit);
            buildUnitsByTag[buildUnit.Tag] = buildUnit;
        }

        foreach (var typeChangeEvent in replay.TrackerEvents?.SUnitTypeChangeEvents ?? [])
        {
            var tag = new UnitTag(typeChangeEvent.UnitTagIndex, typeChangeEvent.UnitTagRecycle);
            if (buildUnitsByTag.TryGetValue(tag, out var buildUnit)
                && !IsIgnoredBuildUnitName(typeChangeEvent.UnitTypeName))
            {
                buildUnit.Name = typeChangeEvent.UnitTypeName;
            }
        }

        buildUnits.Sort(static (left, right) => left.BuiltGameloop.CompareTo(right.BuiltGameloop));
        return buildUnits;
    }

    private static void AssignSpawnKillsToBuildUnits(
        DirectStrikeReplay directStrikeReplay,
        IReadOnlyList<BuildUnitTracker> buildUnits,
        IReadOnlyDictionary<SpawnPlaybackUnitKey, int> unitKills)
    {
        for (int playerIndex = 0; playerIndex < directStrikeReplay.Players.Count; playerIndex++)
        {
            var player = directStrikeReplay.Players[playerIndex];
            foreach (var unit in player.Spawns
                .SelectMany(spawn => spawn.Units)
                .OrderBy(unit => unit.Gameloop))
            {
                BuildUnitTracker? matchedBuildUnit = null;
                foreach (var buildUnit in buildUnits)
                {
                    if (buildUnit.PlayerIndex != playerIndex
                        || buildUnit.BuiltGameloop > unit.Gameloop
                        || !IsCompatibleBuildUnitName(buildUnit.Name, unit.Name))
                    {
                        continue;
                    }

                    if (matchedBuildUnit is null
                        || buildUnit.SpawnedUnitCount < matchedBuildUnit.SpawnedUnitCount
                        || (buildUnit.SpawnedUnitCount == matchedBuildUnit.SpawnedUnitCount
                            && buildUnit.BuiltGameloop < matchedBuildUnit.BuiltGameloop))
                    {
                        matchedBuildUnit = buildUnit;
                    }
                }

                if (matchedBuildUnit is null)
                {
                    continue;
                }

                var unitKey = SpawnPlaybackFactory.GetUnitKey(unit.UnitIndex, unit.Gameloop, unit.X, unit.Y, unit.Name);
                matchedBuildUnit.SpawnedUnitCount++;
                matchedBuildUnit.Kills += unitKills.GetValueOrDefault(unitKey);
            }
        }
    }

    private static bool IsCompatibleBuildUnitName(string buildUnitName, string spawnUnitName)
    {
        return string.Equals(buildUnitName, spawnUnitName, StringComparison.Ordinal)
            || string.Equals(string.Concat(buildUnitName, "Lightweight"), spawnUnitName, StringComparison.Ordinal)
            || string.Equals(string.Concat(buildUnitName, "Starlight"), spawnUnitName, StringComparison.Ordinal);
    }

    private static bool IsIgnoredBuildUnitName(string unitTypeName)
    {
        return unitTypeName.StartsWith("MineralField", StringComparison.Ordinal)
            || unitTypeName.StartsWith("RefineryMinerals", StringComparison.Ordinal)
            || unitTypeName.StartsWith("AssimilatorMinerals", StringComparison.Ordinal)
            || unitTypeName.StartsWith("ExtractorMinerals", StringComparison.Ordinal)
            || unitTypeName.StartsWith("StagingArea", StringComparison.Ordinal)
            || unitTypeName.StartsWith("AreaMarker", StringComparison.Ordinal)
            || unitTypeName.StartsWith("Objective", StringComparison.Ordinal)
            || unitTypeName.StartsWith("Worker", StringComparison.Ordinal);
    }

    private sealed record PlaybackMetadata(
        IReadOnlyList<SpawnPlaybackLandmark> Landmarks,
        IReadOnlyDictionary<SpawnPlaybackUnitKey, IReadOnlyList<int>> UnitKillGameloops);

    private sealed class BuildUnitTracker(
        int playerIndex,
        UnitTag tag,
        int unitIndex,
        string name,
        int builtGameloop,
        int x,
        int y)
    {
        public int PlayerIndex { get; } = playerIndex;
        public UnitTag Tag { get; } = tag;
        public int UnitIndex { get; } = unitIndex;
        public string Name { get; set; } = name;
        public int BuiltGameloop { get; } = builtGameloop;
        public int X { get; } = x;
        public int Y { get; } = y;
        public int SpawnedUnitCount { get; set; }
        public int Kills { get; set; }
    }

    private sealed class PlayerLayout
    {
        public PlaybackPoint? East { get; set; }
        public PlaybackPoint? North { get; set; }
        public PlaybackPoint? South { get; set; }
        public PlaybackPoint? West { get; set; }

        public bool Contains(int x, int y)
        {
            if (South is not { } south || East is not { } east || North is not { } north || West is not { } west)
            {
                return false;
            }

            var point = new PlaybackPoint(x, y);
            bool inside = false;
            return AddSegment(west, south, point, ref inside)
                || AddSegment(south, east, point, ref inside)
                || AddSegment(east, north, point, ref inside)
                || AddSegment(north, west, point, ref inside)
                || inside;
        }

        private static bool AddSegment(PlaybackPoint start, PlaybackPoint end, PlaybackPoint position, ref bool inside)
        {
            if (IsOnSegment(start, end, position))
            {
                return true;
            }

            bool intersects = (end.Y > position.Y) != (start.Y > position.Y)
                && IsLeftOfIntersection(start, end, position);
            if (intersects)
            {
                inside = !inside;
            }

            return false;
        }

        private static bool IsLeftOfIntersection(PlaybackPoint start, PlaybackPoint end, PlaybackPoint position)
        {
            int dy = start.Y - end.Y;
            long left = ((long)position.X - end.X) * dy;
            long right = (long)(start.X - end.X) * (position.Y - end.Y);
            return dy > 0 ? left < right : left > right;
        }

        private static bool IsOnSegment(PlaybackPoint start, PlaybackPoint end, PlaybackPoint position)
        {
            long crossProduct = (((long)position.Y - start.Y) * (end.X - start.X))
                - (((long)position.X - start.X) * (end.Y - start.Y));
            return crossProduct == 0 && position.X >= Math.Min(start.X, end.X)
                && position.X <= Math.Max(start.X, end.X)
                && position.Y >= Math.Min(start.Y, end.Y)
                && position.Y <= Math.Max(start.Y, end.Y);
        }
    }

    private readonly record struct UnitTag(int UnitTagIndex, int UnitTagRecycle);

    private readonly record struct PlaybackPoint(int X, int Y);
}

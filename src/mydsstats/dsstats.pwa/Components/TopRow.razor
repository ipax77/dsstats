@using dsstats.pwa.Services
@using dsstats.indexedDb.Services
@inject DecodeService DecodeService
@inject IndexedDbService DbService
@inject PwaUpdateService PwaUpdateService
@implements IDisposable

<div class="top-row d-flex flex-wrap align-items-center gap-2 px-4 py-3 bg-dark text-light">
	@if (PwaUpdateService.IsUpdateAvailable)
	{
		<button class="btn btn-warning btn-sm" @onclick="ApplyUpdate" disabled="@isApplyingUpdate">
			<i class="bi bi-arrow-clockwise me-1"></i>Update
		</button>
	}

	@if (hasDirHandles)
	{
		<button class="btn btn-success btn-sm" @onclick="DecodeAll"
				disabled="@(isDecoding || DecodeService.Decoding)">
			<i class="bi bi-folder2-open me-1"></i>Decode All
		</button>
		<a href="/decode" class="btn btn-outline-secondary btn-sm">
			<i class="bi bi-folder-symlink me-1"></i>Manage Folders
		</a>
	}
	@if (isDecoding || DecodeService.Decoding)
	{
		<button class="btn btn-danger btn-sm" @onclick="DecodeService.Cancel">
			<i class="bi bi-stop-circle me-1"></i>Cancel
		</button>
	}

	<span class="text-warning d-inline-flex align-items-center"
		  title="@BackgroundDecodeWarning"
		  aria-label="@BackgroundDecodeWarning"
		  tabindex="0">
		<i class="bi bi-exclamation-triangle-fill"></i>
		<span class="visually-hidden">@BackgroundDecodeWarning</span>
	</span>

	<span class="badge bg-info text-dark">Decoded in DB: @totalReplayCount</span>
	@if (storageEstimate is not null && storageEstimate.Quota > 0)
	{
		<span class="badge @GetStorageBadgeClass()"
			  title="@GetStorageTooltip()">
			Storage: @FormatBytes(storageEstimate.Usage) / @FormatBytes(storageEstimate.Quota) (@FormatStoragePercent())
		</span>
	}

	@if (decodeInfo != null)
	{
		@if (decodeInfo.Total > 0)
		{
			<span class="badge bg-secondary">Processed: @decodeInfo.Done / @decodeInfo.Total</span>
			<span class="badge bg-success">Saved: @decodeInfo.Successful</span>
			<span class="badge bg-danger">Errors: @decodeInfo.Error</span>
			<span class="badge bg-light text-dark">Elapsed: @DecodeDisplayFormatter.FormatElapsed(decodeInfo)</span>
			@if (decodeInfo.IsIdle)
			{
				<span class="badge bg-warning text-dark d-inline-flex align-items-center gap-1">
					Idle for: @DecodeDisplayFormatter.FormatIdle(decodeInfo)
					<i class="bi bi-info-circle" title="@IdleDecodeTooltip" aria-label="@IdleDecodeTooltip" tabindex="0"></i>
				</span>
			}
			else if (decodeInfo.TotalIdleTime > TimeSpan.Zero)
			{
				<span class="badge bg-warning text-dark d-inline-flex align-items-center gap-1">
					Idle total: @DecodeDisplayFormatter.FormatTotalIdle(decodeInfo)
					<i class="bi bi-info-circle" title="@IdleDecodeTooltip" aria-label="@IdleDecodeTooltip" tabindex="0"></i>
				</span>
			}
			<span class="badge bg-light text-dark">ETA: @decodeInfo.Eta.ToString(@"hh\:mm\:ss")</span>
		} else
		{
			<span class="badge bg-secondary">@decodeInfo.Done</span>
			<span class="badge bg-danger">Errors: @decodeInfo.Error</span>
			<span class="badge bg-light text-dark">Elapsed: @DecodeDisplayFormatter.FormatElapsed(decodeInfo)</span>
			@if (decodeInfo.IsIdle)
			{
				<span class="badge bg-warning text-dark d-inline-flex align-items-center gap-1">
					Idle for: @DecodeDisplayFormatter.FormatIdle(decodeInfo)
					<i class="bi bi-info-circle" title="@IdleDecodeTooltip" aria-label="@IdleDecodeTooltip" tabindex="0"></i>
				</span>
			}
			else if (decodeInfo.TotalIdleTime > TimeSpan.Zero)
			{
				<span class="badge bg-warning text-dark d-inline-flex align-items-center gap-1">
					Idle total: @DecodeDisplayFormatter.FormatTotalIdle(decodeInfo)
					<i class="bi bi-info-circle" title="@IdleDecodeTooltip" aria-label="@IdleDecodeTooltip" tabindex="0"></i>
				</span>
			}
		}

		@if (decodeInfo.UploadStatus == UploadStatus.Uploading)
		{
			<div class="d-flex align-items-center">
				<div class="spinner-border spinner-border-sm text-success me-1" role="status">
					<span class="visually-hidden">Uploading...</span>
				</div>
				<span>Uploading...</span>
			</div>
		}
		else if (decodeInfo.UploadStatus == UploadStatus.UploadSuccess)
		{
			<span class="d-flex align-items-center text-success">
				<i class="bi bi-check-circle-fill me-1"></i> Upload Successful
			</span>
		}
		else if (decodeInfo.UploadStatus == UploadStatus.UploadError)
		{
			<span class="d-flex align-items-center text-danger">
				<i class="bi bi-x-circle me-1"></i> Upload Failed
			</span>
		}
	}
	else
	{
		<span class="badge bg-success">Ready</span>
	}

	<div class="ms-auto d-flex align-items-center gap-2">
		<span class="small text-light opacity-50">v@(DecodeService.Version.ToString())</span>
		<AuthorizeView>
			<Authorized Context="authState">
				<span class="small text-light">@authState.User.Identity?.Name</span>
				<button type="button"
						class="btn btn-outline-light btn-sm"
						title="InHouse settings"
						data-bs-toggle="modal"
						data-bs-target="#inHouseAccountSettingsModal">
					<i class="bi bi-gear"></i>
					<span class="visually-hidden">InHouse settings</span>
				</button>
			</Authorized>
		</AuthorizeView>
	</div>
</div>

<AuthorizeView>
	<Authorized>
		<InHouseAccountSettingsModal />
	</Authorized>
</AuthorizeView>

@code {
	private const string BackgroundDecodeWarning = "Replay decoding may pause while this tab is in the background. You can safely return later; decoding will resume automatically.";
	private const string IdleDecodeTooltip = "Chrome may freeze background tabs to save resources. Replay decoding resumes automatically when the page wakes, and this paused time is excluded from elapsed time and ETA.";
	private DecodeInfoEventArgs? decodeInfo;
	private bool hasDirHandles;
	private bool isDecoding;
	private bool isApplyingUpdate;
	private int totalReplayCount;
	private int? decodeStartReplayCount;
	private StorageEstimateDto? storageEstimate;

	protected override async Task OnInitializedAsync()
	{
		DecodeService.DecodeStateChanged += OnDecodeStateChanged;
		PwaUpdateService.UpdateAvailableChanged += OnUpdateAvailableChanged;
		await RefreshTopRowState();
		await PwaUpdateService.InitializeAsync();
	}

	private void OnUpdateAvailableChanged()
		=> _ = InvokeAsync(StateHasChanged);

	private void OnDecodeStateChanged(object? sender, DecodeInfoEventArgs e)
	{
		decodeInfo = MergeDecodeInfo(e);
		UpdateReplayCount(e);
		if (e.Finished)
		{
			isDecoding = false;
			decodeStartReplayCount = null;
			_ = RefreshTopRowState();
		}
		InvokeAsync(StateHasChanged);
	}

	private DecodeInfoEventArgs MergeDecodeInfo(DecodeInfoEventArgs e)
	{
		var hasDecodePayload = e.Total > 0 || e.Done > 0 || e.Successful > 0 || e.Error > 0 || e.Finished;
		if (hasDecodePayload || decodeInfo is null)
		{
			return e;
		}

		return new DecodeInfoEventArgs
		{
			Done = decodeInfo.Done,
			Successful = decodeInfo.Successful,
			Total = decodeInfo.Total,
			Error = decodeInfo.Error,
			Eta = decodeInfo.Eta,
			Elapsed = decodeInfo.Elapsed,
			IdleTime = decodeInfo.IdleTime,
			TotalIdleTime = decodeInfo.TotalIdleTime,
			IsIdle = decodeInfo.IsIdle,
			Saving = decodeInfo.Saving,
			Finished = decodeInfo.Finished,
			Info = e.Info ?? decodeInfo.Info,
			UploadStatus = e.UploadStatus
		};
	}

	private void UpdateReplayCount(DecodeInfoEventArgs e)
	{
		if (e.Total <= 0)
		{
			return;
		}

		decodeStartReplayCount ??= totalReplayCount;
		totalReplayCount = decodeStartReplayCount.Value + e.Successful;
	}

	private async Task RefreshTopRowState()
	{
		var entries = await DbService.GetAllDirectoryHandleEntries();
		hasDirHandles = entries.Count > 0;
		totalReplayCount = await DbService.GetTotalReplayCountAsync();
		storageEstimate = await DbService.GetStorageEstimateAsync();
		await InvokeAsync(StateHasChanged);
	}

	private string GetStorageBadgeClass()
	{
		var percent = GetStorageUsageRatio();
		if (percent >= 0.9)
		{
			return "bg-danger";
		}

		if (percent >= 0.75)
		{
			return "bg-warning text-dark";
		}

		return "bg-info text-dark";
	}

	private string GetStorageTooltip()
	{
		if (storageEstimate is null)
		{
			return string.Empty;
		}

		return $"Browser storage used by this app origin. Usage: {FormatBytes(storageEstimate.Usage)}. Quota: {FormatBytes(storageEstimate.Quota)}.";
	}

	private string FormatStoragePercent()
	{
		return GetStorageUsageRatio().ToString("P1");
	}

	private double GetStorageUsageRatio()
	{
		if (storageEstimate is null || storageEstimate.Quota <= 0)
		{
			return 0;
		}

		return Math.Clamp(storageEstimate.Usage / storageEstimate.Quota, 0, 1);
	}

	private static string FormatBytes(double bytes)
	{
		string[] units = ["B", "KB", "MB", "GB", "TB"];
		var value = Math.Max(0, bytes);
		var unitIndex = 0;
		while (value >= 1024 && unitIndex < units.Length - 1)
		{
			value /= 1024;
			unitIndex++;
		}

		return unitIndex == 0
			? $"{value:N0} {units[unitIndex]}"
			: $"{value:N1} {units[unitIndex]}";
	}

	private async Task DecodeAll()
	{
		isDecoding = true;
		await InvokeAsync(StateHasChanged);
		try
		{
			await DecodeService.DecodeAllHandles();
		}
		finally
		{
			isDecoding = false;
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task ApplyUpdate()
	{
		isApplyingUpdate = true;
		await InvokeAsync(StateHasChanged);

		try
		{
			await PwaUpdateService.ApplyUpdateAsync();
		}
		finally
		{
			isApplyingUpdate = false;
			await InvokeAsync(StateHasChanged);
		}
	}

	public void Dispose()
	{
		DecodeService.DecodeStateChanged -= OnDecodeStateChanged;
		PwaUpdateService.UpdateAvailableChanged -= OnUpdateAvailableChanged;
	}
}

@using dsstats.pwa.Services
@using dsstats.indexedDb.Services
@inject DecodeService DecodeService
@inject IndexedDbService DbService
@inject PwaUpdateService PwaUpdateService
@implements IDisposable

<div class="top-row d-flex flex-wrap align-items-center gap-2 px-4 py-3 bg-dark text-light">
	@if (PwaUpdateService.IsUpdateAvailable)
	{
		<button class="btn btn-warning btn-sm" @onclick="ApplyUpdate" disabled="@isApplyingUpdate">
			<i class="bi bi-arrow-clockwise me-1"></i>Update
		</button>
	}

	@if (hasDirHandles)
	{
		<button class="btn btn-success btn-sm" @onclick="DecodeAll"
				disabled="@(isDecoding || DecodeService.Decoding)">
			<i class="bi bi-folder2-open me-1"></i>Decode All
		</button>
		<a href="/decode" class="btn btn-outline-secondary btn-sm">
			<i class="bi bi-folder-symlink me-1"></i>Manage Folders
		</a>
	}
	@if (isDecoding || DecodeService.Decoding)
	{
		<button class="btn btn-danger btn-sm" @onclick="DecodeService.Cancel">
			<i class="bi bi-stop-circle me-1"></i>Cancel
		</button>
	}

	<span class="badge bg-info text-dark">Decoded in DB: @totalReplayCount</span>

	@if (decodeInfo != null)
	{
		@if (decodeInfo.Total > 0)
		{
			<span class="badge bg-secondary">Processed: @decodeInfo.Done / @decodeInfo.Total</span>
			<span class="badge bg-success">Saved: @decodeInfo.Successful</span>
			<span class="badge bg-danger">Errors: @decodeInfo.Error</span>
			<span class="badge bg-light text-dark">Elapsed: @decodeInfo.Elapsed.ToString(@"hh\:mm\:ss")</span>
			<span class="badge bg-light text-dark">ETA: @decodeInfo.Eta.ToString(@"hh\:mm\:ss")</span>
		} else
		{
			<span class="badge bg-secondary">@decodeInfo.Done</span>
			<span class="badge bg-danger">Errors: @decodeInfo.Error</span>
			<span class="badge bg-light text-dark">Elapsed: @decodeInfo.Elapsed.ToString(@"hh\:mm\:ss")</span>
		}

		@if (decodeInfo.UploadStatus == UploadStatus.Uploading)
		{
			<div class="d-flex align-items-center">
				<div class="spinner-border spinner-border-sm text-success me-1" role="status">
					<span class="visually-hidden">Uploading...</span>
				</div>
				<span>Uploading...</span>
			</div>
		}
		else if (decodeInfo.UploadStatus == UploadStatus.UploadSuccess)
		{
			<span class="d-flex align-items-center text-success">
				<i class="bi bi-check-circle-fill me-1"></i> Upload Successful
			</span>
		}
		else if (decodeInfo.UploadStatus == UploadStatus.UploadError)
		{
			<span class="d-flex align-items-center text-danger">
				<i class="bi bi-x-circle me-1"></i> Upload Failed
			</span>
		}
	}
	else
	{
		<span class="badge bg-success">Ready</span>
	}

	<span class="ms-auto small text-light opacity-50">v@(DecodeService.Version.ToString())</span>
</div>

@code {
	private DecodeInfoEventArgs? decodeInfo;
	private bool hasDirHandles;
	private bool isDecoding;
	private bool isApplyingUpdate;
	private int totalReplayCount;
	private int? decodeStartReplayCount;

	protected override async Task OnInitializedAsync()
	{
		DecodeService.DecodeStateChanged += OnDecodeStateChanged;
		PwaUpdateService.UpdateAvailableChanged += OnUpdateAvailableChanged;
		await RefreshTopRowState();
		await PwaUpdateService.InitializeAsync();
	}

	private void OnUpdateAvailableChanged()
		=> _ = InvokeAsync(StateHasChanged);

	private void OnDecodeStateChanged(object? sender, DecodeInfoEventArgs e)
	{
		decodeInfo = MergeDecodeInfo(e);
		UpdateReplayCount(e);
		if (e.Finished)
		{
			isDecoding = false;
			decodeStartReplayCount = null;
			_ = RefreshTopRowState();
		}
		InvokeAsync(StateHasChanged);
	}

	private DecodeInfoEventArgs MergeDecodeInfo(DecodeInfoEventArgs e)
	{
		var hasDecodePayload = e.Total > 0 || e.Done > 0 || e.Successful > 0 || e.Error > 0 || e.Finished;
		if (hasDecodePayload || decodeInfo is null)
		{
			return e;
		}

		return new DecodeInfoEventArgs
		{
			Done = decodeInfo.Done,
			Successful = decodeInfo.Successful,
			Total = decodeInfo.Total,
			Error = decodeInfo.Error,
			Eta = decodeInfo.Eta,
			Elapsed = decodeInfo.Elapsed,
			Saving = decodeInfo.Saving,
			Finished = decodeInfo.Finished,
			Info = e.Info ?? decodeInfo.Info,
			UploadStatus = e.UploadStatus
		};
	}

	private void UpdateReplayCount(DecodeInfoEventArgs e)
	{
		if (e.Total <= 0)
		{
			return;
		}

		decodeStartReplayCount ??= totalReplayCount;
		totalReplayCount = decodeStartReplayCount.Value + e.Successful;
	}

	private async Task RefreshTopRowState()
	{
		var entries = await DbService.GetAllDirectoryHandleEntries();
		hasDirHandles = entries.Count > 0;
		totalReplayCount = await DbService.GetTotalReplayCountAsync();
		await InvokeAsync(StateHasChanged);
	}

	private async Task DecodeAll()
	{
		isDecoding = true;
		await InvokeAsync(StateHasChanged);
		try
		{
			await DecodeService.DecodeAllHandles();
		}
		finally
		{
			isDecoding = false;
			await InvokeAsync(StateHasChanged);
		}
	}

	private async Task ApplyUpdate()
	{
		isApplyingUpdate = true;
		await InvokeAsync(StateHasChanged);

		try
		{
			await PwaUpdateService.ApplyUpdateAsync();
		}
		finally
		{
			isApplyingUpdate = false;
			await InvokeAsync(StateHasChanged);
		}
	}

	public void Dispose()
	{
		DecodeService.DecodeStateChanged -= OnDecodeStateChanged;
		PwaUpdateService.UpdateAvailableChanged -= OnUpdateAvailableChanged;
	}
}

@page "/inhouse"
@using dsstats.indexedDb.Services
@using dsstats.pwa.Services
@using dsstats.shared
@using dsstats.shared.InHouse
@using dsstats.shared.Interfaces
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.JSInterop
@using dsstats.weblib.Players
@using dsstats.weblib.Replays
@implements IAsyncDisposable
@inject InHouseAuthClient Auth
@inject InHouseGameSessionsClient SessionsClient
@inject DecodeService DecodeService
@inject SessionProgressService SessionProgressService
@inject IPlayerService PlayerService
@inject IJSRuntime JS
@inject InHouseHubOptions HubOptions

<PageTitle>mydsstats - InHouse</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
        <div class="d-inline-block p-2 bgchart rounded">
            <h2 class="fw-bold mb-1">InHouse Sessions</h2>
            <div class="text-muted">Private Direct Strike runs, shared by signed-in players.</div>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <input class="form-control" style="max-width: 18rem;" placeholder="Session name" @bind="newSessionName" />
                    <button class="btn btn-primary" @onclick="CreateSessionAsync" disabled="@busy">
                        <i class="bi bi-plus-lg me-1"></i>Create
                    </button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>
    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-warning" role="status"></div>
        </div>
    }
    else if (!passkeysSupported)
    {
        <div class="alert alert-warning">
            Passkeys are not available in this browser context. Use HTTPS or localhost with a browser that supports WebAuthn.
        </div>
    }
    else
    {
        <AuthorizeView>
            <Authorized>
                <div class="row g-3 align-items-start">
                    <div class="col-xl-3 col-lg-4">
                        <div class="card border-light">
                            <div class="card-header bgchart2">
                                <h5 class="text-warning mb-0">Active Sessions</h5>
                            </div>
                            <div class="list-group list-group-flush">
                                @if (sessions.Count == 0)
                                {
                                    <div class="list-group-item bgchart text-muted">No active sessions yet.</div>
                                }
                                @foreach (var session in sessions)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action bgchart @(selectedSession?.SessionId == session.SessionId ? "active" : "")"
                                            @onclick="() => SelectSessionAsync(session.SessionId)">
                                        <div class="d-flex justify-content-between gap-2">
                                            <span class="fw-semibold">@session.Name</span>
                                            <span class="badge text-bg-secondary">@session.Games</span>
                                        </div>
                                        <div class="small text-muted">@session.CreatedByDisplayName · @session.CreatedAt.ToLocalTime().ToString("g")</div>
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="card border-light mt-3">
                            <div class="card-header bgchart2 d-flex align-items-center justify-content-between gap-2">
                                <h5 class="text-warning mb-0">Closed Sessions</h5>
                                <span class="badge text-bg-secondary">@closedSessionsTotal</span>
                            </div>
                            <div class="list-group list-group-flush">
                                @if (closedSessions.Count == 0)
                                {
                                    <div class="list-group-item bgchart text-muted">No closed sessions yet.</div>
                                }
                                @foreach (var session in closedSessions)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action bgchart @(selectedSession?.SessionId == session.SessionId ? "active" : "")"
                                            @onclick="() => SelectClosedSessionAsync(session.SessionId)">
                                        <div class="d-flex justify-content-between gap-2">
                                            <span class="fw-semibold">@session.Name</span>
                                            <span class="badge text-bg-secondary">@session.Games</span>
                                        </div>
                                        <div class="small text-muted">@session.CreatedByDisplayName · @session.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                                    </button>
                                }
                            </div>
                            <div class="card-footer bgchart2 d-flex justify-content-between align-items-center gap-2">
                                <button class="btn btn-outline-light btn-sm" @onclick="PreviousClosedSessionsPageAsync" disabled="@(busy || closedSessionsPage <= 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                                <span class="small text-muted">Page @closedSessionsPage of @ClosedSessionsPageCount</span>
                                <button class="btn btn-outline-light btn-sm" @onclick="NextClosedSessionsPageAsync" disabled="@(busy || closedSessionsPage >= ClosedSessionsPageCount)">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-9 col-lg-8">
                        @if (selectedSession is null)
                        {
                            <div class="alert alert-secondary mb-0">Select or create a session.</div>
                        }
                        else
                        {
                            <div class="card border-light mb-3">
                                <div class="card-header bgchart2 d-flex flex-wrap align-items-center justify-content-between gap-2">
                                    <div>
                                        <h4 class="text-warning mb-0">@selectedSession.Name</h4>
                                        <div class="small text-muted">
                                            Created by @selectedSession.CreatedByDisplayName · @selectedSession.CreatedAt.ToLocalTime().ToString("g")
                                        </div>
                                    </div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <button class="btn btn-outline-light btn-sm" @onclick="RefreshAsync" disabled="@busy">
                                            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                                        </button>
                                        <AuthorizeView Policy="CloseSession" Resource="@selectedSession" Context="closeSessionAuth">
                                            <button class="btn btn-outline-danger btn-sm" @onclick="CloseSessionAsync" disabled="@busy">
                                                <i class="bi bi-lock me-1"></i>Close
                                            </button>
                                        </AuthorizeView>
                                        <AuthorizeView Roles="Admin" Context="deleteSessionAuth">
                                            <button class="btn btn-danger btn-sm" @onclick="DeleteSessionAsync" disabled="@busy">
                                                <i class="bi bi-trash me-1"></i>Delete
                                            </button>
                                        </AuthorizeView>
                                    </div>
                                </div>
                                <div class="card-body bgchart">
                                    @if (selectedSession.ClosedAt is not null)
                                    {
                                        <div class="alert alert-secondary mb-3">This session is closed.</div>
                                    }
                                    else
                                    {
                                        <label class="form-label">Upload replay</label>
                                        <InputFile class="form-control" OnChange="UploadReplayAsync" accept=".SC2Replay" disabled="@busy" />
                                        <div class="small text-muted mt-2">Decoded locally, then attached to this session with observer metadata.</div>
                                    }
                                </div>
                            </div>

                            @if (!IsSelectedSessionClosed)
                            {
                                <div class="card border-light mb-3">
                                    <div class="card-header bgchart2 d-flex flex-wrap align-items-center justify-content-between gap-2">
                                        <h5 class="text-warning mb-0">Next Match</h5>
                                        <button class="btn btn-outline-light btn-sm" @onclick="ResetMatchmakingDraft" disabled="@(selectedSession.RosterPlayers.Count == 0)">
                                            <i class="bi bi-shuffle me-1"></i>Suggest
                                        </button>
                                    </div>
                                    <div class="card-body bgchart">
                                        <div class="row g-3">
                                            <div class="col-xl-4">
                                                <div class="border border-secondary rounded p-2 h-100">
                                                    <div class="fw-semibold text-warning mb-2">Add player</div>
                                                    <div class="input-group input-group-sm mb-2">
                                                        <input class="form-control" placeholder="Search ratings" @bind="playerSearchName" @bind:event="oninput" />
                                                        <button class="btn btn-outline-light" @onclick="SearchRosterPlayersAsync" disabled="@busy">
                                                            <i class="bi bi-search"></i>
                                                        </button>
                                                    </div>
                                                    @if (playerSearchResults.Count > 0)
                                                    {
                                                        <div class="list-group mb-2" style="max-height: 12rem; overflow: auto;">
                                                            @foreach (var rating in playerSearchResults)
                                                            {
                                                                <button type="button" class="list-group-item list-group-item-action bgchart py-1"
                                                                        @onclick="() => SelectRosterSearchResult(rating)">
                                                                    <span class="fw-semibold">@rating.Name</span>
                                                                    <span class="small text-muted ms-2">@rating.Rating.ToString("N0") · @rating.ToonIdString</span>
                                                                </button>
                                                            }
                                                        </div>
                                                    }
                                                    <div class="row g-2">
                                                        <div class="col-12">
                                                            <input class="form-control form-control-sm" placeholder="Name" @bind="manualRosterName" />
                                                        </div>
                                                        <div class="col-4">
                                                            <input type="number" class="form-control form-control-sm" placeholder="Region" @bind="manualRosterRegion" />
                                                        </div>
                                                        <div class="col-4">
                                                            <input type="number" class="form-control form-control-sm" placeholder="Realm" @bind="manualRosterRealm" />
                                                        </div>
                                                        <div class="col-4">
                                                            <input type="number" class="form-control form-control-sm" placeholder="Toon" @bind="manualRosterToonId" />
                                                        </div>
                                                        <div class="col-8">
                                                            <input type="number" class="form-control form-control-sm" placeholder="Rating" @bind="manualRosterRating" />
                                                        </div>
                                                        <div class="col-4 d-flex align-items-center">
                                                            <div class="form-check form-switch">
                                                                <input class="form-check-input" type="checkbox" id="newPlayerSitter" @bind="manualRosterSitter" />
                                                                <label class="form-check-label small" for="newPlayerSitter">Sitter</label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <button class="btn btn-primary btn-sm mt-2 w-100" @onclick="AddRosterPlayerAsync" disabled="@busy">
                                                        <i class="bi bi-person-plus me-1"></i>Add / update roster
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="col-xl-8">
                                                @if (matchmakingSuggestion is null || selectedSession.RosterPlayers.Count == 0)
                                                {
                                                    <div class="text-muted">Add players or upload a replay to get a next-game suggestion.</div>
                                                }
                                                else
                                                {
                                                    var scores = GetDraftScores();
                                                    <div class="d-flex flex-wrap gap-2 mb-3">
                                                        <span class="badge text-bg-secondary">Balance @scores.BalanceScore.ToString("N0")</span>
                                                        <span class="badge text-bg-secondary">Least played @scores.LeastPlayedScore</span>
                                                        <span class="badge text-bg-secondary">Same roster @scores.SameRosterScore</span>
                                                        <span class="badge text-bg-secondary">Team 1 @scores.Team1Rating.ToString("N0")</span>
                                                        <span class="badge text-bg-secondary">Team 2 @scores.Team2Rating.ToString("N0")</span>
                                                    </div>
                                                    @foreach (var warning in matchmakingSuggestion.Warnings)
                                                    {
                                                        <div class="alert alert-warning py-2 mb-2">@warning</div>
                                                    }
                                                    <div class="row g-3">
                                                        <div class="col-lg-6">
                                                            @RenderTeam("Team 1", draftTeam1, "team1")
                                                        </div>
                                                        <div class="col-lg-6">
                                                            @RenderTeam("Team 2", draftTeam2, "team2")
                                                        </div>
                                                        <div class="col-lg-6">
                                                            @RenderTeam("Bench", draftBench, "bench")
                                                        </div>
                                                        <div class="col-lg-6">
                                                            @RenderTeam("Sitters", matchmakingSuggestion.Sitters, "sitters")
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="card border-light mb-3">
                                <div class="card-header bgchart2">
                                    <h5 class="text-warning mb-0">Player Summary</h5>
                                </div>
                                <div class="card-body bgchart">
                                    @if (selectedSession.Players.Count == 0)
                                    {
                                        <div class="text-muted">No players yet.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="tptable w-auto">
                                                <thead>
                                                    <tr>
                                                        <th>Name</th>
                                                        <th>Games</th>
                                                        <th>Obs</th>
                                                        <th>Winrate</th>
                                                        <th>Start</th>
                                                        <th>End</th>
                                                        <th>Gain</th>
                                                        <th>Avg</th>
                                                        <th>Latest</th>
                                                        @if (!IsSelectedSessionClosed)
                                                        {
                                                            <th>Sitter</th>
                                                        }
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var player in selectedSession.Players)
                                                    {
                                                        <tr>
                                                            <td>@player.Name</td>
                                                            <td>@player.Games</td>
                                                            <td>@player.Observes</td>
                                                            <td>@player.Winrate.ToString("P0")</td>
                                                            <td>@FormatRating(player.RatingStart)</td>
                                                            <td>@FormatRating(player.RatingEnd)</td>
                                                            <td class="@GetGainClass(player.RatingDelta)">@FormatGain(player.RatingDelta)</td>
                                                            <td class="@GetGainClass(player.AverageGain)">@FormatGain(player.AverageGain)</td>
                                                            <td>
                                                                @if (player.PlayedLatestGame)
                                                                {
                                                                    <span class="badge text-bg-success">Played</span>
                                                                }
                                                                else if (player.ObservedLatestGame)
                                                                {
                                                                    <span class="badge text-bg-warning">Observed</span>
                                                                }
                                                                else if (player.RatingsPending)
                                                                {
                                                                    <span class="badge text-bg-secondary">Rating pending</span>
                                                                }
                                                            </td>
                                                            @if (!IsSelectedSessionClosed)
                                                            {
                                                                <td>
                                                                    @if (TryGetRosterPlayer(player.ToonId, out var rosterPlayer))
                                                                    {
                                                                        <button class="btn btn-outline-light btn-sm" @onclick="() => ToggleSitterAsync(rosterPlayer)" disabled="@busy">
                                                                            @(rosterPlayer.IsSitter ? "Unmark" : "Sit")
                                                                        </button>
                                                                    }
                                                                </td>
                                                            }
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="card border-light">
                                <div class="card-header bgchart2">
                                    <h5 class="text-warning mb-0">Games</h5>
                                </div>
                                <div class="card-body bgchart">
                                    @if (selectedSession.Replays.Count == 0)
                                    {
                                        <div class="text-muted">No games uploaded yet.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="tptable w-auto">
                                                <thead>
                                                    <tr>
                                                        <th>GameTime</th>
                                                        <th>Mode</th>
                                                        <th>Duration</th>
                                                        <th>Team 1</th>
                                                        <th>Team 2</th>
                                                        <th>Exp2Win</th>
                                                        <th>Rating</th>
                                                        <AuthorizeView Policy="CloseSession" Resource="@selectedSession" Context="removeReplayHeaderAuth">
                                                            <th></th>
                                                        </AuthorizeView>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var replay in selectedSession.Replays)
                                                    {
                                                        <tr class="pointer" @onclick="() => ShowReplay(replay.ReplayHash)">
                                                            <td>@replay.Gametime.ToString("yyyy-MM-dd HH:mm")</td>
                                                            <td>@replay.GameMode</td>
                                                            <td>@TimeSpan.FromSeconds(replay.Duration).ToString(@"hh\:mm\:ss")</td>
                                                            <td><ReplayTeamComponent Replay="replay.ToReplayListDto()" TeamNumber="1" /></td>
                                                            <td><ReplayTeamComponent Replay="replay.ToReplayListDto()" TeamNumber="2" /></td>
                                                            <td>@(replay.ExpectedWinProbability?.ToString("P0") ?? "-")</td>
                                                            <td>@(replay.RatingsPending ? "pending" : replay.AvgRating?.ToString("N0"))</td>
                                                            <AuthorizeView Policy="CloseSession" Resource="@selectedSession" Context="removeReplayAuth">
                                                                <td>
                                                                    <button class="btn btn-outline-danger btn-sm"
                                                                            title="Remove replay from session"
                                                                            @onclick:stopPropagation="true"
                                                                            @onclick="() => RemoveReplayAsync(replay)"
                                                                            disabled="@busy">
                                                                        <i class="bi bi-trash"></i>
                                                                    </button>
                                                                </td>
                                                            </AuthorizeView>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="row g-4">
                    <div class="col-xl-7">
                        <div class="card border-light h-100">
                            <div class="card-header bgchart2">
                                <h4 class="text-warning mb-0">Register</h4>
                            </div>
                            <div class="card-body bgchart">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Display name</label>
                                        <input class="form-control" @bind="displayName" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Tracked profile</label>
                                        <select class="form-select" @bind="selectedProfileKey">
                                            <option value="">Manual entry</option>
                                            @foreach (var profile in trackedProfiles)
                                            {
                                                <option value="@GetProfileKey(profile)">@profile.Name (@FormatToonId(profile.ToonId))</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Profile name</label>
                                        <input class="form-control" @bind="manualProfile.Name" disabled="@HasSelectedProfile" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Region</label>
                                        <input type="number" class="form-control" @bind="manualProfile.ToonId.Region" disabled="@HasSelectedProfile" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Realm</label>
                                        <input type="number" class="form-control" @bind="manualProfile.ToonId.Realm" disabled="@HasSelectedProfile" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">ToonId</label>
                                        <input type="number" class="form-control" @bind="manualProfile.ToonId.Id" disabled="@HasSelectedProfile" />
                                    </div>
                                </div>

                                <div class="mt-3 d-flex gap-2">
                                    <button class="btn btn-primary" @onclick="RegisterAsync" disabled="@busy">
                                        <i class="bi bi-person-plus me-2"></i>Register Passkey
                                    </button>
                                    <button class="btn btn-outline-light" @onclick="LoginAsync" disabled="@busy">
                                        <i class="bi bi-key me-2"></i>Login
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-5">
                        <div class="card border-light h-100">
                            <div class="card-header bgchart2">
                                <h4 class="text-warning mb-0">Link This Device</h4>
                            </div>
                            <div class="card-body bgchart">
                                <p class="text-muted">
                                    If your account already exists on another device, create a link code there and enter it here.
                                </p>
                                <label class="form-label">Link code</label>
                                <input class="form-control mb-3" @bind="linkCode" />
                                <button class="btn btn-outline-light" @onclick="LinkDeviceAsync" disabled="@busy">
                                    <i class="bi bi-link-45deg me-2"></i>Add Passkey
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    }

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-info mt-3 mb-0">@statusMessage</div>
    }
</div>

<ReplayModal @ref="replayModal" IsCloseable="true" IsScrollable="true" OnPlayerRequest="e => playerModal?.Show(e)" />
<PlayerModal @ref="playerModal" />

@code {
    private readonly InHouseProfileDto manualProfile = new()
    {
        Name = "Player",
        ToonId = new ToonIdDto { Region = 1, Realm = 1 }
    };
    private const int ClosedSessionsPageSize = 10;
    private readonly List<TrackedProfileDto> trackedProfiles = [];
    private readonly List<InHouseGameSessionListDto> sessions = [];
    private readonly List<InHouseClosedGameSessionListDto> closedSessions = [];
    private readonly List<PlayerRatingListItem> playerSearchResults = [];
    private readonly List<InHouseMatchmakingPlayer> draftTeam1 = [];
    private readonly List<InHouseMatchmakingPlayer> draftTeam2 = [];
    private readonly List<InHouseMatchmakingPlayer> draftBench = [];
    private HubConnection? hubConnection;
    private InHouseMatchmakingSuggestion? matchmakingSuggestion;
    private InHouseGameSessionDetailDto? selectedSession;
    private string displayName = string.Empty;
    private string selectedProfileKey = string.Empty;
    private string linkCode = string.Empty;
    private string newSessionName = string.Empty;
    private string playerSearchName = string.Empty;
    private string manualRosterName = string.Empty;
    private int manualRosterRegion = 1;
    private int manualRosterRealm = 1;
    private int manualRosterToonId;
    private double manualRosterRating = 1000;
    private int? manualRosterPlayerId;
    private bool manualRosterSitter;
    private Guid? draggedRosterPlayerId;
    private string? draggedGroup;
    private string? statusMessage;
    private bool loading = true;
    private bool busy;
    private bool passkeysSupported;
    private int closedSessionsPage = 1;
    private int closedSessionsTotal;
    ReplayModal? replayModal;
    PlayerModal? playerModal;

    private bool HasSelectedProfile => !string.IsNullOrWhiteSpace(selectedProfileKey);
    private bool IsSelectedSessionClosed => selectedSession?.ClosedAt is not null;
    private int ClosedSessionsPageCount => Math.Max(1, (int)Math.Ceiling((double)closedSessionsTotal / ClosedSessionsPageSize));

    protected override async Task OnInitializedAsync()
    {
        passkeysSupported = await Auth.IsPasskeySupportedAsync();
        await Auth.InitializeAsync();
        Auth.AuthenticationChanged += OnAuthenticationChanged;

        trackedProfiles.AddRange(await SessionProgressService.GetTrackedProfilesAsync());
        displayName = trackedProfiles.FirstOrDefault(profile => profile.Active)?.Name ?? string.Empty;

        if (Auth.IsAuthenticated)
        {
            await EnsureHubConnectedAsync();
            await LoadSessionsAsync();
            await LoadClosedSessionsAsync();
        }

        loading = false;
    }

    private void OnAuthenticationChanged()
        => _ = InvokeAsync(UpdateAuthenticationConnectionAsync);

    private async Task UpdateAuthenticationConnectionAsync()
    {
        try
        {
            if (Auth.IsAuthenticated)
            {
                await EnsureHubConnectedAsync();
                await LoadSessionsAsync();
                await LoadClosedSessionsAsync();
            }
            else
            {
                sessions.Clear();
                closedSessions.Clear();
                closedSessionsPage = 1;
                closedSessionsTotal = 0;
                selectedSession = null;
                ResetMatchmakingDraft();
                await DisposeHubAsync();
            }
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }

        StateHasChanged();
    }

    private async Task LoadSessionsAsync()
    {
        await EnsureHubConnectedAsync();
        var activeSessions = await hubConnection!.InvokeAsync<List<InHouseGameSessionListDto>>("GetActiveSessions");
        sessions.Clear();
        sessions.AddRange(activeSessions.DistinctBy(session => session.SessionId));
        if (selectedSession is null && sessions.Count > 0)
        {
            await SelectSessionAsync(sessions[0].SessionId);
        }
    }

    private async Task LoadClosedSessionsAsync()
    {
        var page = await SessionsClient.GetClosedSessionsAsync(closedSessionsPage, ClosedSessionsPageSize);
        closedSessions.Clear();
        closedSessions.AddRange(page.Items.DistinctBy(session => session.SessionId));
        closedSessionsPage = page.Page;
        closedSessionsTotal = page.Total;
        if (closedSessions.Count == 0 && closedSessionsPage > 1)
        {
            closedSessionsPage--;
            await LoadClosedSessionsAsync();
        }
    }

    private async Task CreateSessionAsync()
    {
        await RunAsync(async () =>
        {
            selectedSession = await SessionsClient.CreateSessionAsync(newSessionName);
            ResetMatchmakingDraft();
            newSessionName = string.Empty;
            await LoadSessionsAsync();
            await LoadClosedSessionsAsync();
            await JoinSelectedSessionAsync();
        });
    }

    private async Task SelectSessionAsync(Guid sessionId)
    {
        await RunAsync(async () =>
        {
            if (selectedSession is not null)
            {
                await LeaveSessionGroupAsync(selectedSession.SessionId);
            }

            selectedSession = await JoinSessionAsync(sessionId);
            ResetMatchmakingDraft();
        });
    }

    private async Task SelectClosedSessionAsync(Guid sessionId)
    {
        await RunAsync(async () =>
        {
            if (selectedSession is not null)
            {
                await LeaveSessionGroupAsync(selectedSession.SessionId);
            }

            selectedSession = await SessionsClient.GetSessionAsync(sessionId);
            ResetMatchmakingDraft();
        });
    }

    private async Task RefreshAsync()
    {
        if (selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            selectedSession = IsSelectedSessionClosed
                ? await SessionsClient.GetSessionAsync(selectedSession.SessionId)
                : await JoinSessionAsync(selectedSession.SessionId);
            ResetMatchmakingDraft();
            await LoadSessionsAsync();
            await LoadClosedSessionsAsync();
        });
    }

    private async Task CloseSessionAsync()
    {
        if (selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            await EnsureHubConnectedAsync();
            selectedSession = await hubConnection!.InvokeAsync<InHouseGameSessionDetailDto>("CloseSession", selectedSession.SessionId);
            ApplySessionState(selectedSession);
            await LoadSessionsAsync();
            await LoadClosedSessionsAsync();
        });
    }

    private async Task DeleteSessionAsync()
    {
        if (selectedSession is null)
        {
            return;
        }

        var sessionId = selectedSession.SessionId;
        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Delete this InHouse session? Imported replay records will be kept.");
        if (!confirmed)
        {
            return;
        }

        await RunAsync(async () =>
        {
            await SessionsClient.DeleteSessionAsync(sessionId);
            if (selectedSession?.SessionId == sessionId)
            {
                selectedSession = null;
                ResetMatchmakingDraft();
            }

            await LoadSessionsAsync();
            await LoadClosedSessionsAsync();
        });
    }

    private async Task UploadReplayAsync(InputFileChangeEventArgs args)
    {
        if (selectedSession is null)
        {
            return;
        }

        var file = args.File;
        await RunAsync(async () =>
        {
            await using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var parsedReplay = await DecodeService.DecodeInHouseReplayFromStream(stream, file.Name);
            ApplySessionState(await SessionsClient.UploadReplayAsync(selectedSession.SessionId, parsedReplay));
            await LoadSessionsAsync();
            await LoadClosedSessionsAsync();
            statusMessage = "Replay attached to the session.";
        });
    }

    private async Task RemoveReplayAsync(InHouseGameSessionReplayDto replay)
    {
        if (selectedSession is null)
        {
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>(
            "confirm",
            "Remove this replay from the InHouse session? The imported replay record will be kept.");
        if (!confirmed)
        {
            return;
        }

        await RunAsync(async () =>
        {
            await EnsureHubConnectedAsync();
            ApplySessionState(await hubConnection!.InvokeAsync<InHouseGameSessionDetailDto>(
                "RemoveReplay",
                selectedSession.SessionId,
                replay.ReplayHash));
            await LoadSessionsAsync();
            await LoadClosedSessionsAsync();
            statusMessage = "Replay removed from the session.";
        });
    }

    private async Task PreviousClosedSessionsPageAsync()
    {
        if (closedSessionsPage <= 1)
        {
            return;
        }

        await RunAsync(async () =>
        {
            closedSessionsPage--;
            await LoadClosedSessionsAsync();
        });
    }

    private async Task NextClosedSessionsPageAsync()
    {
        if (closedSessionsPage >= ClosedSessionsPageCount)
        {
            return;
        }

        await RunAsync(async () =>
        {
            closedSessionsPage++;
            await LoadClosedSessionsAsync();
        });
    }

    private async Task RegisterAsync()
    {
        await RunAsync(async () =>
        {
            await Auth.RegisterAsync(displayName, GetSelectedProfile());
            statusMessage = "Passkey registered.";
        });
    }

    private async Task LoginAsync()
    {
        await RunAsync(async () =>
        {
            await Auth.LoginAsync();
            statusMessage = "Signed in.";
        });
    }

    private async Task LinkDeviceAsync()
    {
        await RunAsync(async () =>
        {
            await Auth.LinkDeviceAsync(linkCode);
            statusMessage = "This device now has a passkey for the existing account.";
        });
    }

    private async Task EnsureHubConnectedAsync()
    {
        if (hubConnection is not null)
        {
            return;
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(new Uri(HubOptions.BaseAddress, "hubs/inhouse"), options =>
            {
                options.AccessTokenProvider = Auth.GetAccessTokenAsync;
            })
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On("active_sessions_changed", () =>
        {
            _ = InvokeAsync(async () =>
            {
                await LoadSessionsAsync();
                await LoadClosedSessionsAsync();
                StateHasChanged();
            });
        });

        hubConnection.On<InHouseGameSessionDetailDto>("session_state", detail =>
        {
            _ = InvokeAsync(() =>
            {
                ApplySessionState(detail);
                StateHasChanged();
            });
        });

        hubConnection.On<InHouseSitterChangedDto>("sitter_changed", changed =>
        {
            _ = InvokeAsync(() =>
            {
                ApplySitterChanged(changed);
                StateHasChanged();
            });
        });

        hubConnection.On<Guid>("session_deleted", deletedSessionId =>
        {
            _ = InvokeAsync(() =>
            {
                ApplySessionDeleted(deletedSessionId);
                StateHasChanged();
            });
        });

        await hubConnection.StartAsync();
    }

    private async Task JoinSelectedSessionAsync()
    {
        if (hubConnection is not null && selectedSession is not null)
        {
            selectedSession = await JoinSessionAsync(selectedSession.SessionId);
            ResetMatchmakingDraft();
        }
    }

    private async Task<InHouseGameSessionDetailDto?> JoinSessionAsync(Guid sessionId)
    {
        if (hubConnection is null)
        {
            return null;
        }

        return await hubConnection.InvokeAsync<InHouseGameSessionDetailDto?>("JoinSession", sessionId);
    }

    private async Task LeaveSessionGroupAsync(Guid sessionId)
    {
        if (hubConnection is not null)
        {
            await hubConnection.SendAsync("LeaveSession", sessionId);
        }
    }

    private async Task DisposeHubAsync()
    {
        if (hubConnection is null)
        {
            return;
        }

        await hubConnection.DisposeAsync();
        hubConnection = null;
    }

    private async Task RunAsync(Func<Task> action)
    {
        busy = true;
        statusMessage = null;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private void ApplySessionState(InHouseGameSessionDetailDto? detail)
    {
        if (detail is null)
        {
            return;
        }

        if (selectedSession is not null
            && selectedSession.SessionId != detail.SessionId)
        {
            return;
        }

        if (selectedSession is not null
            && detail.Revision < selectedSession.Revision)
        {
            return;
        }

        selectedSession = detail;
        ResetMatchmakingDraft();
    }

    private void ApplySitterChanged(InHouseSitterChangedDto changed)
    {
        if (selectedSession is null
            || selectedSession.SessionId != changed.SessionId
            || changed.Revision < selectedSession.Revision)
        {
            return;
        }

        var rosterPlayer = selectedSession.RosterPlayers
            .FirstOrDefault(player => player.RosterPlayerId == changed.RosterPlayerId);
        if (rosterPlayer is null)
        {
            return;
        }

        rosterPlayer.IsSitter = changed.IsSitter;
        selectedSession.Revision = changed.Revision;
        ResetMatchmakingDraft();
    }

    private void ApplySessionDeleted(Guid deletedSessionId)
    {
        sessions.RemoveAll(session => session.SessionId == deletedSessionId);
        closedSessions.RemoveAll(session => session.SessionId == deletedSessionId);
        if (selectedSession?.SessionId == deletedSessionId)
        {
            selectedSession = null;
            ResetMatchmakingDraft();
        }
    }

    private InHouseProfileDto GetSelectedProfile()
    {
        var selectedProfile = trackedProfiles.FirstOrDefault(profile => GetProfileKey(profile) == selectedProfileKey);
        if (selectedProfile is null)
        {
            return new InHouseProfileDto
            {
                Name = manualProfile.Name,
                Active = true,
                ToonId = CloneToonId(manualProfile.ToonId),
            };
        }

        return new InHouseProfileDto
        {
            Name = selectedProfile.Name,
            Active = true,
            ToonId = CloneToonId(selectedProfile.ToonId),
        };
    }

    private static string FormatRating(double? rating)
        => rating?.ToString("N0") ?? "-";

    private static string FormatGain(double? gain)
        => gain?.ToString("+#0.##;-#0.##;0") ?? "-";

    private static string GetGainClass(double? gain)
        => gain is null ? string.Empty : gain < 0 ? "text-danger" : "text-success";

    private static string GetProfileKey(TrackedProfileDto profile)
        => $"{profile.ToonId.Region}:{profile.ToonId.Realm}:{profile.ToonId.Id}";

    private static ToonIdDto CloneToonId(ToonIdDto toonId)
        => new()
        {
            Region = toonId.Region,
            Realm = toonId.Realm,
            Id = toonId.Id,
        };

    private static string FormatToonId(ToonIdDto toonId)
        => $"{toonId.Region}/{toonId.Realm}/{toonId.Id}";

    private void ResetMatchmakingDraft()
    {
        draftTeam1.Clear();
        draftTeam2.Clear();
        draftBench.Clear();

        if (selectedSession is null)
        {
            matchmakingSuggestion = null;
            return;
        }

        if (selectedSession.ClosedAt is not null)
        {
            matchmakingSuggestion = null;
            return;
        }

        matchmakingSuggestion = InHouseMatchmaker.CreateSuggestion(selectedSession);
        draftTeam1.AddRange(matchmakingSuggestion.Team1);
        draftTeam2.AddRange(matchmakingSuggestion.Team2);
        draftBench.AddRange(matchmakingSuggestion.Bench);
    }

    private InHouseMatchmakingScores GetDraftScores()
        => selectedSession is null
            ? new()
            : InHouseMatchmaker.ScoreDraft(
                selectedSession,
                draftTeam1.Select(player => player.RosterPlayerId).ToList(),
                draftTeam2.Select(player => player.RosterPlayerId).ToList());

    private async Task SearchRosterPlayersAsync()
    {
        playerSearchResults.Clear();
        if (string.IsNullOrWhiteSpace(playerSearchName))
        {
            return;
        }

        await RunAsync(async () =>
        {
            var ratings = await PlayerService.GetRatings(new PlayerRatingsRequest
            {
                Name = playerSearchName.Trim(),
                RatingType = RatingType.All,
                Page = 1,
                PageSize = 20,
                Take = 8,
            });
            playerSearchResults.AddRange(ratings);
        });
    }

    private void SelectRosterSearchResult(PlayerRatingListItem rating)
    {
        var toonId = Data.GetToonId(rating.ToonIdString);
        if (toonId is null)
        {
            return;
        }

        manualRosterName = rating.Name;
        manualRosterRegion = toonId.Region;
        manualRosterRealm = toonId.Realm;
        manualRosterToonId = toonId.Id;
        manualRosterRating = rating.Rating;
        manualRosterPlayerId = rating.PlayerId;
    }

    private async Task AddRosterPlayerAsync()
    {
        if (selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            await EnsureHubConnectedAsync();
            ApplySessionState(await hubConnection!.InvokeAsync<InHouseGameSessionDetailDto>(
                "AddOrUpdateRosterPlayer",
                selectedSession.SessionId,
                new InHouseRosterPlayerUpsertRequest
                {
                    Name = manualRosterName,
                    ToonId = new ToonIdDto
                    {
                        Region = manualRosterRegion,
                        Realm = manualRosterRealm,
                        Id = manualRosterToonId,
                    },
                    PlayerId = manualRosterPlayerId,
                    InitialRating = manualRosterRating <= 0 ? 1000 : manualRosterRating,
                    IsSitter = manualRosterSitter,
                }));
            playerSearchResults.Clear();
            statusMessage = "Roster player saved.";
        });
    }

    private async Task ToggleSitterAsync(InHouseRosterPlayerDto rosterPlayer)
    {
        if (selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            await EnsureHubConnectedAsync();
            var changed = await hubConnection!.InvokeAsync<InHouseSitterChangedDto>(
                "SetRosterPlayerSitter",
                selectedSession.SessionId,
                rosterPlayer.RosterPlayerId,
                !rosterPlayer.IsSitter);
            ApplySitterChanged(changed);
        });
    }

    private async Task RemoveRosterPlayerAsync(InHouseRosterPlayerDto rosterPlayer)
    {
        if (selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            await EnsureHubConnectedAsync();
            ApplySessionState(await hubConnection!.InvokeAsync<InHouseGameSessionDetailDto>(
                "RemoveRosterPlayer",
                selectedSession.SessionId,
                rosterPlayer.RosterPlayerId));
            statusMessage = "Roster player removed.";
        });
    }

    private void MoveDraftPlayer(InHouseMatchmakingPlayer player, string target)
    {
        var source = RemoveDraftPlayer(player.RosterPlayerId);
        if (source is null)
        {
            return;
        }

        AddDraftPlayer(player, target, source);
    }

    private void StartDraftDrag(InHouseMatchmakingPlayer player, string group)
    {
        if (group == "sitters")
        {
            draggedRosterPlayerId = null;
            draggedGroup = null;
            return;
        }

        draggedRosterPlayerId = player.RosterPlayerId;
        draggedGroup = group;
    }

    private void DropDraftOnGroup(string target)
    {
        if (draggedRosterPlayerId is null || draggedGroup is null || target == "sitters")
        {
            ClearDraftDrag();
            return;
        }

        var player = FindDraftPlayer(draggedRosterPlayerId.Value);
        if (player is null)
        {
            ClearDraftDrag();
            return;
        }

        if (target == "bench" || GetDraftGroup(target).Count < 3)
        {
            MoveDraftPlayer(player, target);
        }

        ClearDraftDrag();
    }

    private void DropDraftOnPlayer(InHouseMatchmakingPlayer targetPlayer, string targetGroup)
    {
        if (draggedRosterPlayerId is null
            || draggedGroup is null
            || draggedRosterPlayerId == targetPlayer.RosterPlayerId
            || targetGroup == "sitters")
        {
            ClearDraftDrag();
            return;
        }

        var draggedPlayer = FindDraftPlayer(draggedRosterPlayerId.Value);
        if (draggedPlayer is null)
        {
            ClearDraftDrag();
            return;
        }

        if (IsTeamGroup(draggedGroup) && IsTeamGroup(targetGroup))
        {
            SwapDraftPlayers(draggedPlayer.RosterPlayerId, targetPlayer.RosterPlayerId);
        }
        else
        {
            MoveDraftPlayer(draggedPlayer, targetGroup);
        }

        ClearDraftDrag();
    }

    private void ClearDraftDrag()
    {
        draggedRosterPlayerId = null;
        draggedGroup = null;
    }

    private string? RemoveDraftPlayer(Guid rosterPlayerId)
    {
        if (RemoveFrom(draftTeam1, rosterPlayerId)) return "team1";
        if (RemoveFrom(draftTeam2, rosterPlayerId)) return "team2";
        if (RemoveFrom(draftBench, rosterPlayerId)) return "bench";
        return null;
    }

    private void AddDraftPlayer(InHouseMatchmakingPlayer player, string target, string source)
    {
        var targetList = target switch
        {
            "team1" => draftTeam1,
            "team2" => draftTeam2,
            _ => draftBench,
        };

        if (target is "team1" or "team2" && targetList.Count >= 3)
        {
            var displaced = targetList[^1];
            targetList.RemoveAt(targetList.Count - 1);
            if (source == "team1")
            {
                draftTeam1.Add(displaced);
            }
            else if (source == "team2")
            {
                draftTeam2.Add(displaced);
            }
            else
            {
                draftBench.Add(displaced);
            }
        }

        targetList.Add(player);
    }

    private InHouseMatchmakingPlayer? FindDraftPlayer(Guid rosterPlayerId)
        => draftTeam1.Concat(draftTeam2).Concat(draftBench)
            .FirstOrDefault(player => player.RosterPlayerId == rosterPlayerId);

    private List<InHouseMatchmakingPlayer> GetDraftGroup(string group)
        => group switch
        {
            "team1" => draftTeam1,
            "team2" => draftTeam2,
            _ => draftBench,
        };

    private static bool IsTeamGroup(string group)
        => group is "team1" or "team2";

    private void SwapDraftPlayers(Guid firstId, Guid secondId)
    {
        var firstLocation = FindDraftLocation(firstId);
        var secondLocation = FindDraftLocation(secondId);
        if (firstLocation is null || secondLocation is null)
        {
            return;
        }

        (firstLocation.Value.List[firstLocation.Value.Index], secondLocation.Value.List[secondLocation.Value.Index]) =
            (secondLocation.Value.List[secondLocation.Value.Index], firstLocation.Value.List[firstLocation.Value.Index]);
    }

    private (List<InHouseMatchmakingPlayer> List, int Index)? FindDraftLocation(Guid rosterPlayerId)
    {
        var team1Index = draftTeam1.FindIndex(player => player.RosterPlayerId == rosterPlayerId);
        if (team1Index >= 0) return (draftTeam1, team1Index);

        var team2Index = draftTeam2.FindIndex(player => player.RosterPlayerId == rosterPlayerId);
        if (team2Index >= 0) return (draftTeam2, team2Index);

        var benchIndex = draftBench.FindIndex(player => player.RosterPlayerId == rosterPlayerId);
        if (benchIndex >= 0) return (draftBench, benchIndex);

        return null;
    }

    private static bool RemoveFrom(List<InHouseMatchmakingPlayer> players, Guid rosterPlayerId)
    {
        var index = players.FindIndex(player => player.RosterPlayerId == rosterPlayerId);
        if (index < 0)
        {
            return false;
        }

        players.RemoveAt(index);
        return true;
    }

    private bool TryGetRosterPlayer(ToonIdDto toonId, out InHouseRosterPlayerDto rosterPlayer)
    {
        var match = selectedSession?.RosterPlayers.FirstOrDefault(player =>
            player.ToonId.Region == toonId.Region
            && player.ToonId.Realm == toonId.Realm
            && player.ToonId.Id == toonId.Id);
        rosterPlayer = match ?? new();
        return match is not null;
    }

    private RenderFragment RenderTeam(string title, IReadOnlyList<InHouseMatchmakingPlayer> players, string group) => @<div class="border border-secondary rounded p-2 h-100"
                                                                                                                            @ondrop="() => DropDraftOnGroup(group)"
                                                                                                                            @ondragover:preventDefault="true">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="fw-semibold text-warning">@title</span>
            <span class="badge text-bg-dark">@players.Count</span>
        </div>
        @if (players.Count == 0)
        {
            <div class="small text-muted">Empty</div>
        }
        @foreach (var player in players)
        {
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 border-top border-secondary py-2"
                 draggable="@(group != "sitters" ? "true" : "false")"
                 style="@(group != "sitters" ? "cursor: grab;" : null)"
                 @ondragstart="() => StartDraftDrag(player, group)"
                 @ondragend="ClearDraftDrag"
                 @ondrop:stopPropagation="true"
                 @ondrop="() => DropDraftOnPlayer(player, group)"
                 @ondragover:preventDefault="true">
                <div>
                    <div class="fw-semibold">@player.Name</div>
                    <div class="small text-muted">
                        @player.InitialRating.ToString("N0") · G @player.Games · Obs @player.Observes · Debt @player.PlayDebt
                    </div>
                    <div class="d-flex gap-1 mt-1">
                        @if (player.IsNewManual)
                        {
                            <span class="badge text-bg-info">New</span>
                        }
                        @if (player.ObservedLatestGame)
                        {
                            <span class="badge text-bg-warning">Observed</span>
                        }
                        @if (player.PlayedLatestGame)
                        {
                            <span class="badge text-bg-success">Played</span>
                        }
                    </div>
                </div>
                <div class="btn-group btn-group-sm">
                    @if (group != "team1" && group != "sitters")
                    {
                        <button class="btn btn-outline-light" title="Move to Team 1" @onclick='() => MoveDraftPlayer(player, "team1")'>T1</button>
                    }
                    @if (group != "team2" && group != "sitters")
                    {
                        <button class="btn btn-outline-light" title="Move to Team 2" @onclick='() => MoveDraftPlayer(player, "team2")'>T2</button>
                    }
                    @if (group != "bench" && group != "sitters")
                    {
                        <button class="btn btn-outline-light" title="Move to Bench" @onclick='() => MoveDraftPlayer(player, "bench")'>Bench</button>
                    }
                    @if (TryGetRosterPlayer(player.ToonId, out var rosterPlayer))
                    {
                        <button class="btn btn-outline-warning" title="Toggle sitter" @onclick="() => ToggleSitterAsync(rosterPlayer)" disabled="@busy">
                            @(rosterPlayer.IsSitter ? "Play" : "Sit")
                        </button>
                        <button class="btn btn-outline-danger" title="Remove from roster" @onclick="() => RemoveRosterPlayerAsync(rosterPlayer)" disabled="@busy">
                            <i class="bi bi-trash"></i>
                        </button>
                    }
                </div>
            </div>
        }
        @if (IsTeamGroup(group) && players.Count < 3)
        {
            @for (var i = players.Count; i < 3; i++)
            {
                <div class="border border-secondary rounded text-muted small text-center py-2 mt-2"
                     @ondrop="() => DropDraftOnGroup(group)"
                     @ondragover:preventDefault="true">
                    Empty seat
                </div>
            }
        }
    </div>;

    public async ValueTask DisposeAsync()
    {
        Auth.AuthenticationChanged -= OnAuthenticationChanged;
        await DisposeHubAsync();
    }

    private async Task ShowReplay(string replayHash)
    {
        var replayDetails = await SessionsClient.GetReplayDetails(replayHash);
        if (replayDetails == null)
        {
            return;
        }
        replayModal?.Show(replayDetails);
    }

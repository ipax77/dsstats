@page "/inhouse"
@using dsstats.indexedDb.Services
@using dsstats.pwa.Services
@using dsstats.shared
@using dsstats.shared.InHouse
@using dsstats.shared.Interfaces
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.SignalR.Client
@using dsstats.weblib.Players
@using dsstats.weblib.Replays
@implements IAsyncDisposable
@inject InHouseAuthClient Auth
@inject InHouseGameSessionsClient SessionsClient
@inject DecodeService DecodeService
@inject SessionProgressService SessionProgressService

<PageTitle>mydsstats - InHouse</PageTitle>

<div class="container-fluid py-4">
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-3">
        <div>
            <h2 class="fw-bold mb-1">InHouse Sessions</h2>
            <div class="text-muted">Private Direct Strike runs, shared by signed-in players.</div>
        </div>
        <AuthorizeView>
            <Authorized>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    <input class="form-control" style="max-width: 18rem;" placeholder="Session name" @bind="newSessionName" />
                    <button class="btn btn-primary" @onclick="CreateSessionAsync" disabled="@busy">
                        <i class="bi bi-plus-lg me-1"></i>Create
                    </button>
                </div>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-warning" role="status"></div>
        </div>
    }
    else if (!passkeysSupported)
    {
        <div class="alert alert-warning">
            Passkeys are not available in this browser context. Use HTTPS or localhost with a browser that supports WebAuthn.
        </div>
    }
    else
    {
        <AuthorizeView>
            <Authorized>
                <div class="row g-3 align-items-start">
                    <div class="col-xl-3 col-lg-4">
                        <div class="card border-light">
                            <div class="card-header bgchart2">
                                <h5 class="text-warning mb-0">Active Sessions</h5>
                            </div>
                            <div class="list-group list-group-flush">
                                @if (sessions.Count == 0)
                                {
                                    <div class="list-group-item bgchart text-muted">No active sessions yet.</div>
                                }
                                @foreach (var session in sessions)
                                {
                                    <button type="button"
                                            class="list-group-item list-group-item-action bgchart @(selectedSession?.SessionId == session.SessionId ? "active" : "")"
                                            @onclick="() => SelectSessionAsync(session.SessionId)">
                                        <div class="d-flex justify-content-between gap-2">
                                            <span class="fw-semibold">@session.Name</span>
                                            <span class="badge text-bg-secondary">@session.Games</span>
                                        </div>
                                        <div class="small text-muted">@session.CreatedByDisplayName · @session.CreatedAt.ToLocalTime().ToString("g")</div>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-9 col-lg-8">
                        @if (selectedSession is null)
                        {
                            <div class="alert alert-secondary mb-0">Select or create a session.</div>
                        }
                        else
                        {
                            <div class="card border-light mb-3">
                                <div class="card-header bgchart2 d-flex flex-wrap align-items-center justify-content-between gap-2">
                                    <div>
                                        <h4 class="text-warning mb-0">@selectedSession.Name</h4>
                                        <div class="small text-muted">
                                            Created by @selectedSession.CreatedByDisplayName · @selectedSession.CreatedAt.ToLocalTime().ToString("g")
                                        </div>
                                    </div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <button class="btn btn-outline-light btn-sm" @onclick="RefreshAsync" disabled="@busy">
                                            <i class="bi bi-arrow-clockwise me-1"></i>Refresh
                                        </button>
                                        @if (selectedSession.CanClose)
                                        {
                                            <button class="btn btn-outline-danger btn-sm" @onclick="CloseSessionAsync" disabled="@busy">
                                                <i class="bi bi-lock me-1"></i>Close
                                            </button>
                                        }
                                    </div>
                                </div>
                                <div class="card-body bgchart">
                                    @if (selectedSession.ClosedAt is not null)
                                    {
                                        <div class="alert alert-secondary mb-3">This session is closed.</div>
                                    }
                                    else
                                    {
                                        <label class="form-label">Upload replay</label>
                                        <InputFile class="form-control" OnChange="UploadReplayAsync" accept=".SC2Replay" disabled="@busy" />
                                        <div class="small text-muted mt-2">Decoded locally, then attached to this session with observer metadata.</div>
                                    }
                                </div>
                            </div>

                            <div class="card border-light mb-3">
                                <div class="card-header bgchart2">
                                    <h5 class="text-warning mb-0">Player Summary</h5>
                                </div>
                                <div class="card-body bgchart">
                                    @if (selectedSession.Players.Count == 0)
                                    {
                                        <div class="text-muted">No players yet.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="tptable w-auto">
                                                <thead>
                                                    <tr>
                                                        <th>Name</th>
                                                        <th>Games</th>
                                                        <th>Obs</th>
                                                        <th>Winrate</th>
                                                        <th>Start</th>
                                                        <th>End</th>
                                                        <th>Gain</th>
                                                        <th>Avg</th>
                                                        <th>Latest</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var player in selectedSession.Players)
                                                    {
                                                        <tr>
                                                            <td>@player.Name</td>
                                                            <td>@player.Games</td>
                                                            <td>@player.Observes</td>
                                                            <td>@player.Winrate.ToString("P0")</td>
                                                            <td>@FormatRating(player.RatingStart)</td>
                                                            <td>@FormatRating(player.RatingEnd)</td>
                                                            <td class="@GetGainClass(player.RatingDelta)">@FormatGain(player.RatingDelta)</td>
                                                            <td class="@GetGainClass(player.AverageGain)">@FormatGain(player.AverageGain)</td>
                                                            <td>
                                                                @if (player.PlayedLatestGame)
                                                                {
                                                                    <span class="badge text-bg-success">Played</span>
                                                                }
                                                                else if (player.ObservedLatestGame)
                                                                {
                                                                    <span class="badge text-bg-warning">Observed</span>
                                                                }
                                                                else if (player.RatingsPending)
                                                                {
                                                                    <span class="badge text-bg-secondary">Rating pending</span>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="card border-light">
                                <div class="card-header bgchart2">
                                    <h5 class="text-warning mb-0">Games</h5>
                                </div>
                                <div class="card-body bgchart">
                                    @if (selectedSession.Replays.Count == 0)
                                    {
                                        <div class="text-muted">No games uploaded yet.</div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="tptable w-auto">
                                                <thead>
                                                    <tr>
                                                        <th>GameTime</th>
                                                        <th>Mode</th>
                                                        <th>Duration</th>
                                                        <th>Team 1</th>
                                                        <th>Team 2</th>
                                                        <th>Exp2Win</th>
                                                        <th>Rating</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var replay in selectedSession.Replays)
                                                    {
                                                        <tr class="pointer" @onclick="() => ShowReplay(replay.ReplayHash)">
                                                            <td>@replay.Gametime.ToString("yyyy-MM-dd hh:mm")</td>
                                                            <td>@replay.GameMode</td>
                                                            <td>@TimeSpan.FromSeconds(replay.Duration).ToString(@"hh\:mm\:ss")</td>
                                                            <td><ReplayTeamComponent Replay="replay.ToReplayListDto()" TeamNumber="1" /></td>
                                                            <td><ReplayTeamComponent Replay="replay.ToReplayListDto()" TeamNumber="2" /></td>
                                                            <td>@(replay.ExpectedWinProbability?.ToString("P0") ?? "-")</td>
                                                            <td>@(replay.RatingsPending ? "pending" : replay.AvgRating?.ToString("N0"))</td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="row g-4">
                    <div class="col-xl-7">
                        <div class="card border-light h-100">
                            <div class="card-header bgchart2">
                                <h4 class="text-warning mb-0">Register</h4>
                            </div>
                            <div class="card-body bgchart">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Display name</label>
                                        <input class="form-control" @bind="displayName" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Tracked profile</label>
                                        <select class="form-select" @bind="selectedProfileKey">
                                            <option value="">Manual entry</option>
                                            @foreach (var profile in trackedProfiles)
                                            {
                                                <option value="@GetProfileKey(profile)">@profile.Name (@FormatToonId(profile.ToonId))</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">Profile name</label>
                                        <input class="form-control" @bind="manualProfile.Name" disabled="@HasSelectedProfile" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Region</label>
                                        <input type="number" class="form-control" @bind="manualProfile.ToonId.Region" disabled="@HasSelectedProfile" />
                                    </div>
                                    <div class="col-md-2">
                                        <label class="form-label">Realm</label>
                                        <input type="number" class="form-control" @bind="manualProfile.ToonId.Realm" disabled="@HasSelectedProfile" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">ToonId</label>
                                        <input type="number" class="form-control" @bind="manualProfile.ToonId.Id" disabled="@HasSelectedProfile" />
                                    </div>
                                </div>

                                <div class="mt-3 d-flex gap-2">
                                    <button class="btn btn-primary" @onclick="RegisterAsync" disabled="@busy">
                                        <i class="bi bi-person-plus me-2"></i>Register Passkey
                                    </button>
                                    <button class="btn btn-outline-light" @onclick="LoginAsync" disabled="@busy">
                                        <i class="bi bi-key me-2"></i>Login
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl-5">
                        <div class="card border-light h-100">
                            <div class="card-header bgchart2">
                                <h4 class="text-warning mb-0">Link This Device</h4>
                            </div>
                            <div class="card-body bgchart">
                                <p class="text-muted">
                                    If your account already exists on another device, create a link code there and enter it here.
                                </p>
                                <label class="form-label">Link code</label>
                                <input class="form-control mb-3" @bind="linkCode" />
                                <button class="btn btn-outline-light" @onclick="LinkDeviceAsync" disabled="@busy">
                                    <i class="bi bi-link-45deg me-2"></i>Add Passkey
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    }

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert alert-info mt-3 mb-0">@statusMessage</div>
    }
</div>

<ReplayModal @ref="replayModal" IsCloseable="true" IsScrollable="true" OnPlayerRequest="e => playerModal?.Show(e)" />
<PlayerModal @ref="playerModal" />

@code {
    private readonly InHouseProfileDto manualProfile = new()
    {
        Name = "Player",
        ToonId = new ToonIdDto { Region = 1, Realm = 1 }
    };
    private readonly List<TrackedProfileDto> trackedProfiles = [];
    private readonly List<InHouseGameSessionListDto> sessions = [];
    private HubConnection? hubConnection;
    private InHouseGameSessionDetailDto? selectedSession;
    private string displayName = string.Empty;
    private string selectedProfileKey = string.Empty;
    private string linkCode = string.Empty;
    private string newSessionName = string.Empty;
    private string? statusMessage;
    private bool loading = true;
    private bool busy;
    private bool passkeysSupported;
    ReplayModal? replayModal;
    PlayerModal? playerModal;

    private bool HasSelectedProfile => !string.IsNullOrWhiteSpace(selectedProfileKey);

    protected override async Task OnInitializedAsync()
    {
        passkeysSupported = await Auth.IsPasskeySupportedAsync();
        await Auth.InitializeAsync();
        Auth.AuthenticationChanged += OnAuthenticationChanged;

        trackedProfiles.AddRange(await SessionProgressService.GetTrackedProfilesAsync());
        displayName = trackedProfiles.FirstOrDefault(profile => profile.Active)?.Name ?? string.Empty;

        if (Auth.IsAuthenticated)
        {
            await EnsureHubConnectedAsync();
            await LoadSessionsAsync();
        }

        loading = false;
    }

    private void OnAuthenticationChanged()
        => _ = InvokeAsync(UpdateAuthenticationConnectionAsync);

    private async Task UpdateAuthenticationConnectionAsync()
    {
        try
        {
            if (Auth.IsAuthenticated)
            {
                await EnsureHubConnectedAsync();
                await LoadSessionsAsync();
            }
            else
            {
                sessions.Clear();
                selectedSession = null;
                await DisposeHubAsync();
            }
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }

        StateHasChanged();
    }

    private async Task LoadSessionsAsync()
    {
        var activeSessions = await SessionsClient.GetActiveSessionsAsync();
        sessions.Clear();
        sessions.AddRange(activeSessions.DistinctBy(session => session.SessionId));
        if (selectedSession is null && sessions.Count > 0)
        {
            await SelectSessionAsync(sessions[0].SessionId);
        }
    }

    private async Task CreateSessionAsync()
    {
        await RunAsync(async () =>
        {
            selectedSession = await SessionsClient.CreateSessionAsync(newSessionName);
            newSessionName = string.Empty;
            await LoadSessionsAsync();
            await JoinSelectedSessionAsync();
        });
    }

    private async Task SelectSessionAsync(Guid sessionId)
    {
        await RunAsync(async () =>
        {
            if (selectedSession is not null)
            {
                await LeaveSessionGroupAsync(selectedSession.SessionId);
            }

            selectedSession = await SessionsClient.GetSessionAsync(sessionId);
            await JoinSelectedSessionAsync();
        });
    }

    private async Task RefreshAsync()
    {
        if (selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            selectedSession = await SessionsClient.GetSessionAsync(selectedSession.SessionId);
            await LoadSessionsAsync();
        });
    }

    private async Task CloseSessionAsync()
    {
        if (selectedSession is null)
        {
            return;
        }

        await RunAsync(async () =>
        {
            selectedSession = await SessionsClient.CloseSessionAsync(selectedSession.SessionId);
            await LoadSessionsAsync();
        });
    }

    private async Task UploadReplayAsync(InputFileChangeEventArgs args)
    {
        if (selectedSession is null)
        {
            return;
        }

        var file = args.File;
        await RunAsync(async () =>
        {
            await using var stream = file.OpenReadStream(5 * 1024 * 1024);
            var parsedReplay = await DecodeService.DecodeInHouseReplayFromStream(stream, file.Name);
            selectedSession = await SessionsClient.UploadReplayAsync(selectedSession.SessionId, parsedReplay);
            await LoadSessionsAsync();
            statusMessage = "Replay attached to the session.";
        });
    }

    private async Task RegisterAsync()
    {
        await RunAsync(async () =>
        {
            await Auth.RegisterAsync(displayName, GetSelectedProfile());
            statusMessage = "Passkey registered.";
        });
    }

    private async Task LoginAsync()
    {
        await RunAsync(async () =>
        {
            await Auth.LoginAsync();
            statusMessage = "Signed in.";
        });
    }

    private async Task LinkDeviceAsync()
    {
        await RunAsync(async () =>
        {
            await Auth.LinkDeviceAsync(linkCode);
            statusMessage = "This device now has a passkey for the existing account.";
        });
    }

    private async Task EnsureHubConnectedAsync()
    {
        if (hubConnection is not null)
        {
            return;
        }

        hubConnection = new HubConnectionBuilder()
            .WithUrl(new Uri(Auth.ApiBaseAddress, "hubs/inhouse"), options =>
            {
                options.AccessTokenProvider = Auth.GetAccessTokenAsync;
            })
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<Guid>("session_changed", sessionId =>
        {
            _ = InvokeAsync(async () =>
            {
                await LoadSessionsAsync();
                if (selectedSession?.SessionId == sessionId)
                {
                    selectedSession = await SessionsClient.GetSessionAsync(sessionId);
                }
                StateHasChanged();
            });
        });

        hubConnection.On<InHouseGameSessionDetailDto>("replay_added", detail =>
        {
            _ = InvokeAsync(async () =>
            {
                if (selectedSession?.SessionId == detail.SessionId)
                {
                    selectedSession = detail;
                }
                await LoadSessionsAsync();
                StateHasChanged();
            });
        });

        await hubConnection.StartAsync();
    }

    private async Task JoinSelectedSessionAsync()
    {
        if (hubConnection is not null && selectedSession is not null)
        {
            await hubConnection.SendAsync("JoinSession", selectedSession.SessionId);
        }
    }

    private async Task LeaveSessionGroupAsync(Guid sessionId)
    {
        if (hubConnection is not null)
        {
            await hubConnection.SendAsync("LeaveSession", sessionId);
        }
    }

    private async Task DisposeHubAsync()
    {
        if (hubConnection is null)
        {
            return;
        }

        await hubConnection.DisposeAsync();
        hubConnection = null;
    }

    private async Task RunAsync(Func<Task> action)
    {
        busy = true;
        statusMessage = null;
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            statusMessage = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private InHouseProfileDto GetSelectedProfile()
    {
        var selectedProfile = trackedProfiles.FirstOrDefault(profile => GetProfileKey(profile) == selectedProfileKey);
        if (selectedProfile is null)
        {
            return new InHouseProfileDto
            {
                Name = manualProfile.Name,
                Active = true,
                ToonId = CloneToonId(manualProfile.ToonId),
            };
        }

        return new InHouseProfileDto
        {
            Name = selectedProfile.Name,
            Active = true,
            ToonId = CloneToonId(selectedProfile.ToonId),
        };
    }

    private static string FormatRating(double? rating)
        => rating?.ToString("N0") ?? "-";

    private static string FormatGain(double? gain)
        => gain?.ToString("+#0.##;-#0.##;0") ?? "-";

    private static string GetGainClass(double? gain)
        => gain is null ? string.Empty : gain < 0 ? "text-danger" : "text-success";

    private static string GetProfileKey(TrackedProfileDto profile)
        => $"{profile.ToonId.Region}:{profile.ToonId.Realm}:{profile.ToonId.Id}";

    private static ToonIdDto CloneToonId(ToonIdDto toonId)
        => new()
        {
            Region = toonId.Region,
            Realm = toonId.Realm,
            Id = toonId.Id,
        };

    private static string FormatToonId(ToonIdDto toonId)
        => $"{toonId.Region}/{toonId.Realm}/{toonId.Id}";

    public async ValueTask DisposeAsync()
    {
        Auth.AuthenticationChanged -= OnAuthenticationChanged;
        await DisposeHubAsync();
    }

    private async Task ShowReplay(string replayHash)
    {
        var replayDetails = await SessionsClient.GetReplayDetails(replayHash);
        if (replayDetails == null)
        {
            return;
        }
        replayModal?.Show(replayDetails);
    }
}

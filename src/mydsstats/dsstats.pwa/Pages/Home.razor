@page "/"
@using dsstats.indexedDb.Services
@using dsstats.pwa.Services
@using dsstats.shared
@inject DecodeService DecodeService
@inject IndexedDbService DbService
@inject RatingService RatingService
@inject PwaConfigService PwaConfigService
@implements IDisposable

<PageTitle>mydsstats</PageTitle>

@if (latestReplayDetails is not null)
{
    <div class="container py-4 bgchart rounded mb-3">
        <div class="row align-items-center g-3">
            <div class="col-lg-8">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                    <span class="badge text-bg-success">Ready To Decode</span>
                    <span class="badge text-bg-light">Folder-first workflow</span>
                </div>
                <h1 class="display-5 fw-bold mb-2">Direct Strike Replay Decoder</h1>
                <p class="text-muted mb-3">
                    Your replay library is set up locally in the browser. Add folders once, decode the newest replays in small batches,
                    and keep the latest match ready for review.
                </p>
                <ul class="list-unstyled mb-0 d-flex flex-wrap gap-3">
                    <li><i class="bi bi-lightning-charge-fill text-primary me-1"></i>Fast browser decoding</li>
                    <li><i class="bi bi-hdd-fill text-primary me-1"></i>Local IndexedDB storage</li>
                    <li><i class="bi bi-folder2-open text-primary me-1"></i>Saved replay folders</li>
                </ul>
            </div>
            <div class="col-lg-4 text-lg-end">
                <a href="/decode" class="btn btn-primary btn-lg px-4">
                    <i class="bi bi-folder-symlink me-2"></i>Manage Decode Folders
                </a>
            </div>
        </div>
    </div>

    <div class="mb-5">
        <h3 class="p-2 rounded bgchart d-inline text-warning">Latest Replay</h3>
        <div class="mt-2">
            <dsstats.weblib.Replays.ReplayComponent @ref="replayComponent" ReplayDetails="latestReplayDetails"
                                                    OnRatingUpdateRequest="UpdateRatings" />
        </div>
    </div>
}
else
{
    <div class="container py-5 bgchart rounded">
        <div class="row align-items-center g-4">
            <div class="col-lg-7 text-center text-lg-start">
                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-lg-start mb-3">
                    <span class="badge text-bg-light">Browser-only</span>
                    <span class="badge text-bg-light">Saved folders</span>
                    <span class="badge text-bg-light">Default top 100</span>
                </div>
                <h1 class="display-4 fw-bold mb-3">Direct Strike Replay Decoder</h1>
                <p class="lead text-muted mb-4">
                    Decode your <strong>StarCraft II: Direct Strike</strong> replays directly in your browser.
                    The main workflow is simple: save your replay folder once, then decode the newest replays whenever you want.
                    Everything stays in your device's <strong>IndexedDB</strong> for quick local access.
                </p>
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="fw-semibold mb-1">1. Add Folder</div>
                            <div class="small text-muted">Grant access to your Direct Strike replay directory once.</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="fw-semibold mb-1">2. Pick A Batch</div>
                            <div class="small text-muted">Decode 1, 10, 100, or all new replays. Default is 100.</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="fw-semibold mb-1">3. Review Locally</div>
                            <div class="small text-muted">Inspect decoded matches from IndexedDB and optionally upload later.</div>
                        </div>
                    </div>
                </div>
                <div class="d-flex flex-wrap gap-2 justify-content-center justify-content-lg-start">
                    <a href="/decode" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-folder-symlink me-2"></i>Add Replay Folder
                    </a>
                    <a href="/replays" class="btn btn-outline-light btn-lg px-4">
                        <i class="bi bi-collection-play me-2"></i>Browse Replays
                    </a>
                </div>
            </div>
            <div class="col-lg-5 text-center">
                <img src="images/replay.jpg" alt="Replay decoding illustration" class="img-fluid rounded shadow-sm mb-3" />
                <div class="small text-muted">
                    Works best when you save a replay folder first, then decode the newest matches in repeatable runs.
                </div>
            </div>
        </div>
    </div>
}

            @if (showUploadPrompt)
            {
                <div class="modal d-block" tabindex="-1" style="background:rgba(0,0,0,0.6)">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h5 class="modal-title"><i class="bi bi-cloud-upload me-2"></i>Upload Anonymously?</h5>
                            </div>
                            <div class="modal-body">
                                <p>Your replays can be uploaded anonymously to contribute to shared statistics. No personal data is
                                    linked to your account.</p>
                                    <p class="mb-0">Would you like to enable anonymous uploads?</p>
                                </div>
                                <div class="modal-footer">
                                    <button class="btn btn-secondary" @onclick="DeclineUpload">Not Now</button>
                                    <button class="btn btn-primary" @onclick="AcceptUpload">
                                        <i class="bi bi-check2 me-1"></i>Enable &amp; Upload
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

@code {
    private ReplayDetails? latestReplayDetails;
    private dsstats.weblib.Replays.ReplayComponent? replayComponent;
    private bool showUploadPrompt;

    protected override void OnInitialized()
    {
        DecodeService.DecodeStateChanged += DecodeStateChanged;
        DecodeService.PromptForUpload += OnPromptForUpload;
        _ = LoadInitialData();
        base.OnInitialized();
    }

    private async Task LoadInitialData()
    {
        // If the service already has a replay, use it; otherwise, fetch from DB
        if (DecodeService.LatestReplayHash is not null && DecodeService.LatestReplay is not null)
        {
            await SetLatestReplay(DecodeService.LatestReplayHash, DecodeService.LatestReplay);
        }
        else
        {
            var list = await DbService.GetFilteredReplayListsAsync(
                new ReplayFilter(new ReplaysRequest { Skip = 0, Take = 1 }));

            if (list.Count > 0)
            {
                var replay = await DbService.GetReplayByHashAsync(list[0].ReplayHash);
                if (replay is not null)
                {
                    await SetLatestReplay(list[0].ReplayHash, replay);
                }
            }
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task SetLatestReplay(string hash, ReplayDto replay, ReplayRatingDto? rating = null)
    {
        // Fetch rating immediately
        rating ??= await DbService.GetReplayRatingAsync(hash);

        latestReplayDetails = new ReplayDetails
        {
            ReplayHash = hash,
            Replay = replay,
            ReplayRatings = rating is not null ? [rating] : [],
        };
    }

    private async void DecodeStateChanged(object? sender, DecodeInfoEventArgs e)
    {
        if (e.Finished && DecodeService.LatestReplayHash is not null && DecodeService.LatestReplay is not null)
        {
            // Only update if it's actually newer than what we have (or if we have nothing)
            bool isNewer = latestReplayDetails == null ||
                           DecodeService.LatestReplay.Gametime > latestReplayDetails.Replay.Gametime;

            if (isNewer)
            {
                var rating = await RatingService.FetchAndSaveRating(DecodeService.LatestReplayHash);
                await SetLatestReplay(DecodeService.LatestReplayHash, DecodeService.LatestReplay, rating);
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private void OnPromptForUpload(object? sender, EventArgs e)

    {
        showUploadPrompt = true;
        InvokeAsync(StateHasChanged);
    }

    private void DeclineUpload()
    {
        showUploadPrompt = false;
    }

    private async Task AcceptUpload()
    {
        showUploadPrompt = false;
        var config = await PwaConfigService.GetConfig();
        config.UploadCredential = true;
        await PwaConfigService.SaveConfig(config);
        await DecodeService.TriggerUploadAsync();
    }

    private async Task UpdateRatings()
    {
        if (latestReplayDetails is null) return;
        var rating = await RatingService.FetchAndSaveRating(latestReplayDetails.ReplayHash);
        if (rating is null) return;

        latestReplayDetails.ReplayRatings = [rating];
        replayComponent?.Update(latestReplayDetails);
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DecodeService.DecodeStateChanged -= DecodeStateChanged;
        DecodeService.PromptForUpload -= OnPromptForUpload;
    }
}
